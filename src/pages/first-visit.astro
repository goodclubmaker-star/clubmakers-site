---
// /src/pages/first-visit.astro
// 처음 오시는 분 페이지 — 일반 골퍼 입구

import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "처음 오시는 분께";
const pageDescription = "골프채공작소 클럽메이커스가 처음이신 분을 위한 안내. 어떤 일로 오셨는지에 따라 가장 가까운 입구를 찾아드립니다. 비용·진행 과정·자주 묻는 질문 정리.";
const pageKeywords = "클럽메이커스 처음, 클럽피팅 처음, 골프채공작소 방문, 양재동 클럽피팅, 채기웅";

// 자주 묻는 첫 질문 5개
const faqs = [
  {
    q: "비용은 얼마나 드나요?",
    a: "작업과 분석에 따라 다릅니다. 그립 교체나 라이각 조정처럼 즉시 가능한 작업이 있고, 종합 분석이나 샤프트 교체처럼 시간이 더 필요한 작업이 있습니다. 자세한 가격은 작업 페이지에서 정리해 두었습니다.",
    link: { href: "/workshop", label: "작업·가격 보기 →" },
  },
  {
    q: "처음인데 어떻게 진행되나요?",
    a: "어떤 클럽이 어디서 불편하신지 먼저 듣는 것에서 시작합니다. 그 다음 측정, 분석, 처방 순서로 진행되는데 — 한 분 한 분 충분한 시간을 들여 봐드립니다. 자세한 진행 과정은 아래에 정리해 두었습니다.",
    link: null,
  },
  {
    q: "제 클럽을 갖고 가도 되나요?",
    a: "네, 오히려 그게 가장 좋습니다. 현재 쓰고 계신 클럽의 길이·라이각·무게·샤프트 강도을 직접 측정하는 것이 가장 정확한 출발점입니다. 가지고 계신 모든 클럽을 갖고 오셔도 좋습니다.",
    link: null,
  },
  {
    q: "예약은 꼭 해야 하나요?",
    a: "분석과 교육은 예약제로 진행합니다. 다만 그립 교체나 라이각 조정 같은 즉시 가능한 작업은 예약 없이 방문하셔도 됩니다. 분석·교육 시간과 겹치지 않도록 방문 전 전화 한 통 주시면 가장 확실합니다.",
    link: { href: "/contact", label: "예약·문의 →" },
  },
  {
    q: "어떤 분들이 주로 오시나요?",
    a: "구력 1년의 입문 골퍼부터 프로, 다른 피팅샵 운영자, 클럽메이킹을 배우고 싶은 분까지 다양합니다. 클럽피팅이 처음이라도, 또는 깊이 공부하시는 분이라도 — 본인의 자리에서 시작하실 수 있습니다.",
    link: null,
  },
];

// 4개 시나리오 카드
const scenarios = [
  {
    badge: "01",
    label: "FITTING",
    situation: "특정 클럽이 안 맞아요",
    examples: "드라이버 슬라이스, 7번 아이언 거리 부족, 후반에 무너지는 패턴 등",
    rec: "원인부터 추적하는 클럽피팅이 도움이 됩니다. 가시기 전에 증상별 진단 페이지를 먼저 살펴보시면 어떤 변수들이 관련 있는지 감을 잡으실 수 있습니다.",
    primary: { href: "/system", label: "피팅 시스템 보기 →" },
    secondary: { href: "/topics", label: "증상별 진단 먼저" },
  },
  {
    badge: "02",
    label: "REPAIR",
    situation: "샤프트 · 그립 · 라이각만 손보고 싶어요",
    examples: "샤프트 교체, 그립 교체, 라이각·로프트 조정, 길이 조정, 밸런스 조정 등",
    rec: "작업은 별도 예약 없이 방문하셔도 됩니다. 즉시 가능한 작업과 클럽을 맡기고 찾으셔야 하는 작업이 있어서, 방문하시면 종류에 맞게 안내드립니다.",
    primary: { href: "/workshop", label: "작업·가격 보기 →" },
    secondary: null,
  },
  {
    badge: "03",
    label: "STUDY",
    situation: "클럽피팅을 깊이 공부하고 싶어요",
    examples: "장비를 감이 아니라 구조로 이해하고 싶은 분, 피팅 책을 찾고 계신 분, 데이터 해석을 배우고 싶은 분 등",
    rec: "『실제적인 클럽피팅』 책이 있습니다. 본문 14 PART, 약 600페이지로 인터뷰부터 통합 결정까지 다룹니다. 인용 4개를 먼저 읽어보시면 책의 톤을 파악하실 수 있습니다.",
    primary: { href: "/book", label: "책 둘러보기 →" },
    secondary: { href: "/book/part-1", label: "PART 1 미리보기" },
  },
  {
    badge: "04",
    label: "LEARN",
    situation: "클럽피팅을 직접 배우고 싶어요",
    examples: "피팅샵 창업을 준비하시는 분, 클럽메이킹 작업을 배우고 싶은 분, 책을 현장 작업과 함께 익히고 싶은 분 등",
    rec: "채기웅 공작소장이 직접 진행하는 교육 과정이 있습니다. 책의 원칙을 현장 작업과 함께 익히는 방식입니다.",
    primary: { href: "/education", label: "교육 과정 보기 →" },
    secondary: null,
  },
];

// 피팅 진행 4단계
const stages = [
  {
    num: "01",
    label: "INTERVIEW",
    title: "인터뷰",
    desc: "어떤 클럽이 어디서 어떻게 불편하신지부터 듣습니다. 평소 라운드 패턴, 후반 변화, 가장 자주 나는 미스 등 — 측정 전에 골퍼의 이야기를 먼저 정리합니다.",
  },
  {
    num: "02",
    label: "MEASURE",
    title: "측정",
    desc: "신체 측정(키·WTF·악력 등), 현재 클럽 스펙(길이·라이각·무게·SW), 스윙 분석(키네마틱 시퀀스 결합), 론치모니터 데이터 — 4가지 영역을 함께 측정합니다.",
  },
  {
    num: "03",
    label: "ANALYZE",
    title: "분석",
    desc: "측정한 데이터를 종합해 원인을 추적합니다. 같은 슬라이스도 원인이 다르면 처방이 다릅니다 — 결과만 보고 장비를 바꾸지 않고, 무엇이 그 결과를 만들었는지부터 봅니다.",
  },
  {
    num: "04",
    label: "PRESCRIBE",
    title: "처방",
    desc: "길이·라이각·무게·샤프트 EI 등 변수를 결정합니다. 한 번에 여러 변수를 바꾸지 않고, 가장 근본 원인 하나부터 — 그래야 무엇이 효과를 만들었는지 알 수 있습니다.",
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schemaType="WebPage"
  keywords={pageKeywords}
>

  <!-- ==================== HERO ==================== -->
  <section class="fv-hero">
    <div class="container narrow">
      <p class="eyebrow">FIRST VISIT · 처음 오시는 분께</p>

      <h1 class="fv-title">
        어디로 가실지 <br />
        <em>함께 찾아드릴게요.</em>
      </h1>

      <p class="fv-lead">
        <strong>골프채공작소 클럽메이커스</strong>가 처음이세요? 어떤 일로 오셨는지에 따라 가까운 입구가 다릅니다.
        <strong>자기 상황을 미리 정리하지 않으셔도 괜찮습니다.</strong>
        먼저 전화 한 통이나 메시지 하나로 충분합니다.
      </p>

      <div class="fv-quick">
        <a href="/contact" class="quick-btn">
          <span>지금 바로 문의</span>
          <span>→</span>
        </a>
        <a href="#scenarios" class="quick-text">
          어떤 분께 어떤 입구가 맞는지 보기 ↓
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== INTRO ==================== -->
  <section class="fv-intro">
    <div class="container narrow">
      <p class="eyebrow">ABOUT · 어떤 곳인가요</p>
      <h2 class="section-title">
        친근한 <em>골프채 공작소</em>입니다
      </h2>

      <div class="prose">
        <p>
          클럽메이커스는 1985년에 시작했습니다. 채기웅 공작소장이 24년 동안 골프채를
          만지면서, 한 가지를 일관되게 지켜왔습니다 —
          <strong>결과가 아니라 원인부터 본다.</strong>
        </p>
        <p>
          슬라이스가 난다고 헤드를 바꾸지 않고, 거리가 안 난다고 샤프트부터 교체하지
          않습니다. 같은 증상도 원인이 다르면 처방이 다르다는 것을 24년의 경험이
          가르쳐줬습니다.
        </p>
        <p>
          그래서 분석은 <strong>인터뷰부터 시작</strong>합니다. 어떤 클럽이 어디서 어떻게
          불편하신지 천천히 듣고, 그 다음에 측정으로 넘어갑니다. 한 분 한 분 충분한 시간을
          들여 봐드리기 위해 동시에 여러 분을 받지 않습니다.
        </p>
        <p>
          작업은 손에 익은 24년의 작업으로, 분석은 키네마틱 시퀀스가 결합된 시스템으로,
          그리고 클럽피팅을 배우고 싶은 분께는 직접 가르쳐 드립니다 —
          <strong>골프채를 다루는 네 가지 방식이 한자리에 있습니다.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="fv-faq">
    <div class="container narrow">
      <p class="eyebrow">FAQ · 자주 묻는 첫 질문</p>
      <h2 class="section-title">
        처음 오시는 분이 <em>가장 자주 물으시는 것</em>
      </h2>

      <ol class="faq-list">
        {faqs.map((f, i) => (
          <li class="faq-item">
            <p class="faq-num">Q{String(i + 1).padStart(2, "0")}</p>
            <h3 class="faq-q">{f.q}</h3>
            <p class="faq-a">{f.a}</p>
            {f.link && (
              <a href={f.link.href} class="faq-link">{f.link.label}</a>
            )}
          </li>
        ))}
      </ol>

      <p class="faq-foot">
        더 많은 질문은 <a href="/faq">자주 묻는 질문</a> 페이지에 정리되어 있습니다.
      </p>
    </div>
  </section>

  <!-- ==================== 4 SCENARIOS ==================== -->
  <section id="scenarios" class="fv-scenarios">
    <div class="container">
      <div class="scenarios-head">
        <p class="eyebrow">PATHS · 어떤 일로 오셨나요</p>
        <h2 class="section-title">
          상황에 따라 <em>가까운 입구</em>가 다릅니다
        </h2>
        <p class="section-lead">
          본인 상황과 가장 가까운 카드를 골라보세요.
          여러 가지가 동시에 해당되시면, 가장 절실한 것부터 시작하셔도 됩니다.
        </p>
      </div>

      <div class="scenarios-grid">
        {scenarios.map((s) => (
          <article class="scenario-card">
            <div class="scenario-head">
              <span class="scenario-badge">{s.badge}</span>
              <span class="scenario-label">{s.label}</span>
            </div>
            <h3 class="scenario-situation">"{s.situation}"</h3>
            <p class="scenario-examples">예: {s.examples}</p>
            <p class="scenario-rec">{s.rec}</p>
            <div class="scenario-cta">
              <a href={s.primary.href} class="scenario-btn">{s.primary.label}</a>
              {s.secondary && (
                <a href={s.secondary.href} class="scenario-sub">{s.secondary.label}</a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS (4 stages) ==================== -->
  <section class="fv-stages">
    <div class="container narrow">
      <p class="eyebrow">PROCESS · 피팅이 어떻게 진행되나요</p>
      <h2 class="section-title">
        분석은 <em>인터뷰부터</em> 시작합니다
      </h2>
      <p class="section-lead">
        측정값을 먼저 보지 않습니다. 골퍼의 이야기를 듣고, 그 이야기를 측정으로 검증한 다음,
        검증된 측정에서 원인을 찾고, 원인에 맞는 처방을 드립니다.
      </p>

      <ol class="stages-list">
        {stages.map((st) => (
          <li class="stage-item">
            <div class="stage-num">{st.num}</div>
            <div class="stage-body">
              <p class="stage-label">{st.label}</p>
              <h3 class="stage-title">{st.title}</h3>
              <p class="stage-desc">{st.desc}</p>
            </div>
          </li>
        ))}
      </ol>

      <aside class="stages-note">
        <p>
          <strong>한 번 방문에 모든 단계가 한 번에 진행됩니다.</strong>
          평균 1.5~2시간 정도 걸립니다. 처방 결과를 바로 시타로 검증하고, 필요하면
          현장에서 미세 보정까지 진행합니다.
        </p>
        <p class="stages-note-link">
          더 자세한 진행 과정은 <a href="/system">공작소의 시스템</a> 페이지에서.
        </p>
      </aside>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="fv-final">
    <div class="container narrow">
      <p class="eyebrow">NEXT STEP · 다음 단계</p>
      <h2 class="final-title">
        어떤 일로 오셨든, <br />
        <em>편하게 연락주세요.</em>
      </h2>

      <p class="final-lead">
        "이 정도 일로 연락드려도 될까" 하고 망설이지 않으셔도 됩니다.
        막연한 궁금증부터 구체적인 작업 문의까지 — 어떤 내용이든 환영합니다.
      </p>

      <div class="final-cta">
        <a href="/contact" class="btn-large">
          <span>예약 · 문의하기</span>
          <span>→</span>
        </a>
      </div>

      <div class="final-resources">
        <p class="resources-label">먼저 자료부터 보고 싶으시다면</p>
        <div class="resources-links">
          <a href="/book">『실제적인 클럽피팅』 책 →</a>
          <a href="/topics">증상별 진단 9가지 →</a>
          <a href="/glossary">클럽피팅 용어사전 →</a>
          <a href="/faq">전체 자주 묻는 질문 →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>


<style>
  :root {
    --bg: #F8F5EE; --bg-elev: #FFFFFF; --bg-soft: #F1ECE0;
    --text: #1F1B16; --text-2: #3A332A; --muted: #6B6358;
    --rule: #E2DACA; --rule-2: #D2C9B5;
    --accent: #2C5F4F; --accent-2: #87A99B; --accent-soft: #E6EDE7;
    --serif: "Noto Serif KR", "Apple SD Gothic Neo", serif;
    --sans:  "Pretendard", "Apple SD Gothic Neo", system-ui, sans-serif;
  }

  .container { width: 100%; max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .narrow { max-width: 760px; }

  .eyebrow {
    font-family: var(--sans);
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .15em;
    color: var(--accent);
    text-transform: uppercase;
    margin: 0 0 1.25rem;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(1.875rem, 4.5vw, 2.875rem);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -.02em;
    color: var(--text);
    margin: 0 0 1.5rem;
  }
  .section-title em {
    font-style: normal;
    color: var(--accent);
  }
  .section-lead {
    font-family: var(--sans);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--text-2);
    max-width: 580px;
    margin: 0;
  }
  .prose p {
    font-family: var(--sans);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--text-2);
    margin: 0 0 1.1em;
  }
  .prose p strong { color: var(--text); font-weight: 600; }

  /* ==================== HERO ==================== */
  .fv-hero {
    background: var(--bg);
    padding: 96px 0 72px;
    border-bottom: 1px solid var(--rule);
  }
  .fv-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -.025em;
    color: var(--text);
    margin: 0 0 2rem;
  }
  .fv-title em {
    font-style: normal;
    color: var(--accent);
    font-weight: 600;
  }
  .fv-lead {
    font-family: var(--sans);
    font-size: 1.1875rem;
    line-height: 1.85;
    color: var(--text-2);
    max-width: 680px;
    margin: 0 0 2.5rem;
  }
  .fv-lead strong { color: var(--text); font-weight: 600; }

  .fv-quick {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem 2rem;
  }
  .quick-btn {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    padding: 16px 28px;
    background: var(--text);
    color: var(--bg);
    border-radius: 2px;
    text-decoration: none;

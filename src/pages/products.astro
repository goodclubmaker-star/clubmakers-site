---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '자체 제품 — VERSUS / DEFINE / KRZ / 뽀로로 — 클럽메이커스';
const description = '클럽메이커스가 직접 설계하고 제작한 제품들. VERSUS 맞춤 드라이버 (650,000원), DEFINE 하이브리드 샤프트, KRZ 203H 헤드, 뽀로로 라이센스 골프 라인업.';
---

<BaseLayout title={title} description={description}>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero products-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">PRODUCTS · 자체 제품</div>
      <h1>공작소가 만든 제품들</h1>
      <p class="page-hero-subtitle">
        공작소가 직접 설계하고 제작한 제품들입니다.
        VERSUS 맞춤 드라이버를 중심으로, DEFINE 하이브리드 샤프트와 KRZ 203H 헤드, 그리고 뽀로로 라이센스 라인업이 한자리에 있습니다.
      </p>
    </div>
  </section>

  <!-- ============================================================
       제품 바로가기 네비게이션 (앵커 칩)
       ============================================================ -->
  <nav class="products-nav" aria-label="제품 바로가기">
    <div class="products-nav-inner">
      <a href="#versus-driver" class="products-nav-chip">VERSUS 드라이버</a>
      <a href="#define-shaft" class="products-nav-chip">DEFINE 샤프트</a>
      <a href="#krz" class="products-nav-chip">KRZ 203H</a>
      <a href="#pororo" class="products-nav-chip">뽀로로 헤드커버</a>
      <a href="#pororo-ball" class="products-nav-chip">뽀로로 골프공</a>
    </div>
  </nav>

  <!-- ============================================================
       SECTION 01 — VERSUS 드라이버 헤드
       ============================================================ -->
  <section id="versus-driver" class="section section-versus-head">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 01 · VERSUS 드라이버 헤드</p>
      <h2 class="versus-head-title">검정 무광, 0.5° 훅페이스</h2>
      <p class="versus-head-lede">
        딥페이스와 샬로우의 중간 타입입니다.
        어떤 레벨의 골퍼가 들어와도 헤드가 자연스럽게 적응할 수 있도록 설계했습니다.
      </p>

      <div class="versus-head-layout">
        <figure class="versus-head-image">
          <img
            src="/products/versus-head.jpg"
            alt="VERSUS 드라이버 헤드 — 검정 무광 0.5° 훅페이스"
            loading="lazy"
          />
          <figcaption class="versus-head-caption">VERSUS 드라이버 헤드 — 검정 무광</figcaption>
        </figure>

        <div class="versus-head-specs">
          <article class="versus-spec">
            <p class="versus-spec-label">기본 로프트</p>
            <p class="versus-spec-value">10.5°</p>
          </article>
          <article class="versus-spec">
            <p class="versus-spec-label">페이스</p>
            <p class="versus-spec-value">0.5° 훅페이스</p>
          </article>
          <article class="versus-spec">
            <p class="versus-spec-label">표면</p>
            <p class="versus-spec-value">검정 무광</p>
          </article>
          <article class="versus-spec">
            <p class="versus-spec-label">페이스 타입</p>
            <p class="versus-spec-value">중간 타입</p>
            <p class="versus-spec-note">딥페이스와 샬로우 사이</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 02 — VERSUS 드라이버 샤프트 5종
       ============================================================ -->
  <section class="section section-versus-shaft">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 02 · VERSUS 드라이버 샤프트 5종</p>
      <h2 class="versus-shaft-title">헤드 스피드별, 다섯 가지 답</h2>
      <p class="versus-shaft-lede">
        버트부터 팁까지의 강성 분포로 헤드가 들어오는 타이밍을 설계합니다.
        같은 헤드라도 골퍼마다 들어오는 속도와 타이밍이 다르기 때문입니다.
      </p>

      <figure class="versus-shaft-graph">
        <div class="versus-shaft-graph-frame">
          <svg viewBox="0 0 720 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="VERSUS 5종 샤프트 디플렉션 분포 그래프">
            <rect width="720" height="320" fill="#F1ECE0" />
            <g stroke="#D2C9B5" stroke-width="0.5" opacity="0.6">
              <line x1="60" y1="60" x2="60" y2="250" />
              <line x1="200" y1="60" x2="200" y2="250" />
              <line x1="340" y1="60" x2="340" y2="250" />
              <line x1="480" y1="60" x2="480" y2="250" />
              <line x1="620" y1="60" x2="620" y2="250" />
            </g>
            <line x1="60" y1="250" x2="620" y2="250" stroke="#C8C0AB" stroke-width="1" />

            <path d="M 60,95 Q 340,170 620,115" stroke="#1F1B16" stroke-width="2.2" fill="none" stroke-linecap="round" />
            <path d="M 60,108 Q 340,188 620,128" stroke="#C19A4F" stroke-width="2.2" fill="none" stroke-linecap="round" />
            <path d="M 60,121 Q 340,206 620,141" stroke="#3A332A" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.85" />
            <path d="M 60,134 Q 340,222 620,154" stroke="#6B6358" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7" />
            <path d="M 60,147 Q 340,238 620,167" stroke="#87A99B" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.75" />

            <text x="630" y="118" font-family="Pretendard, sans-serif" font-size="12" font-weight="600" fill="#1F1B16">75MHS</text>
            <text x="630" y="131" font-family="Pretendard, sans-serif" font-size="12" font-weight="600" fill="#C19A4F">65MS</text>
            <text x="630" y="144" font-family="Pretendard, sans-serif" font-size="12" font-weight="500" fill="#3A332A">55MS</text>
            <text x="630" y="157" font-family="Pretendard, sans-serif" font-size="12" font-weight="500" fill="#6B6358">55MR</text>
            <text x="630" y="170" font-family="Pretendard, sans-serif" font-size="12" font-weight="500" fill="#87A99B">45LU</text>

            <text x="60" y="280" font-family="Pretendard, sans-serif" font-size="11" letter-spacing="0.18em" fill="#6B6358">BUTT</text>
            <text x="620" y="280" font-family="Pretendard, sans-serif" font-size="11" letter-spacing="0.18em" fill="#6B6358" text-anchor="end">TIP</text>
          </svg>
        </div>
        <figcaption class="versus-shaft-graph-caption">5종 모델별 디플렉션 분포 — 버트(끝)에서 팁(헤드 쪽)까지</figcaption>
      </figure>

      <div class="versus-shaft-table-wrap">
        <table class="versus-shaft-table">
          <thead>
            <tr>
              <th scope="col">모델</th>
              <th scope="col">무게</th>
              <th scope="col">토크</th>
              <th scope="col">강도</th>
              <th scope="col">헤드 스피드</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">VERSUS 45LU</th>
              <td>55 g</td><td>4.2</td><td>UNI</td><td>85 ~ 95 mph</td>
            </tr>
            <tr>
              <th scope="row">VERSUS 55MR</th>
              <td>60 g</td><td>3.8</td><td>R</td><td>90 ~ 100 mph</td>
            </tr>
            <tr>
              <th scope="row">VERSUS 55MS</th>
              <td>63 g</td><td>3.3</td><td>S</td><td>92 ~ 105 mph</td>
            </tr>
            <tr>
              <th scope="row">VERSUS 65MS</th>
              <td>69 g</td><td>3.1</td><td>S</td><td>95 ~ 110 mph</td>
            </tr>
            <tr>
              <th scope="row">VERSUS 75MHS</th>
              <td>75 g</td><td>2.7</td><td>S</td><td>100 ~ 115 mph</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VERSUS 맞춤 드라이버 — 가격 강조 박스
       (검은 배경 + 골드 라벨 — workshop-qna의 비용 박스 패턴 차용)
       ============================================================ -->
  <section class="versus-price">
    <div class="versus-price-inner">
      <p class="versus-price-eyebrow">VERSUS 맞춤 드라이버</p>
      <h2 class="versus-price-heading">VERSUS — 우승을 향하여</h2>
      <p class="versus-price-tagline">
        클럽메이커스 자체 R&amp;D · 헤드와 샤프트의 완전한 결합
      </p>

      <div class="versus-price-amount">
        <span class="versus-price-number">650,000</span>
        <span class="versus-price-unit">원</span>
      </div>

      <ul class="versus-price-includes">
        <li>헤드</li>
        <li>샤프트</li>
        <li>그립</li>
        <li>피팅</li>
        <li>제작</li>
      </ul>
      <p class="versus-price-includes-note">일체 포함</p>

      <div class="versus-price-actions">
        <a href="/contact" class="versus-cta-primary">예약·문의</a>
        <a href="/system" class="versus-cta-ghost">분석 시스템 보기 →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 03 — DEFINE 하이브리드 샤프트
       ============================================================ -->
  <section id="define-shaft" class="section section-define">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 03 · DEFINE 하이브리드 샤프트</p>
      <h2 class="define-title">하이브리드와 롱 아이언, 전용 설계</h2>
      <p class="define-lede">
        하이브리드와 긴 아이언을 위한 샤프트입니다.
        가벼운 중량과 팁 안정화로, 공격적인 볼 스트라이킹을 만들어 냅니다.
      </p>

      <div class="define-shaft-svg" aria-hidden="true">
        <svg viewBox="0 0 720 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="defineShaftGrad" x1="0%" x2="100%" y1="0%" y2="0%">
              <stop offset="0%" stop-color="#1F1B16" stop-opacity="0.92" />
              <stop offset="55%" stop-color="#3A332A" stop-opacity="0.65" />
              <stop offset="100%" stop-color="#6B6358" stop-opacity="0.45" />
            </linearGradient>
          </defs>
          <path d="M 30,28 L 670,30 L 670,34 L 30,32 Z" fill="url(#defineShaftGrad)" />
          <rect x="660" y="24" width="14" height="16" fill="#C19A4F" rx="2" />
          <rect x="22" y="26" width="8" height="12" fill="#1F1B16" rx="1" />
          <text x="30" y="14" font-family="Pretendard, sans-serif" font-size="9" letter-spacing="0.22em" fill="#6B6358">BUTT</text>
          <text x="670" y="14" text-anchor="end" font-family="Pretendard, sans-serif" font-size="9" letter-spacing="0.22em" fill="#6B6358">TIP</text>
        </svg>
      </div>

      <div class="define-specs">
        <article class="define-spec">
          <p class="define-spec-label">REGULAR</p>
          <p class="define-spec-value">67 g</p>
        </article>
        <article class="define-spec">
          <p class="define-spec-label">STIFF</p>
          <p class="define-spec-value">70 g</p>
        </article>
        <article class="define-spec">
          <p class="define-spec-label">기본 길이</p>
          <p class="define-spec-value">42″</p>
        </article>
      </div>

      <p class="define-note">DEFINE 샤프트 실제품 사진은 별도 정리 후 추가됩니다.</p>
    </div>
  </section>

  <!-- ============================================================
       SECTION 04 — KRZ 203H 하이브리드 헤드
       ============================================================ -->
  <section id="krz" class="section section-krz">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 04 · KRZ 203H 하이브리드 헤드</p>
      <h2 class="krz-title">CAD 설계로 태어난</h2>
      <p class="krz-subtitle">203H Hybrid · Crafted by Clubmakers</p>
      <p class="krz-lede">
        자체 CAD 설계로 모델링한 하이브리드 헤드입니다.
        19°와 23° 두 가지 로프트로, 롱 아이언 대용부터 미들 거리까지 커버합니다.
      </p>

      <figure class="krz-wireframe">
        <img
          src="/products/krz-wireframe.jpg"
          alt="KRZ 203H 하이브리드 헤드 — CAD 와이어프레임 모델링"
          loading="lazy"
        />
        <figcaption class="krz-wireframe-caption">CAD WIREFRAME · 203H 하이브리드 자체 설계 모델링</figcaption>
      </figure>

      <div class="krz-cuts">
        <figure class="krz-cut">
          <img src="/products/krz-cut1.jpg" alt="KRZ 203H — 토 사이드" loading="lazy" />
        </figure>
        <figure class="krz-cut">
          <img src="/products/krz-cut2.jpg" alt="KRZ 203H — 솔" loading="lazy" />
        </figure>
        <figure class="krz-cut">
          <img src="/products/krz-cut3.jpg" alt="KRZ 203H — 어드레스 뷰" loading="lazy" />
        </figure>
      </div>

      <div class="krz-specs-wrap">
        <p class="krz-specs-label">MAIN SPECS · 주요 사양</p>
        <div class="krz-specs-scroll">
          <table class="krz-specs">
            <thead>
              <tr>
                <th scope="col">로프트</th>
                <th scope="col">라이</th>
                <th scope="col">길이</th>
                <th scope="col">전체 무게 (SW)</th>
                <th scope="col">킥포인트</th>
                <th scope="col">헤드 M.O.I</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>19°</td><td>59°</td><td>39.75″</td><td>345 g (D2)</td><td>MID</td><td>2,468 g·cm²</td>
              </tr>
              <tr>
                <td>23°</td><td>59.5°</td><td>39.25″</td><td>347 g (D2)</td><td>MID</td><td>2,270 g·cm²</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <aside class="krz-matched-shaft">
        <p class="krz-matched-eyebrow">MATCHED SHAFT · 하이브리드 전용 설계</p>
        <h3 class="krz-matched-title">DEFINE 635VTM</h3>
        <p class="krz-matched-spec">68 g (40″) · Torque 3.3 ~ 3.5 · Regular / Stiff</p>
      </aside>
    </div>
  </section>

  <!-- ============================================================
       별도 라인업 구분선
       ============================================================ -->
  <div class="lineup-divider">
    <div class="lineup-divider-inner">
      <span class="lineup-divider-line"></span>
      <p class="lineup-divider-text">
        <span class="lineup-divider-ko">별도 라인업</span>
        <span class="lineup-divider-en">LICENSED COLLECTION</span>
      </p>
      <span class="lineup-divider-line"></span>
    </div>
  </div>

  <!-- ============================================================
       SECTION 05 — 뽀로로 골프 (라이센스 + 헤드커버 + 갤러리)
       ============================================================ -->
  <section id="pororo" class="section section-pororo">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 05 · 뽀로로 골프</p>
      <h2 class="pororo-title">선수들의 멘탈 파트너,<br />뽀로로 헤드커버</h2>
      <p class="pororo-lede">
        ㈜아이코닉스로부터 '뽀롱뽀롱 뽀로로' 라이센스를 위임받아 제작한 골프 액세서리 라인업입니다.
        KLPGA·LPGA 투어 무대에서 선수들의 캐디백 옆을 함께 했습니다.
      </p>

      <!-- 헤드커버 제품 카드 -->
      <div class="pororo-products">
        <article class="pororo-product">
          <div class="pororo-product-image">
            <img src="/products/pororo-cover-pororo.jpg" alt="뽀로로 드라이버 헤드커버" loading="lazy" />
          </div>
          <div class="pororo-product-body">
            <p class="pororo-product-label">DRIVER COVER</p>
            <h3 class="pororo-product-name">뽀로로 헤드커버</h3>
            <p class="pororo-product-price">49,000원</p>
          </div>
        </article>
        <article class="pororo-product">
          <div class="pororo-product-image">
            <img src="/products/pororo-cover-krong.jpg" alt="크롱 드라이버 헤드커버" loading="lazy" />
          </div>
          <div class="pororo-product-body">
            <p class="pororo-product-label">DRIVER COVER</p>
            <h3 class="pororo-product-name">크롱 헤드커버</h3>
            <p class="pororo-product-price">49,000원</p>
          </div>
        </article>
      </div>
      <p class="pororo-product-note">페어웨이 우드 커버는 구입 문의 부탁드립니다.</p>

      <!-- 박희영 LPGA 우승 -->
      <div class="pororo-block pororo-block-park">
        <p class="pororo-block-eyebrow">박희영 프로 · LPGA 우승 파트너</p>
        <h3 class="pororo-block-title">투어 우승의 순간, 헤드커버가 함께</h3>
        <p class="pororo-block-lede">
          박희영 프로의 LPGA 매뉴라이프 파이낸셜 클래식 우승 당시, 매경닷컴은 클럽메이커스 뽀로로 헤드커버를 함께 보도했습니다.
          연장 승부 속에서도 "앙증맞은 헤드커버를 보면서 심리적인 안정감을 찾는 모습"으로 골퍼의 멘탈 파트너 역할이 조명되었습니다.
        </p>

        <figure class="pororo-press">
          <img src="/products/pororo-park-press.jpg" alt="매경닷컴 MK스포츠 · 박희영 프로 LPGA 우승 보도" loading="lazy" />
          <figcaption>매경닷컴 MK스포츠 · LPGA 매뉴라이프 파이낸셜 클래식 우승 보도</figcaption>
        </figure>

        <div class="pororo-gallery pororo-gallery-park">
          <figure><img src="/products/pororo-park-1.jpg" alt="박희영 프로와 뽀로로 헤드커버 - Newsen" loading="lazy" /></figure>
          <figure><img src="/products/pororo-park-2.jpg" alt="박희영 프로 OSEN — '뽀로로 친구들과'" loading="lazy" /></figure>
          <figure><img src="/products/pororo-park-3.jpg" alt="박희영 프로 필드 컷" loading="lazy" /></figure>
          <figure><img src="/products/pororo-park-4.jpg" alt="박희영 프로 미즈노 부스" loading="lazy" /></figure>
        </div>
      </div>

      <!-- 김효주 스위스 우승 -->
      <div class="pororo-block pororo-block-kim">
        <p class="pororo-block-eyebrow">김효주 프로 · 스위스 우승 파트너</p>
        <h3 class="pororo-block-title">우승의 순간, 함께한 크롱 헤드커버</h3>
        <p class="pororo-block-lede">
          김효주 프로의 스위스 우승 무대에 동행한 크롱 헤드커버.
          투어에서 함께한 캐릭터는 골퍼 옆에 머무는 멘탈 파트너의 역할을 합니다.
        </p>

        <div class="pororo-gallery pororo-gallery-kim">

---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '자체 제품 — VERSUS / DEFINE / KRZ / 뽀로로 — 클럽메이커스';
const description = '클럽메이커스가 직접 설계하고 제작한 제품들. VERSUS 맞춤 드라이버 (650,000원), DEFINE 하이브리드 샤프트, KRZ 203H 헤드, 뽀로로 라이센스 골프 라인업.';
---

<BaseLayout title={title} description={description}>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero products-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">PRODUCTS · 자체 제품</div>
      <h1>공작소가 만든 제품들</h1>
      <p class="page-hero-subtitle">
        공작소가 직접 설계하고 제작한 제품들입니다.
        VERSUS 맞춤 드라이버를 중심으로, DEFINE 하이브리드 샤프트와 KRZ 203H 헤드, 그리고 뽀로로 라이센스 라인업이 한자리에 있습니다.
      </p>
    </div>
  </section>

  <!-- ============================================================
       SECTION 01 — VERSUS 드라이버 헤드
       ============================================================ -->
  <section class="section section-versus-head">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 01 · VERSUS 드라이버 헤드</p>
      <h2 class="versus-head-title">검정 무광, 0.5° 훅페이스</h2>
      <p class="versus-head-lede">
        딥페이스와 샬로우의 중간 타입입니다.
        어떤 레벨의 골퍼가 들어와도 헤드가 자연스럽게 적응할 수 있도록 설계했습니다.
      </p>

      <div class="versus-head-layout">
        <figure class="versus-head-image">
          <img
            src="/products/versus-head.jpg"
            alt="VERSUS 드라이버 헤드 — 검정 무광 0.5° 훅페이스"
            loading="lazy"
          />
          <figcaption class="versus-head-caption">VERSUS 드라이버 헤드 — 검정 무광</figcaption>
        </figure>

        <div class="versus-head-specs">
          <article class="versus-spec">
            <p class="versus-spec-label">기본 로프트</p>
            <p class="versus-spec-value">10.5°</p>
          </article>
          <article class="versus-spec">
            <p class="versus-spec-label">페이스</p>
            <p class="versus-spec-value">0.5° 훅페이스</p>
          </article>
          <article class="versus-spec">
            <p class="versus-spec-label">표면</p>
            <p class="versus-spec-value">검정 무광</p>
          </article>
          <article class="versus-spec">
            <p class="versus-spec-label">페이스 타입</p>
            <p class="versus-spec-value">중간 타입</p>
            <p class="versus-spec-note">딥페이스와 샬로우 사이</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VERSUS 맞춤 드라이버 — 가격 강조 박스
       (검은 배경 + 골드 라벨 — workshop-qna의 비용 박스 패턴 차용)
       ============================================================ -->
  <section class="versus-price">
    <div class="versus-price-inner">
      <p class="versus-price-eyebrow">VERSUS 맞춤 드라이버</p>
      <h2 class="versus-price-heading">VERSUS — 우승을 향하여</h2>
      <p class="versus-price-tagline">
        클럽메이커스 자체 R&amp;D · 헤드와 샤프트의 완전한 결합
      </p>

      <div class="versus-price-amount">
        <span class="versus-price-number">650,000</span>
        <span class="versus-price-unit">원</span>
      </div>

      <ul class="versus-price-includes">
        <li>헤드</li>
        <li>샤프트</li>
        <li>그립</li>
        <li>피팅</li>
        <li>제작</li>
      </ul>
      <p class="versus-price-includes-note">일체 포함</p>

      <div class="versus-price-actions">
        <a href="/contact" class="versus-cta-primary">예약·문의</a>
        <a href="/system" class="versus-cta-ghost">분석 시스템 보기 →</a>
      </div>
    </div>
  </section>

</BaseLayout>


<style>
  /* ============================================================
     SECTION 베이스 (페이지 로컬)
     글로벌 .section / .section-eyebrow 와 충돌하지 않도록
     versus-head- / versus-price- 프리픽스로 스코프
     ============================================================ */
  .section {
    padding: clamp(4rem, 8vw, 6rem) 1.5rem;
    background: var(--bg);
  }
  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ============================================================
     SECTION 01 — VERSUS 헤드
     ============================================================ */
  .versus-head-title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    line-height: 1.35;
    color: var(--ink);
    margin: 0.4rem 0 1.25rem;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .versus-head-lede {
    font-family: var(--sans);
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-2);
    max-width: 60ch;
    margin: 0 0 3rem;
  }

  .versus-head-layout {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 3rem;
    align-items: stretch;
  }

  .versus-head-image {
    margin: 0;
    background: var(--bg-soft);
    border: 1px solid var(--rule);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
  }
  .versus-head-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .versus-head-caption {
    position: absolute;
    bottom: 0.75rem;
    left: 0.9rem;
    font-family: var(--sans);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    color: rgba(31, 27, 22, 0.55);
    background: rgba(248, 245, 238, 0.85);
    padding: 0.3rem 0.6rem;
    border-radius: 2px;
  }

  .versus-head-specs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }
  .versus-spec {
    padding: 1.5rem 1.25rem;
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 110px;
  }
  .versus-spec-label {
    font-family: var(--sans);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    text-transform: uppercase;
    margin: 0 0 0.65rem;
    font-weight: 500;
  }
  .versus-spec-value {
    font-family: var(--serif);
    font-size: 1.35rem;
    color: var(--ink);
    margin: 0;
    font-weight: 600;
    line-height: 1.2;
  }
  .versus-spec-note {
    font-family: var(--sans);
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0.5rem 0 0;
    line-height: 1.5;
  }

  /* ============================================================
     VERSUS 맞춤 드라이버 — 가격 박스
     ============================================================ */
  .versus-price {
    padding: clamp(4.5rem, 9vw, 7rem) 1.5rem;
    background: #1F1B16; /* var(--ink) 톤 */
    color: #F8F5EE;
    position: relative;
  }
  .versus-price::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 1px;
    background: var(--gold);
    opacity: 0.6;
  }
  .versus-price-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .versus-price-eyebrow {
    font-family: var(--sans);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    color: var(--gold);
    text-transform: uppercase;
    margin: 0 0 1.5rem;
    font-weight: 500;
  }
  .versus-price-heading {
    font-family: var(--serif);
    font-size: clamp(2rem, 4.2vw, 2.8rem);
    color: #F8F5EE;
    margin: 0 0 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }
  .versus-price-tagline {
    font-family: var(--sans);
    font-size: 1rem;
    color: rgba(248, 245, 238, 0.7);
    margin: 0 0 3rem;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }
  .versus-price-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.3rem;
    margin: 0 0 2rem;
  }
  .versus-price-number {
    font-family: var(--serif);
    font-size: clamp(3rem, 6.5vw, 4.5rem);
    color: var(--gold);
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.005em;
  }
  .versus-price-unit {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    color: var(--gold);
    font-weight: 400;
  }
  .versus-price-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    column-gap: 1.25rem;
    row-gap: 0.5rem;
  }
  .versus-price-includes li {
    font-family: var(--sans);
    font-size: 0.95rem;
    color: rgba(248, 245, 238, 0.85);
    position: relative;
  }
  .versus-price-includes li:not(:last-child)::after {
    content: '·';
    position: absolute;
    right: -0.85rem;
    top: 0;
    color: rgba(193, 154, 79, 0.5);
  }
  .versus-price-includes-note {
    font-family: var(--sans);
    font-size: 0.82rem;
    color: rgba(248, 245, 238, 0.5);
    margin: 0 0 3rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .versus-price-actions {
    display: flex;
    justify-content: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .versus-cta-primary {
    display: inline-block;
    padding: 0.95rem 2rem;
    background: var(--accent);
    color: #F8F5EE;
    font-family: var(--sans);
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 2px;
    letter-spacing: 0.04em;
    transition: background 0.2s ease;
  }
  .versus-cta-primary:hover {
    background: #234B3F;
  }
  .versus-cta-ghost {
    display: inline-block;
    padding: 0.95rem 2rem;
    background: transparent;
    color: var(--gold);
    border: 1px solid rgba(193, 154, 79, 0.45);
    font-family: var(--sans);
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 2px;
    letter-spacing: 0.04em;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .versus-cta-ghost:hover {
    border-color: var(--gold);
    background: rgba(193, 154, 79, 0.08);
  }

  /* ============================================================
     모바일
     ============================================================ */
  @media (max-width: 860px) {
    .versus-head-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
  @media (max-width: 540px) {
    .versus-head-specs {
      grid-template-columns: 1fr;
    }
    .versus-spec { min-height: auto; }
    .versus-price-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .versus-cta-primary,
    .versus-cta-ghost {
      text-align: center;
    }
  }
</style>

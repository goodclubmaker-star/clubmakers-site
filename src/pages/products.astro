---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '자체 제품 — VERSUS 드라이버 · KRZ 203H 하이브리드 · 뽀로로 라이센스 — 골프채공작소 클럽메이커스';
const description = '공작소가 직접 설계하고 만든 제품들입니다. VERSUS 맞춤 드라이버(헤드·샤프트·그립·피팅·제작 포함 65만원), KRZ 203H 하이브리드(MOI 2,468 g·cm²), 뽀로로 라이센스 헤드커버. 박희영·김효주 프로가 LPGA 우승 시 사용한 뽀로로 헤드커버를 만든 곳입니다.';
---

<BaseLayout title={title} description={description}>

  <!-- ============================================================
       HERO — 직접 만든, 한 자루
       ============================================================ -->
  <section class="page-hero products-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">PRODUCTS · 자체 제품</div>
      <h1>직접 만든, 한 자루</h1>
      <p class="page-hero-subtitle">
        공작소가 설계하고 깎고 조립한 제품들입니다.
        VERSUS 맞춤 드라이버를 중심으로,
        KRZ 203H 하이브리드, 그리고 LPGA 투어 현장에서 선수들이 함께한 뽀로로 라이센스 라인업이 한자리에 있습니다.
      </p>
      <p class="page-hero-meta">1985년부터 25년 — 채기웅 공작소장 제작</p>
    </div>
  </section>

  <!-- ============================================================
       SECTION 01 — VERSUS 드라이버
       ============================================================ -->
  <section class="section section-versus">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 01 · VERSUS 드라이버</p>
      <h2 class="section-title">검정 무광, 0.5° 훅페이스</h2>
      <p class="section-lede">
        딥페이스와 샬로우의 중간 타입입니다.
        체격·스윙·임팩트 패턴이 다른 골퍼들이 들어와도 헤드가 자연스럽게 적응하도록 설계했습니다.
        헤드·샤프트·그립·피팅·제작까지 한 자루로 묶어 65만원입니다.
      </p>

      <div class="versus-grid">
        <figure class="vp vp-tall">
          <img src="/images/products/versus-head-1.jpg" alt="VERSUS 드라이버 헤드 정면 — 검정 무광 0.5° 훅페이스"
               width="1081" height="1440" loading="lazy" decoding="async" />
          <figcaption>VERSUS 헤드 · 정면</figcaption>
        </figure>
        <figure class="vp vp-tall">
          <img src="/images/products/versus-head-2.jpg" alt="VERSUS 드라이버 헤드 측면 — 솔과 페이스 각도"
               width="1081" height="1440" loading="lazy" decoding="async" />
          <figcaption>VERSUS 헤드 · 측면</figcaption>
        </figure>
        <figure class="vp vp-wide">
          <img src="/images/products/versus-shaft-1.jpg" alt="VERSUS 샤프트 — 55MS 그라파이트"
               width="1200" height="843" loading="lazy" decoding="async" />
          <figcaption>VERSUS 샤프트 · 55MS</figcaption>
        </figure>
        <figure class="vp vp-wide">
          <img src="/images/products/versus-shaft-2.jpg" alt="VERSUS 샤프트 — 65MS 그라파이트"
               width="1200" height="674" loading="lazy" decoding="async" />
          <figcaption>VERSUS 샤프트 · 65MS</figcaption>
        </figure>
      </div>

      <div class="spec-block">
        <h3>VERSUS 스펙</h3>
        <table class="spec-table">
          <tbody>
            <tr><th>헤드</th><td>10.5° 로프트 · 검정 무광 · 0.5° 훅페이스</td></tr>
            <tr><th>샤프트</th><td>VERSUS 55MS / 65MS (Mid Kick-point, Stiff Flex)</td></tr>
            <tr><th>구성</th><td>헤드 + 샤프트 + 그립 + 피팅 + 제작</td></tr>
            <tr><th>가격</th><td><strong>650,000원</strong> (한 자루 완성가)</td></tr>
          </tbody>
        </table>
        <div class="cta-row">
          <a href="/contact" class="btn-primary">VERSUS 상담 예약</a>
          <a href="/workshop" class="btn-ghost">작업 안내 보기</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 02 — KRZ 203H 하이브리드
       ============================================================ -->
  <section class="section section-krz">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 02 · KRZ 203H 하이브리드</p>
      <h2 class="section-title">긴 아이언이 어렵게 느껴질 때</h2>
      <p class="section-lede">
        3·4번 아이언 자리를 대체하는 하이브리드입니다.
        DEFINE 635VTM 샤프트를 매칭해 토크 3.3~3.5로 안정적인 임팩트를 잡습니다.
        로프트와 길이 두 가지 옵션으로 자신의 거리 공백을 정확히 메우실 수 있습니다.
      </p>

      <div class="krz-grid">
        <figure class="vp vp-tall">
          <img src="/images/products/krz-hybrid-1.jpg" alt="KRZ 203H 하이브리드 헤드 정면"
               width="454" height="675" loading="lazy" decoding="async" />
          <figcaption>KRZ 203H · 정면</figcaption>
        </figure>
        <figure class="vp vp-square">
          <img src="/images/products/krz-hybrid-2.jpg" alt="KRZ 203H 하이브리드 솔"
               width="454" height="452" loading="lazy" decoding="async" />
          <figcaption>KRZ 203H · 솔</figcaption>
        </figure>
        <figure class="vp vp-wide">
          <img src="/images/products/krz-hybrid-3.jpg" alt="KRZ 203H 하이브리드 — 작업 단계"
               width="730" height="557" loading="lazy" decoding="async" />
          <figcaption>KRZ 203H · 어드레스</figcaption>
        </figure>
      </div>

      <div class="spec-block">
        <h3>KRZ 203H 정밀 스펙</h3>
        <table class="spec-table spec-table-2col">
          <thead>
            <tr><th></th><th>19° 모델</th><th>23° 모델</th></tr>
          </thead>
          <tbody>
            <tr><th>로프트</th><td>19°</td><td>23°</td></tr>
            <tr><th>라이</th><td>59°</td><td>59.5°</td></tr>
            <tr><th>길이</th><td>39.75″</td><td>39.25″</td></tr>
            <tr><th>무게</th><td>345g (D2)</td><td>347g (D2)</td></tr>
            <tr><th>MOI</th><td>2,468 g·cm²</td><td>2,270 g·cm²</td></tr>
          </tbody>
        </table>
        <p class="spec-foot">
          매칭 샤프트 · <strong>DEFINE 635VTM</strong> 68g · Torque 3.3~3.5 · Regular / Stiff
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 03 — 공작소 작업 흐름
       ============================================================ -->
  <section class="section section-work">
    <div class="section-inner">
      <p class="section-eyebrow">SECTION 03 · 어떻게 만들어집니까</p>
      <h2 class="section-title">측정에서 한 자루까지</h2>
      <p class="section-lede">
        제품 한 자루는 네 단계를 거칩니다.
        퍼스널 인터뷰로 골퍼의 습관과 목표를 듣고, 라이각·스윙웨이트를 측정하고, 부품을 골라 직접 조립합니다.
        모든 단계가 데이터로 남습니다.
      </p>

      <div class="work-grid">
        <figure class="vp vp-wide">
          <img src="/images/products/work-interview.jpg" alt="공작소 — 퍼스널 인터뷰"
               width="1200" height="798" loading="lazy" decoding="async" />
          <figcaption>01 · 퍼스널 인터뷰</figcaption>
        </figure>
        <figure class="vp vp-wide">
          <img src="/images/products/work-lie-angle.jpg" alt="공작소 — Maltby 라이보드 라이각 측정"
               width="1200" height="798" loading="lazy" decoding="async" />
          <figcaption>02 · 라이각 측정 (Maltby 라이보드)</figcaption>
        </figure>
        <figure class="vp vp-wide">
          <img src="/images/products/work-swing-weight.jpg" alt="공작소 — 스윙웨이트 스케일 측정"
               width="1200" height="800" loading="lazy" decoding="async" />
          <figcaption>03 · 스윙웨이트 측정</figcaption>
        </figure>
        <figure class="vp vp-tall">
          <img src="/images/products/work-fitting.jpg" alt="공작소 — 피팅 및 조립 작업"
               width="1200" height="1800" loading="lazy" decoding="async" />
          <figcaption>04 · 피팅 · 조립</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 04 — 팀 신지애
       ============================================================ -->
  <section class="section section-shinjiyai">
    <div class="section-inner shinjiyai-layout">
      <figure class="shinjiyai-board">
        <img src="/images/products/team-shinjiyai-board.jpg" alt="팀 신지애 파트너십 — 서울경제 골프매거진 2008.11"
             width="1080" height="1920" loading="lazy" decoding="async" />
      </figure>
      <div class="shinjiyai-text">
        <p class="section-eyebrow ink-eyebrow">SECTION 04 · 팀 신지애 클럽피팅 파트너</p>
        <h2 class="section-title light">피팅은 우리가 책임진다</h2>
        <blockquote class="quote-large">
          <p>피팅은 우리가 책임진다.</p>
          <footer>— 서울경제 골프매거진 2008.11, 「팀 신지애 클럽피팅 파트너」</footer>
        </blockquote>
        <p class="shinjiyai-body">
          신지애 선수와의 파트너십 자료입니다.
          공작소의 클럽피팅이 투어 현장에서 검증받은 한 시기를 기록합니다.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 05 — PORORO HEROES (핵심)
       ============================================================ -->
  <section class="section section-pororo">
    <div class="section-inner">
      <p class="section-eyebrow gold-eyebrow">SECTION 05 · PORORO HEROES</p>
      <h2 class="section-title light">투어 현장에서, 선수들의 선택</h2>
      <p class="section-lede light">
        뽀로로 헤드커버는 클럽메이커스가 라이센스 계약으로 만든 제품입니다.
        LPGA·KLPGA 투어에서 선수들이 사용하는 헤드커버 가운데 뽀로로 라이센스 라인을 공급한 곳입니다.
      </p>

      <!-- 핵심 매체 인용 -->
      <blockquote class="pororo-pullquote">
        <p>
          “국내의 한 제조회사가 정식 라이선스 계약을 통해
          뽀로로를 필드로 끌어 들였고, 김효주에게도 헤드커버를 선물했다.
          박희영은 LPGA 매뉴라이프클래식 우승 당시 뽀로로 헤드커버로
          전 세계 골프팬들의 시선을 끌었다.”
        </p>
        <footer>— 아시아경제 2014.10.30</footer>
      </blockquote>

      <!-- 박희영 갤러리 (5장 — 우승 강조) -->
      <article class="player-section">
        <header class="player-header">
          <h3 class="player-name">박희영 프로</h3>
          <p class="player-caption">LPGA 매뉴라이프 파이낸셜 클래식 2013 우승 · 뽀로로 헤드커버</p>
        </header>
        <div class="player-gallery park-gallery">
          <figure class="vp">
            <img src="/images/products/park-1-winner-lpga.jpg" alt="박희영 — LPGA 매뉴라이프클래식 2013 우승 영문 기사"
                 width="700" height="509" loading="lazy" decoding="async" />
            <figcaption>Hee Young Park wins Canada LPGA · 2013.07.14</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/park-2-winner-mk.jpg" alt="박희영 — 매뉴라이프 우승 MK스포츠 기사 (뽀로로 헤드커버 화제)"
                 width="954" height="717" loading="lazy" decoding="async" />
            <figcaption>MK스포츠 · 매뉴라이프 우승 화제</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/park-3-beach.jpg" alt="박희영 프로 — 바하마 라운드, 뽀로로 헤드커버"
                 width="650" height="866" loading="lazy" decoding="async" />
            <figcaption>바하마 라운드</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/park-4-cart.jpg" alt="박희영 프로 — 카트 위 뽀로로 헤드커버"
                 width="960" height="720" loading="lazy" decoding="async" />
            <figcaption>코스 이동 중</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/park-5-raise.jpg" alt="박희영 프로 — 뽀로로 헤드커버 들어 보이기 (Newsen)"
                 width="450" height="640" loading="lazy" decoding="async" />
            <figcaption>Newsen 인터뷰</figcaption>
          </figure>
        </div>
      </article>

      <!-- 김효주 갤러리 (4장 — 뽀로로 헤드커버) -->
      <article class="player-section">
        <header class="player-header">
          <h3 class="player-name">김효주 프로</h3>
          <p class="player-caption">뽀로로 헤드커버 · KLPGA·LPGA 다승</p>
        </header>
        <div class="player-gallery kim-gallery">
          <figure class="vp">
            <img src="/images/products/kim-1-smile.jpg" alt="김효주 프로"
                 width="500" height="750" loading="lazy" decoding="async" />
            <figcaption>Mania Report</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/kim-2-caddy.jpg" alt="김효주 프로 — 캐디와 함께"
                 width="500" height="750" loading="lazy" decoding="async" />
            <figcaption>캐디백</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/kim-3-shot.jpg" alt="김효주 프로 — 코스 위에서"
                 width="540" height="746" loading="lazy" decoding="async" />
            <figcaption>코스 위에서</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/kim-4-round.jpg" alt="김효주 프로 — 라운드 중"
                 width="429" height="435" loading="lazy" decoding="async" />
            <figcaption>라운드 중</figcaption>
          </figure>
        </div>
      </article>

      <!-- 콜라주: 그 외 많은 프로들 -->
      <article class="player-section">
        <header class="player-header">
          <h3 class="player-name pros-name">이 외에도 많은 프로들이</h3>
          <p class="player-caption">고진영·안신애 프로 등, 투어 캐디백 위에서 뽀로로가 함께해 왔습니다.</p>
        </header>
        <div class="player-gallery pros-collage">
          <figure class="vp">
            <img src="/images/products/pros-1-ko.jpg" alt="고진영 프로 — 뽀로로 헤드커버 (엑스포츠뉴스 2014)"
                 width="821" height="734" loading="lazy" decoding="async" />
            <figcaption>고진영 프로 · 엑스포츠뉴스 2014</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/pros-2-ahn.jpg" alt="안신애 프로 — 뽀로로 헤드커버 (마니아리포트)"
                 width="766" height="1326" loading="lazy" decoding="async" />
            <figcaption>안신애 프로 · 마니아리포트</figcaption>
          </figure>
        </div>
      </article>

      <!-- 뽀로로 제품 자체 -->
      <article class="player-section">
        <header class="player-header">
          <h3 class="player-name">제품 라인업</h3>
          <p class="player-caption">드라이버·우드·하이브리드용 헤드커버. 메트로신문 보도 기준 7만원 라인.</p>
        </header>
        <div class="player-gallery pororo-products">
          <figure class="vp">
            <img src="/images/products/pororo-collection.jpg" alt="뽀로로 헤드커버 컬렉션"
                 width="800" height="886" loading="lazy" decoding="async" />
            <figcaption>뽀로로 컬렉션</figcaption>
          </figure>
          <figure class="vp">
            <img src="/images/products/pororo-trio.jpg" alt="뽀로로 3총사 — 드라이버·우드·하이브리드 헤드커버"
                 width="540" height="505" loading="lazy" decoding="async" />
            <figcaption>3총사 · 드라이버 · 우드 · 하이브리드</figcaption>
          </figure>
        </div>
        <blockquote class="metro-quote">
          <p>“뽀로로 헤드커버는 클럽메이커스에서 7만 원에 판매되고 있다.”</p>
          <footer>— 메트로신문 보도</footer>
        </blockquote>
      </article>
    </div>
  </section>

  <!-- ============================================================
       CLOSING CTA
       ============================================================ -->
  <section class="section section-cta">
    <div class="section-inner cta-inner">
      <h2 class="cta-title">직접 보러 오세요</h2>
      <p class="cta-lede">
        제품은 사진보다 손에 들었을 때 더 정확합니다.
        예약 후 방문하시면 헤드 무게·샤프트 휨·그립 두께를 직접 비교하실 수 있습니다.
      </p>
      <div class="cta-row">
        <a href="/contact" class="btn-primary">방문 예약</a>
        <a href="/first-visit" class="btn-ghost">처음 방문 안내</a>
      </div>
      <p class="cta-meta">
        서울 서초구 동산로2길 50, 가보빌딩 지하층 · 010-4363-5555 · clubmakers@naver.com
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     공통 토큰 보강 (BaseLayout 글로벌에 이미 있을 것이나, 안전을 위해)
     ============================================================ */
  :root {
    --ink: #0F0F0E;
    --green: #0F2922;
    --gold: #B8985C;
    --cream: #F8F2E5;
    --grey-line: rgba(15, 15, 14, 0.12);
    --grey-line-light: rgba(248, 242, 229, 0.18);
  }

  /* ============================================================
     HERO — 검정 배경
     ============================================================ */
  .products-hero {
    background: var(--ink);
    color: var(--cream);
    padding: clamp(5rem, 12vw, 9rem) 1.5rem clamp(4rem, 10vw, 7rem);
  }
  .products-hero h1 {
    font-family: 'Noto Serif KR', serif;
    font-weight: 600;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0.4rem 0 1.4rem;
  }
  .page-hero-eyebrow {
    font-family: 'Pretendard', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .page-hero-subtitle {

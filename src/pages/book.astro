---
// /src/pages/book.astro
// 『실제적인 클럽피팅』 — 책 랜딩 (재구성)
// 표지 + 14개 PART 카드 + 인용 4개 + 책 정보 + 대상 독자

import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "『실제적인 클럽피팅』 — 채기웅 저, 본문 14 PART · 부록 4 · 약 600페이지";
const pageDescription = "클럽메이커스 채기웅 공작소장이 쓴 클럽피팅 안내서. 인터뷰부터 론치모니터까지, 결과가 아니라 원인부터 추적하는 피팅 시스템. 본문 14 PART, 부록 4, 약 600페이지.";
const pageKeywords = "실제적인 클럽피팅, 클럽피팅 책, 채기웅, 클럽메이커스, 클럽피팅, 클럽메이킹, 골프 피팅 책";

// 14 PART 목차
const parts = [
  { num: 1,  title: "인터뷰",                         sub: "피팅이 시작되는 곳" },
  { num: 2,  title: "판단 구조 시스템",                sub: "결과 중심 해석에서 원인 중심 해석으로" },
  { num: 3,  title: "골퍼 구조 해석 시스템",            sub: "인터뷰 결과를 피팅 변수로 변환하기" },
  { num: 4,  title: "볼 비행 구조",                    sub: "공이 왜 그렇게 날아가는가" },
  { num: 5,  title: "타점 / CG / 기어이펙트",           sub: "충돌이 만드는 왜곡 구조" },
  { num: 6,  title: "헤드 기하 구조",                   sub: "라이각 · 로프트 · 오프셋 · CG" },
  { num: 7,  title: "MOI / 관성 구조",                 sub: "관성의 물리 원리와 피팅 적용" },
  { num: 8,  title: "무게 / 총무게 / 스윙웨이트",       sub: "무게를 시간 구조로 이해하는 방법" },
  { num: 9,  title: "샤프트 구조와 피팅 판단",          sub: "CPM · EI · 토크 · 스파인" },
  { num: 10, title: "론치모니터 해석 시스템",           sub: "데이터를 언어로, 언어를 결정으로" },
  { num: 11, title: "통합 결정과 문제 해결 시스템",     sub: "결정 흐름과 문제 해결 트리" },
  { num: 12, title: "숏게임 — 웨지와 퍼터",             sub: "바운스 · 솔 그라인드 · 스트로크 매칭" },
  { num: 13, title: "통합 케이스 스터디",               sub: "실전 피팅 사례 8개" },
  { num: 14, title: "특수군 피팅 가이드",               sub: "시니어 · 여성 · 주니어" },
];

// 인용 4개 — 책의 다른 측면
const quotes = [
  { text: "같은 증상이라도 원인이 다르면 개입이 다릅니다.", source: "PART 11 · 문제 해결 시스템" },
  { text: "타점은 모든 문제 해결의 출발점입니다.",           source: "PART 5 · 타점 · 기어이펙트" },
  { text: "데이터는 원인이 아니라 결과입니다.",             source: "PART 2 · 판단 구조 시스템" },
  { text: "기준이 없으면 비교도 없습니다.",                  source: "PART 1 · 인터뷰" },
];

// 대상 독자
const audience = [
  "클럽피팅을 체계적으로 공부하고 싶은 분",
  "피팅샵 운영자 또는 예비 창업자",
  "클럽메이킹 작업 기준을 배우고 싶은 분",
  "론치모니터 데이터를 해석하고 싶은 분",
  "장비 선택을 감이 아니라 구조로 이해하고 싶은 골퍼",
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schemaType="Book"
  keywords={pageKeywords}
>

  <!-- ==================== HERO ==================== -->
  <section class="book-hero">
    <div class="container">
      <div class="hero-grid">
        <!-- 표지 영역 (텍스트 표지) -->
        <div class="cover-area">
          <div class="cover">
            <p class="cover-eyebrow">CLUBMAKERS BOOK · 2026</p>
            <p class="cover-author">채기웅</p>
            <h1 class="cover-title">실제적인 <br />클럽피팅</h1>
            <p class="cover-en">Practical Clubfitting</p>
            <div class="cover-foot">
              <p>본문 14 PART · 부록 4</p>
              <p>약 600페이지</p>
            </div>
          </div>
        </div>

        <!-- 책 소개 -->
        <div class="intro-area">
          <p class="eyebrow">BOOK · 채기웅 저</p>
          <h2 class="intro-title">
            결과가 아니라 <em>원인</em>부터 <br />추적하는 피팅 시스템
          </h2>
          <p class="intro-lead">
            클럽메이커스 채기웅 공작소장이 24년의 현장 경험을 정리한 클럽피팅 안내서.
            인터뷰부터 론치모니터까지, 같은 증상도 원인이 다르면 처방이 다르다는 원칙을
            <strong>14 PART의 구조 해석 시스템</strong>으로 풀어냅니다.
          </p>

          <div class="intro-meta">
            <div class="meta-row">
              <span class="meta-label">저자</span>
              <span class="meta-value">채기웅 (클럽메이커스 공작소장)</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">구성</span>
              <span class="meta-value">본문 14 PART · 부록 4 · 현장작업표준서 12종</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">분량</span>
              <span class="meta-value">약 600페이지</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">발행</span>
              <span class="meta-value">Clubmakers Korea, 2026</span>
            </div>
          </div>

          <div class="intro-cta">
            <a href="#contents" class="btn-primary">
              <span>14 PART 보기</span>
              <span>↓</span>
            </a>
            <a href="/contact" class="btn-secondary">구매·교육 문의 →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== QUOTES ==================== -->
  <section class="quotes-section">
    <div class="container narrow">
      <p class="eyebrow">PHILOSOPHY · 책이 말하는 것</p>
      <h2 class="section-title">
        피팅에 대한 <em>다른 시선</em>
      </h2>

      <div class="quote-grid">
        {quotes.map((q, i) => (
          <figure class="quote-card">
            <p class="quote-num">{String(i + 1).padStart(2, '0')}</p>
            <blockquote class="quote-text">{q.text}</blockquote>
            <figcaption class="quote-source">— {q.source}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TABLE OF CONTENTS ==================== -->
  <section id="contents" class="contents-section">
    <div class="container">
      <div class="toc-head">
        <p class="eyebrow">CONTENTS · 본문 14 PART</p>
        <h2 class="section-title">전체 <em>목차</em></h2>
        <p class="toc-lead">
          각 PART는 독립된 장입니다. 관심 있는 PART부터 바로 들어갈 수 있습니다.
          모든 PART는 학습 목표 → 본문 → 마무리 → 확인 문제 순으로 구성됩니다.
        </p>
      </div>

      <ol class="parts-grid">
        {parts.map((p) => (
          <li>
            <a href={`/book/part-${p.num}`} class="part-card">
              <div class="part-card-head">
                <p class="part-card-num">PART {String(p.num).padStart(2, '0')}</p>
                <span class="part-card-arrow">→</span>
              </div>
              <h3 class="part-card-title">{p.title}</h3>
              <p class="part-card-sub">{p.sub}</p>
            </a>
          </li>
        ))}
      </ol>

      <div class="appendix-card">
        <p class="app-eyebrow">APPENDIX · 부록 4</p>
        <p class="app-body">
          부록 A 의사결정 트리 / 부록 B 다운스윙 정밀 분석 / 부록 C 샤프트 매트릭스 /
          부록 D 용어·수치 참조표 — <em>현장에서 즉시 쓸 수 있는 도구</em>들로 구성됩니다.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== AUDIENCE ==================== -->
  <section class="audience-section">
    <div class="container narrow">
      <p class="eyebrow">FOR · 대상 독자</p>
      <h2 class="section-title">
        이런 분께 <em>적합</em>합니다
      </h2>

      <ul class="audience-list">
        {audience.map((a) => (
          <li>
            <span class="aud-mark">●</span>
            <span class="aud-text">{a}</span>
          </li>
        ))}
      </ul>

      <p class="audience-foot">
        클럽피팅을 처음 접하는 일반 골퍼에게도 일부 PART(1·4·5·11)는 충분히 접근 가능합니다.
        다만 책 전체는 <strong>현장에서 결정을 내리는 사람</strong>의 시점에서 쓰여 있습니다.
      </p>
    </div>
  </section>

  <!-- ==================== TOPICS BRIDGE ==================== -->
  <section class="topics-bridge">
    <div class="container narrow">
      <p class="eyebrow">SHORTCUT · 증상부터 시작하고 싶다면</p>
      <h2 class="section-title">
        <em>증상별 진단 트리</em>로 가기
      </h2>
      <p class="bridge-lead">
        책의 PART 11 문제 해결 시스템을 검색자 관점에서 재구성한 9개 페이지가 별도로 있습니다.
        슬라이스, 훅, 거리 부족 같은 구체적 증상에서 시작해 책으로 들어가는 입구입니다.
      </p>

      <a href="/topics" class="bridge-card">
        <p class="bridge-card-eyebrow">TOPICS · 증상별 진단</p>
        <p class="bridge-card-title">9가지 진단 트리 보기</p>
        <p class="bridge-card-desc">
          방향 / 슬라이스 · 훅 / 타점 / 탄도 · 스핀 / 리듬 · 타이밍 /
          SW · MOI / 절대 금지 / 클럽별 / 복합 문제
        </p>
        <span class="bridge-card-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="cta-section">
    <div class="container narrow">
      <p class="eyebrow">NEXT STEP · 책과 피팅</p>
      <h2 class="section-title">
        책을 읽고 <em>직접 진단</em>받기
      </h2>

      <p class="cta-lead">
        책은 <strong>구조와 원칙</strong>을 다룹니다. 실제 처방은 골퍼마다 다릅니다.
        클럽메이커스에서는 책에서 다룬 시스템을 <strong>현장 측정과 함께</strong> 적용합니다.
      </p>

      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">
          <span>구매·교육 문의</span>
          <span>→</span>
        </a>
        <a href="/system" class="btn-secondary">피팅 진행 과정 보기</a>
        <a href="/topics" class="btn-secondary">증상별 진단 →</a>
      </div>
    </div>
  </section>

</BaseLayout>


<style>
  :root {
    --bg: #F8F5EE; --bg-elev: #FFFFFF; --bg-soft: #F1ECE0;
    --text: #1F1B16; --text-2: #3A332A; --muted: #6B6358;
    --rule: #E2DACA; --rule-2: #D2C9B5;
    --accent: #2C5F4F; --accent-2: #87A99B; --accent-soft: #E6EDE7;
    --serif: "Noto Serif KR", "Apple SD Gothic Neo", serif;
    --sans:  "Pretendard", "Apple SD Gothic Neo", system-ui, sans-serif;
  }

  .container { width: 100%; max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .narrow { max-width: 760px; }

  .eyebrow {
    font-family: var(--sans);
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .15em;
    color: var(--accent);
    text-transform: uppercase;
    margin: 0 0 1.25rem;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 4.2vw, 2.625rem);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -.015em;
    color: var(--text);
    margin: 0 0 2rem;
  }
  .section-title em { font-style: normal; color: var(--accent); }

  /* ================ HERO ================ */
  .book-hero {
    background: var(--bg);
    padding: 80px 0 96px;
    border-bottom: 1px solid var(--rule);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }
  @media (min-width: 880px) {
    .hero-grid { grid-template-columns: 380px 1fr; gap: 80px; }
  }

  /* COVER */
  .cover-area { display: flex; justify-content: center; }
  .cover {
    background: linear-gradient(155deg, var(--text) 0%, #2a2520 100%);
    color: var(--bg);
    padding: 56px 40px 48px;
    border-radius: 4px;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 3 / 4.4;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 1px 0 rgba(255,255,255,.08) inset,
      0 30px 60px rgba(31, 27, 22, .25),
      0 12px 24px rgba(31, 27, 22, .15);
    position: relative;
    overflow: hidden;
  }
  .cover:before {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 12px;
    width: 1px;
    background: rgba(135, 169, 155, .25);
  }
  .cover-eyebrow {
    font-family: var(--sans);
    font-size: .6875rem;
    font-weight: 700;
    letter-spacing: .25em;
    color: var(--accent-2);
    margin: 0 0 auto;
    text-transform: uppercase;
  }
  .cover-author {
    font-family: var(--serif);
    font-size: 1rem;
    color: rgba(255,255,255,.7);
    margin: 0 0 1.25rem;
    letter-spacing: .04em;
  }
  .cover-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 600;
    line-height: 1.1;
    color: var(--bg);
    margin: 0 0 1rem;
    letter-spacing: -.01em;
  }
  .cover-en {
    font-family: var(--sans);
    font-size: .8125rem;
    color: var(--accent-2);
    letter-spacing: .12em;
    margin: 0 0 auto;
    font-style: italic;
  }
  .cover-foot {
    font-family: var(--sans);
    font-size: .75rem;
    color: rgba(255,255,255,.55);
    letter-spacing: .04em;
    border-top: 1px solid rgba(255,255,255,.12);
    padding-top: 1.25rem;
    margin-top: 2rem;
  }
  .cover-foot p { margin: 0 0 .25rem; }

  /* INTRO */
  .intro-title {
    font-family: var(--serif);
    font-size: clamp(1.875rem, 4.5vw, 2.875rem);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -.02em;
    color: var(--text);
    margin: 0 0 1.5rem;
  }
  .intro-title em { font-style: normal; color: var(--accent); }
  .intro-lead {
    font-family: var(--sans);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--text-2);
    margin: 0 0 2rem;
  }
  .intro-lead strong { color: var(--text); font-weight: 600; }

  .intro-meta {
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 6px 0;
    margin: 0 0 2rem;
  }
  .meta-row {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 1rem;
    padding: 12px 22px;
    font-family: var(--sans);
    font-size: .9375rem;
    border-bottom: 1px solid var(--rule);
  }
  .meta-row:last-child { border-bottom: none; }
  .meta-label {
    color: var(--muted);
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    align-self: center;
  }
  .meta-value { color: var(--text-2); font-weight: 500; }

  .intro-cta { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* ================ QUOTES ================ */
  .quotes-section {
    padding: 96px 0;
    background: var(--bg);
    border-top: 1px solid var(--rule);
  }
  .quote-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  @media (min-width: 720px) { .quote-grid { grid-template-columns: 1fr 1fr; } }

  .quote-card {
    margin: 0;
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    padding: 32px 32px 28px;
    border-radius: 2px;
    border-top: 3px solid var(--accent);
    position: relative;
  }
  .quote-num {
    font-family: var(--serif);
    font-size: .8125rem;
    font-weight: 700;
    letter-spacing: .15em;
    color: var(--accent-2);
    margin: 0 0 1rem;
  }
  .quote-text {
    font-family: var(--serif);
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 500;
    line-height: 1.55;
    color: var(--text);
    margin: 0 0 1.5rem;
    quotes: "\201C" "\201D";
    position: relative;
    padding-left: 1.5rem;
  }
  .quote-text:before {
    content: '"';
    position: absolute;
    left: 0;
    top: -.25rem;
    font-size: 2rem;
    color: var(--accent-2);
    font-weight: 700;
    line-height: 1;
  }
  .quote-source {
    font-family: var(--sans);
    font-size: .8125rem;
    color: var(--muted);
    letter-spacing: .02em;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }

  /* ================ CONTENTS ================ */
  .contents-section {
    padding: 96px 0;
    border-top: 1px solid var(--rule);
  }
  .toc-head { max-width: 760px; margin: 0 auto 3rem; padding: 0 24px; text-align: left; }
  .toc-head .section-title { margin-bottom: 1.5rem; }
  .toc-lead {
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-2);
    margin: 0;
  }

  .parts-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 600px) { .parts-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 960px) { .parts-grid { grid-template-columns: repeat(3, 1fr); } }

  .part-card {
    display: block;
    background: var(--bg-elev);
    border: 1px solid var(--rule);
    padding: 22px 24px;
    border-radius: 2px;
    text-decoration: none;
    color: var(--text);
    transition: transform .25s, border-color .25s, background .25s;
    position: relative;
  }
  .part-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .part-card:hover .part-card-arrow { color: var(--accent); transform: translateX(3px); }

  .part-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: .85rem;
  }

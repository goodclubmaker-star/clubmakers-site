---
import BaseLayout from '../layouts/BaseLayout.astro';

// 4개 카테고리 × Q&A = 21개 (BROKEN 5 / PERFORMANCE 6 / REPLACEMENT 5 / GENERAL 5)
const categories = [
  {
    id: 'broken',
    label: 'BROKEN',
    title: '클럽이 부서졌을 때',
    intro: '샤프트 부러짐 · 헤드 분리 · 페룰 손상 · 그립 찢어짐 · 헤드 흠집',
    items: [
      {
        q: '샤프트가 부러졌어요. 어떻게 하나요?',
        situation: '스윙 중이나 충격으로 샤프트가 부러진 경우입니다. 헤드 쪽에서 부러지는 경우와 그립 쪽에서 부러지는 경우 두 가지가 있습니다.',
        solution: [
          { title: '1) 샤프트 교체', body: '부러진 샤프트를 빼내고 새 샤프트로 교체합니다. 가장 일반적인 방법입니다. 단, 같은 OEM 샤프트를 구하기 어려운 경우가 많아 비슷한 성향의 대체 샤프트를 선택하시게 됩니다.' },
          { title: '2) 연장 수리', body: '헤드에 가까운 쪽이 부러진 경우, 손상 부위를 잘라내고 그립 쪽에 연장 키트를 넣어 길이를 맞추는 방법입니다. 같은 샤프트를 구하기 어렵거나 비용이 부담될 때 검토할 수 있습니다. 다만 길이와 밸런스가 변하면서 클럽 느낌이 달라질 수 있습니다.' }
        ],
        cost: [
          { label: '샤프트 교체 공임', value: '18,000원' },
          { label: '연장 수리', value: '별도 견적 (위치·상태에 따라)' }
        ],
        visit: '클럽을 맡기시는 작업입니다. 신규 샤프트 주문 시간과 에폭시 경화 24시간이 필요합니다. 방문 전 전화로 클럽 모델과 부러진 위치를 알려주시면 미리 안내드립니다.',
        actions: [
          { href: '/workshop#head-shaft', label: '헤드·샤프트 작업 보기' },
          { href: '/contact', label: '예약·문의', primary: true }
        ]
      },
      {
        q: '헤드가 빠졌어요. 다시 붙일 수 있나요?',
        situation: '헤드와 샤프트 사이가 분리되어 헤드가 빠진 경우입니다.',
        cause: '대부분 에폭시 노후입니다. 5~10년 이상 된 클럽은 에폭시가 약해져 분리될 수 있습니다. 새 클럽인데도 빠졌다면 처음 조립 시 에폭시 도포가 부족했거나 유격이 있던 경우입니다.',
        solutionText: '헤드와 샤프트가 모두 손상되지 않았다면 재접합이 가능합니다. 페룰과 샤프트 팁을 정리한 뒤 신규 에폭시로 재접착합니다. 샤프트 팁이 손상되었다면 샤프트 교체가 필요합니다.',
        cost: [
          { label: '연결부 수리 공임', value: '18,000원' },
          { label: '부품 (에폭시·페룰 등)', value: '몇 천 원 ~ 1만 원대' }
        ],
        visit: '클럽을 맡기시는 작업입니다. 에폭시 24시간 경화 시간이 필요해 당일 회수는 어렵습니다. 다음 날 또는 그다음 날 픽업 가능합니다.',
        actions: [
          { href: '/workshop#head-shaft', label: '헤드·샤프트 작업 보기' },
          { href: '/contact', label: '예약·문의', primary: true }
        ]
      },
      {
        q: '페룰이 갈라졌어요. 그냥 둬도 되나요?',
        situation: '헤드와 샤프트 연결부의 검은 플라스틱 부품이 페룰입니다. 페룰이 갈라지거나 헐거워진 경우입니다.',
        cause: '충격·마모 또는 처음 조립 시 압착 부족입니다. 페룰 자체는 결합력에 직접 영향을 주지 않지만, 갈라진 채로 두면 헤드 분리의 신호일 수 있습니다.',
        solutionText: '페룰 교체가 필요합니다. 헤드를 분리하지 않고 교체할 수 있는 경우와, 헤드를 분리해야 정확히 교체되는 경우가 있어 클럽 상태를 보고 판단합니다.',
        cost: [
          { label: '페룰 헐거움 공임', value: '5,000원' },
          { label: '헤드 분리 필요 시', value: '+10,000원' }
        ],
        visit: '대부분 즉시 가능한 작업입니다. 분석·교육 예약과 겹치지 않는 시간이라면 방문 즉시 진행됩니다. 미리 전화 한 통 주시면 안전합니다.',
        actions: [
          { href: '/workshop#head-shaft', label: '헤드·샤프트 작업 보기' },
          { href: '/contact', label: '예약·문의', primary: true }
        ]
      },
      {
        q: '그립이 찢어졌어요. 한 자루만 교체할 수 있나요?',
        situation: '그립이 찢어지거나 닳은 경우입니다. 한 자루 또는 세트 전체일 수 있습니다.',
        solution: [
          { title: '한 자루만 교체', body: '특정 클럽 그립만 닳거나 찢어진 경우. 그립이 같은 모델이면 손에 닿는 느낌의 차이가 적습니다.' },
          { title: '전체 교체', body: '14자루 세트 한 번에. 일관성 면에서 추천' }
        ],
        solutionText: '그립 종류는 손 크기·기후·취향에 따라 다양해서 직접 잡아보고 결정하시는 것이 좋습니다.',
        cost: [
          { label: '그립 장착 공임 (그립을 가져오실 시)', value: '5,000원 / 한 자루' },
          { label: '퍼터 그립 (그립 가져오실 시)', value: '7,000원' },
          { label: '그립 부품', value: '캐비어, 프라이드 2~3만원 / 슈퍼스트록 퍼터그립 4~5만원' }
        ],
        visit: '즉시 가능한 작업입니다. 한 자루는 10~15분, 세트 전체는 약 1시간이면 마무리됩니다.',
        actions: [
          { href: '/workshop#grip', label: '그립 작업 보기' },
          { href: '/contact', label: '예약·문의', primary: true }
        ]
      },
      {
        q: '클럽이 떨어져서 헤드에 흠집이 났어요. 수리 가능한가요?',
        situation: '헤드 표면에 흠집·페인트 손상·금속 패임이 생긴 경우입니다.',
        notice: '공작소는 헤드 도색·복원·그루브 재생 같은 작업은 다루지 않습니다. 이런 작업이 필요한 경우 제조사 또는 전문 도색·복원 업체에 문의하셔야 합니다.',
        solution: [
          { title: '공작소에서 가능한 부분', body: '직접 보고 헤드의 손상 정도와 사용 가능 여부를 진단해드립니다. 헤드 자체에 균열이나 깊은 패임이 있어 사용이 어려우면 새 헤드로 교체할 수 있습니다.' }
        ],
        bullets: [
          '<strong>표면 페인트 손상</strong>: 미관 문제로 성능 영향은 거의 없음 (전문 도색 업체 안내)',
          '<strong>페이스 그루브 마모</strong>: 시간이 지나면 자연스럽게 마모됨. 새 클럽 또는 헤드 교체로 해결',
          '<strong>헤드 균열·깊은 패임</strong>: 사용 불가일 가능성. 헤드 교체 필요'
        ],
        visit: '직접 보고 진단해드립니다. 도색·복원이 필요한 경우 적합한 곳을 안내드릴 수 있습니다.',
        actions: [
          { href: '/contact', label: '예약·문의', primary: true }
        ]
      }
    ]
  },
  {
    id: 'performance',
    label: 'PERFORMANCE',
    title: '클럽 성능 문제',
    intro: '거리 부족 · 슬라이스 · 무게 문제 · 어드레스 · 후반 무너짐',
    items: [
      {
        q: '갑자기 거리가 안 나요. 무엇 때문일까요?',
        situation: '같은 스윙인데 평소보다 거리가 줄었습니다. 일시적일 수도 있고 지속될 수도 있습니다.',
        bullets: [
          '<strong>스윙 변화</strong>: 컨디션·자세·계절(겨울 옷차림) 등으로 헤드스피드 감소',
          '<strong>클럽 변화</strong>: 샤프트 노후·페이스 마모·그립 노후로 잡는 힘 변화',
          '<strong>타점 변동</strong>: 페이스 중심에서 자주 벗어나면 거리 손실이 큽니다',
          '<strong>공의 변화</strong>: 더 단단한 공으로 바꾸면 짧아질 수 있음'
        ],
        solutionText: '원인이 다양해 분석을 통해 무엇이 줄어든 지점인지 확인이 필요합니다. 헤드스피드·타점·스매시 팩터 — 이 세 가지를 측정하면 원인이 좁혀집니다.',
        cost: [
          { label: '분석 프로그램', value: '60,000원 (낮시간 45,000원)' },
          { label: '분석 후 작업', value: '결정되면 별도 견적' }
        ],
        visit: '분석은 예약제로 진행됩니다. 네이버 예약이 가장 빠릅니다. 분석 후 클럽 작업이 필요하면 같은 자리에서 진행되는 경우가 많습니다.',
        actions: [
          { href: '/system', label: '공작소의 시스템' },
          { href: 'https://naver.me/GfrbfXtX', label: '네이버 예약', primary: true, external: true }
        ]
      },
      {
        q: '슬라이스가 갑자기 심해졌어요. 클럽 문제일까요?',
        situation: '평소와 같은 클럽인데 슬라이스가 심해진 경우입니다.',
        intro: '"같은 슬라이스도 원인이 다르면 처방이 다릅니다." 가능성을 좁혀야 합니다.',
        bullets: [
          '<strong>그립 노후</strong>: 미끄러우면 페이스가 열리는 경향',
          '<strong>라이각 변화</strong>: 너무 업라이트 또는 플랫이 되면 페이스 방향이 바뀜',
          '<strong>샤프트 노후</strong>: EI 변화 또는 샤프트 휨',
          '<strong>타점 변화</strong>: 힐 쪽으로 자주 맞으면 기어이펙트로 슬라이스',
          '<strong>스윙 변화</strong>: 클럽 문제가 아니라 스윙 자체의 변화'
        ],
        solutionText: '원인이 다섯 가지 이상이라 장비를 바꾸기 전에 진단부터 합니다. 인터뷰 → 클럽 측정 → 스윙 분석 순서로 좁혀가면 어느 변수가 원인인지 분명해집니다.',
        cost: [
          { label: '분석 프로그램', value: '60,000원 (낮시간 45,000원)' },
          { label: '진단 결과에 따라', value: '그립 교체 5,000원 + 부품 / 라이각 조정 10,000원 / 샤프트 교체 18,000원 + 부품' }
        ],
        visit: '분석은 예약제로 진행됩니다. 1:1로 약 40~60분.',
        actions: [
          { href: '/topics/slice-hook', label: '증상별 진단: 슬라이스·훅' },
          { href: '/system', label: '공작소의 시스템' },
          { href: 'https://naver.me/GfrbfXtX', label: '네이버 예약', primary: true, external: true }
        ]
      },
      {
        q: '클럽이 무겁게 느껴져요. 가볍게 만들 수 있나요?',
        situation: '같은 클럽인데 평소보다 무겁게 느껴지거나, 처음부터 자기에게 무거웠던 경우입니다.',
        intro: '"무겁다"는 두 가지 다른 문제를 가리킵니다.',
        solution: [
          { title: '1) 총무게가 무거움', body: '라운드 후반에 피곤하고 거리도 짧아집니다. → 가벼운 샤프트나 그립으로 무게 조정 필요.' },
          { title: '2) 헤드가 무겁게 느껴짐 (스윙웨이트 SW가 높음)', body: '헤드는 무겁고 손은 가벼운 느낌. → SW 조정으로 해결.' }
        ],
        solutionText: '두 가지는 처방이 다릅니다. 처음에는 둘 중 어느 문제인지 진단부터입니다.',
        bullets: [
          '<strong>총무게 줄이기</strong>: 가벼운 샤프트로 교체 (가장 큰 차이) 또는 가벼운 그립',
          '<strong>SW 줄이기</strong>: 그립 교체 (그립 +5g당 SW -1pt 정도) 또는 헤드 무게 조정'
        ],
        cost: [
          { label: '분석 (필요 시)', value: '60,000원 / 낮시간 45,000원' },
          { label: 'SW 조정', value: '5,000원' },
          { label: '그립 교체', value: '5,000원 + 그립값' },
          { label: '샤프트 교체', value: '18,000원 + 샤프트값' }
        ],
        visit: '진단부터 작업까지 같은 날에 끝나는 경우가 많습니다 (단순 SW 조정 또는 그립 교체). 샤프트 교체가 필요하면 클럽을 맡기셔야 합니다.',
        actions: [
          { href: '/workshop#length-balance', label: '길이·밸런스 작업' },
          { href: '/system', label: '공작소의 시스템' },
          { href: 'https://naver.me/GfrbfXtX', label: '네이버 예약', primary: true, external: true }
        ]
      },
      {
        q: '어드레스가 어색해요. 클럽이 안 맞는 걸까요?',
        situation: '클럽을 어드레스했을 때 토우가 들리거나 힐이 들리는 등 자세가 어색한 경우입니다.',
        intro: '대부분 라이각 불일치입니다.',
        bullets: [
          '<strong>너무 업라이트</strong>: 토우가 들리고 미스가 좌측 (페이스 닫힘)',
          '<strong>너무 플랫</strong>: 힐이 들리고 미스가 우측 (페이스 열림)'
        ],
        solutionText: '신체(특히 키와 손-바닥 거리)에 따라 적정 라이각이 달라집니다. 다이나믹 라이 테스트로 측정 후 라이각 조정합니다. 임팩트 테이프로 실제 임팩트 시 클럽이 어떻게 닿는지 확인합니다.',
        cost: [
          { label: '다이나믹 라이 테스트', value: '분석 프로그램에 포함 (60,000원)' },
          { label: '라이·로프트 조정', value: '10,000원 / 클럽' }
        ],
        visit: '라이각 조정 자체는 즉시 가능한 작업입니다 (몇 분 ~ 10분). 정확한 진단이 먼저라 분석을 권장합니다. 분석 + 작업 같은 날 가능합니다.',
        actions: [
          { href: '/workshop#lie-loft', label: '라이·로프트 작업' },
          { href: '/system', label: '공작소의 시스템' },
          { href: 'https://naver.me/GfrbfXtX', label: '네이버 예약', primary: true, external: true }
        ]
      },
      {
        q: '후반에 클럽이 무너져요. 무엇을 봐야 하나요?',
        situation: '13~14번 홀 이후로 거리가 줄거나 미스가 많아지는 패턴입니다.',
        cause: '대부분 클럽 무게 + 골퍼의 지구력 불일치입니다. 후반에 피곤해지면 릴리즈가 늦어지고, 그 결과 우측 미스나 거리 손실이 나타납니다. 이는 스윙 문제가 아니라 클럽이 그분의 지구력을 초과한다는 신호입니다.',
        solutionText: '총무게 재조정이 핵심입니다. 가벼운 샤프트 또는 가벼운 그립으로 무게 부담을 낮춥니다. 분석으로 후반 패턴을 확인한 후 결정합니다.',

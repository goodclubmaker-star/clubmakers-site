import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = "PART 12. 숏게임 클럽 — 웨지와 퍼터 | 『실제적인 클럽피팅』";
const pageDescription = "채기웅 저 『실제적인 클럽피팅』 PART 12. 숏게임 클럽 — 웨지와 퍼터 — 바운스·솔 그라인드·퍼터 헤드 구조·스트로크 매칭. 웨지 구조와 피팅";
const pageKeywords = "클럽피팅, 숏게임 클럽 — 웨지와 퍼터, 채기웅, 실제적인 클럽피팅";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schemaType="Article"
  keywords={pageKeywords}
>

  <!-- ==================== HERO ==================== -->
  <section class="part-hero">
    <div class="container narrow">
      <div class="crumb">
        <a href="/book">『실제적인 클럽피팅』</a>
        <span>·</span>
        <span class="crumb-current">PART 12</span>
      </div>

      <p class="eyebrow">PART 12 · 본문 14 PART 중 12번째</p>

      <h1 class="part-title">
        <span class="part-num">PART 12</span>
        <span class="part-name">숏게임 클럽 — 웨지와 퍼터</span>
        <span class="part-sub">바운스·솔 그라인드·퍼터 헤드 구조·스트로크 매칭</span>
      </h1>

      <p class="part-en">Short Game — Wedges &amp; Putters</p>

      <p class="part-lead">웨지 구조와 피팅</p>

import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = "PART 3. 골퍼 구조 해석 시스템 | 『실제적인 클럽피팅』";
const pageDescription = "채기웅 저 『실제적인 클럽피팅』 PART 3. 골퍼 구조 해석 시스템 — 인터뷰 결과를 피팅 변수로 변환하기. PART 3는 인터뷰와 데이터 해석에서 얻은 정보를 실제 피팅 변수로 옮기는 단계를 다룹니다.";
const pageKeywords = "클럽피팅, 골퍼 구조 해석 시스템, 채기웅, 실제적인 클럽피팅";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schemaType="Article"
  keywords={pageKeywords}
>

  <!-- ==================== HERO ==================== -->
  <section class="part-hero">
    <div class="container narrow">
      <div class="crumb">
        <a href="/book">『실제적인 클럽피팅』</a>
        <span>·</span>
        <span class="crumb-current">PART 3</span>
      </div>

      <p class="eyebrow">PART 03 · 본문 14 PART 중 3번째</p>

      <h1 class="part-title">
        <span class="part-num">PART 3</span>
        <span class="part-name">골퍼 구조 해석 시스템</span>
        <span class="part-sub">인터뷰 결과를 피팅 변수로 변환하기</span>
      </h1>

      <p class="part-en">Reading the Golfer's Architecture</p>

      <p class="part-lead">PART 3는 인터뷰와 데이터 해석에서 얻은 정보를 실제 피팅 변수로 옮기는 단계를 다룹니다.</p>

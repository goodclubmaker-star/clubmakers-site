  <section id="sec-9" class="part-section">
    <div class="container narrow">
      <p class="eyebrow">SECTION 09 · 9절</p>
      <h2 class="section-title">현장 오판 케이스</h2>

      <div class="prose">
        
      <div class="data-table-wrap">
        <table class="data-table">
          <thead><tr><th>케이스</th><th>증상</th><th>잘못된 조치</th><th>올바른 접근</th></tr></thead>

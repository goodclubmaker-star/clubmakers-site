const pageDescription = "채기웅 저 『실제적인 클럽피팅』 PART 9. 샤프트 구조와 피팅 판단 — CPM·EI·토크·스파인의 구조와 적용. 현장 피터의 샤프트 판단 기준";
const pageKeywords = "클럽피팅, 샤프트 구조와 피팅 판단, 채기웅, 실제적인 클럽피팅";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const groovesRulesSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': 'https://myclubmakers.com/equipment-rules/grooves/#article',
  headline: '그루브 장비 규정 — 2010년 변경의 의미와 현재',
  description: 'USGA·R&A 2010년 그루브 규정 변경 한글 정리. 그루브 부피 제한·엣지 라운딩(0.010인치)·V/U 그루브 차이·일반 골퍼와 엘리트 골퍼 적용 차이. 클럽메이커스 24년 현장 해석.',
  inLanguage: 'ko-KR',
  author: {
    '@type': 'Person',
    name: '채기웅',
    url: 'https://myclubmakers.com/about',
  },
  publisher: {
    '@type': 'Organization',
    name: '클럽메이커스',
    url: 'https://myclubmakers.com',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '내가 가진 2009년 이전 클럽도 사용 가능한가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '일반 라운드와 핸디캡 등록 라운드에서는 가능합니다. 2010년 그루브 규정은 모범 로컬 룰(G-2)이라 대회 주최 측이 채택할 때만 적용됩니다. PGA Tour, USGA 챔피언십, 엘리트 아마추어 대회는 적용 중이지만, 일반 골퍼·일반 클럽 대회·친선 라운드에서는 2009년 이전 그루브도 합법입니다.',
      },
    },
    {
      '@type': 'Question',
      name: 'V그루브와 U그루브 중 어느 것이 합법인가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '둘 다 합법입니다. 2010년 규정은 그루브 모양(V냐 U냐)을 직접 규제하지 않고, 단면적/간격 비율과 엣지의 날카로움을 제한합니다. U그루브여도 새 규정의 한계(0.010인치 엣지 반지름) 안에 있으면 합법입니다.',
      },
    },
    {
      '@type': 'Question',
      name: '드라이버와 퍼터에는 그루브 규정이 적용되지 않나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '2010년 그루브 규정 변경은 드라이버와 퍼터에 적용되지 않습니다. 다만 다른 일반적인 그루브 규정(폭, 깊이, 간격 한계)은 모든 클럽에 적용됩니다.',
      },
    },
    {
      '@type': 'Question',
      name: '그루브가 마모된 클럽은 부적합인가요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '대부분의 경우 합법입니다. 마모는 사용 누적의 결과이며, 출고 시 적합했던 클럽이 자연스럽게 마모됐다는 이유로 부적합 판정을 받지는 않습니다. 다만 의도적으로 그루브를 깊게 갈거나 날카롭게 만들면 위반입니다.',
      },
    },
    {
      '@type': 'Question',
      name: '오래된 웨지를 그루브 재가공해서 다시 쓸 수 있나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '그루브 재가공(re-grooving)은 USGA 규정상 위험한 작업입니다. 단순히 마모된 그루브를 닦아내는 정도는 허용되지만, 깊이를 늘리거나 엣지를 날카롭게 만들면 부적합이 됩니다. 클럽메이커스는 그루브 재생 작업을 다루지 않습니다 — 마모된 웨지는 교체를 권합니다.',
      },
    },
  ],
};
---

<BaseLayout
  title="그루브 규정 — 2010년 변경과 현재"
  description="USGA·R&A 2010년 그루브 규정 변경 한글 정리. 그루브 부피 제한·엣지 라운딩(0.010인치)·V/U 그루브 차이·일반 골퍼와 엘리트 골퍼 적용 차이. 클럽메이커스 24년 현장 해석."
  schemaType="Article"
  keywords="그루브 규정, 2010 그루브 룰, V그루브, U그루브, 박스 그루브, 그루브 부피, 그루브 엣지, 0.010인치, Model Local Rule G-2, USGA 그루브, R&A 그루브, 웨지 그루브, 아이언 그루브, 핑 EYE2, Ping Eye 2"
  extraSchema={[groovesRulesSchema, faqSchema]}
>

  <!-- 1. Hero -->
  <section class="page-hero grooves-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">EQUIPMENT RULES · TOPIC 02 · 그루브 규정</div>
      <h1>그루브 — 2010년에 무엇이<br/>바뀌었고, 누구에게 적용되는가</h1>
      <p class="page-hero-subtitle">
        그루브는 페이스에 새겨진 작은 홈입니다. 이 작은 홈이 <strong>스핀과 컨트롤의 핵심 메커니즘</strong>입니다.<br/>
        <span class="hero-sub-light">2010년 USGA·R&A는 그루브 규정을 대폭 강화했습니다. 그 변화의 의미와 현재 적용 범위를 정리합니다.</span>
      </p>
    </div>
  </section>

  <!-- 2. Quick Summary -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">QUICK SUMMARY · 핵심 4가지</p>
      <h2>2010년 그루브 규정의 핵심</h2>
      <div class="quick-grid">
        <div class="quick-card">
          <p class="quick-num">01</p>
          <h3 class="quick-title">발효일<br/><strong>2010.01.01</strong></h3>
          <p class="quick-body">신규 제조 클럽에 새 규정 적용. PGA Tour와 메이저 대회에 즉시 적용.</p>
        </div>
        <div class="quick-card">
          <p class="quick-num">02</p>
          <h3 class="quick-title">엣지 라운딩<br/><strong>0.010인치 +</strong></h3>
          <p class="quick-body">25° 이상 클럽의 그루브 엣지에 최소 0.010인치(0.254mm) 반지름.</p>
        </div>
        <div class="quick-card">
          <p class="quick-num">03</p>
          <h3 class="quick-title">단면적·간격<br/><strong>비율 제한</strong></h3>
          <p class="quick-body">그루브 단면적 / 인접 그루브 간격의 비율로 그루브 부피 제한.</p>
        </div>
        <div class="quick-card">
          <p class="quick-num">04</p>
          <h3 class="quick-title">일반 골퍼<br/><strong>여전히 OK</strong></h3>
          <p class="quick-body">모범 로컬 룰 G-2. 일반 라운드에서 2009년 이전 그루브 사용 가능.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. 그루브의 역할 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">FUNDAMENTALS · 그루브의 역할</p>
      <h2>그루브는 무엇을 하는가</h2>
      <p class="section-body">
        그루브는 단순한 장식이 아닙니다. 임팩트 순간 페이스와 볼 사이의 <strong>접촉 마찰을 결정</strong>하는 핵심 구조입니다.
        그루브가 하는 일은 두 가지입니다.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">그루브의 두 가지 기능</p>
        <ul class="rule-list">
          <li>
            <strong>① 이물질 배출</strong><br/>
            잔디·흙·물기가 페이스와 볼 사이에 있을 때, 그루브 안으로 빠져 페이스가 볼과 직접 접촉하도록 함.
            러프나 젖은 잔디에서 결정적인 역할.
          </li>
          <li>
            <strong>② 마찰 생성</strong><br/>
            그루브 엣지가 볼 표면을 미세하게 잡아 회전(스핀)을 부여. 엣지가 날카로울수록 마찰이 강하고, 결과적으로 스핀이 많이 발생.
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">왜 USGA가 개입했는가</h3>
      <p class="section-body">
        2000년대 중반, USGA·R&A는 골프의 본질적인 문제를 인식했습니다.
        프로 선수들이 <strong>러프에서도 페어웨이만큼 좋은 스핀</strong>을 만들고 있었어요.
        결과적으로 "정확한 드라이브"의 가치가 떨어지고,
        파워풀한 거리만이 우승의 가장 중요한 요소가 되어가고 있었습니다.
      </p>
      <p class="section-body">
        2007년 USGA가 그루브의 영향을 본격 연구한 결과,
        러프에서의 스핀이 <strong>U그루브(박스 그루브)에서 비정상적으로 높다</strong>는 결론에 도달했습니다.
        2008년 8월 변경안 발표, 2010년 1월 1일 발효까지 약 17개월의 유예 기간이 있었습니다.
      </p>
    </div>
  </section>

  <!-- 4. V그루브 vs U그루브 역사 -->
  <section class="section section-bg-cream">
    <div class="section-content-narrow">
      <p class="section-eyebrow">HISTORY · 그루브의 역사</p>
      <h2>V그루브에서 U그루브로, 그리고 다시</h2>
      <div class="history-timeline">
        <div class="timeline-item">
          <div class="timeline-year">~1984</div>
          <div class="timeline-body">
            <strong>V그루브 시대</strong> — 모든 클럽이 V자 단면 그루브. 단조 가공의 한계로 V형이 자연스러운 선택.
            러프에서 스핀이 적게 나와 정확성의 가치가 컸던 시기.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">1984</div>
          <div class="timeline-body">
            <strong>U그루브 허용</strong> — 주조(인베스트먼트 캐스팅) 기술 발전으로 U자 단면 그루브 제작 가능.
            USGA 규정에서 "V형이어야 한다"는 조항 삭제. U그루브 시대 시작.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">1990</div>
          <div class="timeline-body">
            <strong>핑 EYE 2 소송</strong> — PGA Tour가 핑(Karsten Manufacturing)의 EYE 2 아이언 U그루브를 부적합 판정.
            법정 분쟁 끝에 PGA Tour가 합의로 사용을 허용. U그루브의 합법성이 굳어짐.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2000~2007</div>
          <div class="timeline-body">
            <strong>U그루브 진화기</strong> — 클리블랜드, 보키, 미즈노 등이 더 깊고 날카로운 U그루브로
            <strong>러프에서도 7,000~9,000rpm 스핀</strong>을 만들어내기 시작.
            "러프에서 핀에 붙이기"가 일상화.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2007.02</div>
          <div class="timeline-body">
            <strong>USGA·R&A 그루브 변경 제안</strong> — 메이커들로부터 의견 수렴 시작.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2008.08</div>
          <div class="timeline-body">
            <strong>새 규정 채택</strong> — 단면적/간격 비율 + 엣지 라운딩 발표. 2010년 1월 1일 발효 결정.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2010.01.01</div>
          <div class="timeline-body">
            <strong>새 규정 발효</strong> — 모든 신제품 적용. PGA Tour, 유러피언 투어, LPGA 즉시 채택.
            메이저 챔피언십(US Open, US Women's Open, US Senior Open)도 적용.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2014.01.01</div>
          <div class="timeline-body">
            <strong>USGA 모든 챔피언십에 확대</strong> — US 아마추어, US 미드아마추어 등도 적용 시작.
            엘리트 아마추어 대회가 새 규정에 합류.
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-year">2024~현재</div>
          <div class="timeline-body">
            <strong>일반 골퍼는 여전히 모범 로컬 룰</strong> — 일반 골퍼의 일반 라운드에서는 여전히
            2009년 이전 그루브 사용 가능. USGA가 "최소 4년 후" 적용 검토 중이지만 발표 X.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. 새 규정 상세 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">REGULATION · 새 규정 상세</p>
      <h2>2010년 규정의 두 가지 핵심</h2>
      <p class="section-body">
        새 그루브 규정은 그루브의 모양(V냐 U냐)을 직접 규제하지 않습니다.
        대신 <strong>두 가지 측정값</strong>으로 그루브의 효과를 제한합니다.
      </p>

      <h3 class="subsection-h3">규정 ① 단면적 / 간격 비율</h3>
      <p class="section-body">
        그루브의 단면적(cross-sectional area)을 인접 그루브 간격(pitch)으로 나눈 값에 한계를 둡니다.
        쉽게 표현하면 <strong>"페이스 1인치당 그루브가 차지하는 부피"</strong>입니다.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">왜 이 비율이 중요한가</p>
        <ul class="rule-list">
          <li>
            <strong>U그루브의 우위 차단</strong>: U그루브는 같은 폭이라도 V그루브보다 단면적이 큼.
            단면적/간격 비율로 제한하면 U그루브를 만들려면 간격을 더 넓게 해야 함.
          </li>
          <li>
            <strong>총 그루브 양 제한</strong>: 그루브가 차지하는 페이스 공간이 줄어들어 이물질 배출 능력 제한.
            러프나 젖은 라이에서 스핀 감소.
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">규정 ② 엣지 반지름 (Edge Radius) — 0.010인치 이상</h3>
      <p class="section-body">
        25° 이상의 로프트를 가진 클럽(5번 아이언 ~ 웨지 전체)의 그루브 엣지에는
        <strong>최소 0.010인치(0.254mm)의 반지름</strong>이 적용되어야 합니다.
        이전 규정에서는 가공 직후의 날카로운 엣지가 그대로 허용됐었어요.
        새 규정은 엣지를 <strong>의도적으로 둥글게 다듬어야</strong> 합니다.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">엣지 라운딩의 효과</p>
        <ul class="rule-list">
          <li>
            <strong>스핀 약 5~15% 감소</strong> (러프에서 측정 기준)<br/>
            엣지가 둥글면 볼 표면을 잡는 마찰력이 줄어듦.
          </li>
          <li>
            <strong>러프에서 더 큰 효과</strong><br/>
            잔디가 페이스와 볼 사이에 끼어 있을 때 엣지의 마찰이 핵심. 둥근 엣지는 잔디를 그냥 넘김.
          </li>
          <li>
            <strong>페어웨이에서는 영향 적음</strong><br/>
            깨끗한 임팩트에서는 엣지보다 그루브 자체의 깊이가 중요.
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">25° 미만 클럽 — 부피 제한만 적용</h3>
      <p class="section-body">
        25° 미만의 로프트(주로 3~4번 아이언, 하이브리드, 페어웨이우드)에는 엣지 라운딩 규정이 적용되지 않습니다.
        이런 클럽은 풀스윙 위주이고 러프에서의 스핀 의존도가 낮기 때문이에요.
        다만 단면적/간격 비율 제한은 그대로 적용됩니다.
      </p>
    </div>
  </section>

  <!-- 6. 적용 범위 -->
  <section class="section section-bg-cream">
    <div class="section-content-narrow">
      <p class="section-eyebrow">SCOPE · 적용 범위</p>
      <h2>누구에게 적용되는가 — 핵심 정리</h2>
      <p class="section-body">
        그루브 규정의 가장 헷갈리는 부분이 바로 <strong>적용 범위</strong>입니다.

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const adjustableRulesSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': 'https://myclubmakers.com/equipment-rules/adjustable/#article',
  headline: '어드저스터블 클럽 규정 — 슬리브·웨이트·납테이프와 라운드 중 조정 금지',
  description: 'USGA·R&A Rule 4.1a 어드저스터블 클럽 규정 한글 정리. 슬리브 호젤·이동식 웨이트·납테이프 사용 규정. 라운드 중 조정 금지 (위반 시 DQ). 클럽메이커스 24년 현장 해석.',
  inLanguage: 'ko-KR',
  author: {
    '@type': 'Person',
    name: '채기웅',
    url: 'https://myclubmakers.com/about',
  },
  publisher: {
    '@type': 'Organization',
    name: '클럽메이커스',
    url: 'https://myclubmakers.com',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '드라이버 슬리브를 라운드 시작 후 다시 조정해도 되나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '안 됩니다. Rule 4.1a(3)에 따라 라운드 중 어드저스터블 기능을 사용해 클럽 성능을 변경하면 그 클럽으로 다음 스트로크를 했을 때 실격(Disqualification)입니다. 다만 변경 후 다음 스트로크 전에 원래 위치로 되돌리면 페널티가 없습니다.',
      },
    },
    {
      '@type': 'Question',
      name: '납테이프를 라운드 중에 추가하거나 떼면 어떻게 되나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '실격입니다. 납테이프는 라운드 시작 전엔 자유롭게 추가·제거·이동할 수 있지만, 라운드 시작 후엔 변경 금지입니다. 라운드 중 납테이프가 자연스럽게 떨어진 경우는 페널티 없이 그대로 진행 가능합니다 — 의도적 변경만 금지.',
      },
    },
    {
      '@type': 'Question',
      name: '라운드 중에 슬리브가 살짝 풀려서 다시 조여도 되나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '클럽 손상 수리(Rule 4.1a(2))에 해당해 페널티 없이 다시 조일 수 있습니다. 단, 풀리기 전 위치로 정확히 되돌려야 합니다. 의도적으로 다른 위치로 조이면 4.1a(3) 위반입니다.',
      },
    },
    {
      '@type': 'Question',
      name: '어드저스터블 드라이버는 모든 설정에서 적합해야 하나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '네, 그렇습니다. 어드저스터블 클럽은 가능한 모든 조정 위치에서 적합 규정(부피 460cc, COR 0.830, 길이 48인치 등)을 통과해야 합니다. 한 위치에서만 적합하고 다른 위치에서 부적합이면 그 모델 자체가 적합 리스트에서 제외됩니다.',
      },
    },
    {
      '@type': 'Question',
      name: '아이언이나 웨지에도 어드저스터블 기능이 있나요?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '드물지만 있습니다. PXG 아이언 일부 모델은 백 캐비티에 이동식 웨이트가 있고, 일부 웨지는 그루브 없는 페이스 영역의 웨이트 조정이 가능합니다. 다만 일반적이지 않으며, 대부분의 어드저스터블 기능은 드라이버·페어웨이우드·하이브리드에 집중되어 있습니다.',
      },
    },
  ],
};
---

<BaseLayout
  title="어드저스터블 클럽 규정 — Rule 4.1a"
  description="USGA·R&A Rule 4.1a 어드저스터블 클럽 규정 한글 정리. 슬리브 호젤·이동식 웨이트·납테이프 사용 규정. 라운드 중 조정 금지 (위반 시 실격). 클럽메이커스 24년 현장 해석."
  schemaType="Article"
  keywords="어드저스터블 클럽, Rule 4.1a, 조정 가능 클럽, 슬리브, 어드저스터블 호젤, 이동식 웨이트, movable weight, 납테이프, lead tape, 라운드 중 조정, 라운드 중 납테이프, USGA 어드저스터블, 드라이버 슬리브"
  extraSchema={[adjustableRulesSchema, faqSchema]}
>

  <!-- 1. Hero -->
  <section class="page-hero adjustable-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">EQUIPMENT RULES · TOPIC 05 · 어드저스터블 클럽</div>
      <h1>어드저스터블 클럽 — 라운드 전엔 자유,<br/>라운드 중엔 절대 금지</h1>
      <p class="page-hero-subtitle">
        오늘날 시판되는 거의 모든 드라이버는 <strong>슬리브·웨이트·페이스 각도</strong> 등을 조정할 수 있습니다.<br/>
        <span class="hero-sub-light">이런 어드저스터블 기능은 합법이지만, 라운드 시작 후 조정하면 즉시 실격입니다. 그 경계를 정확히 짚어드립니다.</span>
      </p>
    </div>
  </section>

  <!-- 2. Quick Summary -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">QUICK SUMMARY · 핵심 4가지</p>
      <h2>어드저스터블 규정의 핵심</h2>
      <p class="quick-hint">카드를 누르시면 상세 설명으로 이동합니다.</p>
      <div class="quick-grid">
        <a href="#legal" class="quick-card">
          <p class="quick-num">01</p>
          <h3 class="quick-title">장비 자체는<br/><strong>합법</strong></h3>
          <p class="quick-body">슬리브, 이동식 웨이트, 조정 가능 페이스 모두 합법.</p>
          <span class="quick-arrow">자세히 ↓</span>
        </a>
        <a href="#conditions" class="quick-card">
          <p class="quick-num">02</p>
          <h3 class="quick-title">3가지<br/><strong>조건 충족</strong></h3>
          <p class="quick-body">쉽게 조정 X · 단단히 고정 · 모든 위치에서 적합.</p>
          <span class="quick-arrow">자세히 ↓</span>
        </a>
        <a href="#during-round" class="quick-card">
          <p class="quick-num">03</p>
          <h3 class="quick-title">라운드 중<br/><strong>조정 금지</strong></h3>
          <p class="quick-body">라운드 시작 후 조정 → 그 클럽으로 친 순간 <strong>실격</strong>.</p>
          <span class="quick-arrow">자세히 ↓</span>
        </a>
        <a href="#lead-tape" class="quick-card">
          <p class="quick-num">04</p>
          <h3 class="quick-title">납테이프<br/><strong>전엔 OK · 중엔 X</strong></h3>
          <p class="quick-body">전통적 예외. 라운드 시작 전엔 자유, 시작 후엔 일절 변경 금지.</p>
          <span class="quick-arrow">자세히 ↓</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 3. 어드저스터블 클럽이 합법인 근거 -->
  <section class="section" id="legal">
    <div class="section-content-narrow">
      <p class="section-eyebrow">REGULATION 01 · 합법성</p>
      <h2>어드저스터블 클럽은 모두 합법</h2>
      <p class="section-body">
        오해하기 쉬운 부분 — 어드저스터블 클럽은 <strong>USGA·R&A 규정상 완전히 합법</strong>입니다.
        장비 적합성 규정(Equipment Rules)은 어드저스터블 기능을 명시적으로 허용해요.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">조정 가능한 항목</p>
        <ul class="rule-list">
          <li>
            <strong>로프트(Loft)</strong> — 슬리브 어댑터로 1~2도 단위 조정. 대부분의 드라이버·페어웨이우드 적용
          </li>
          <li>
            <strong>라이(Lie)</strong> — 슬리브 회전으로 업라이트/플랫 조정. 페이스 각도와 함께 변함
          </li>
          <li>
            <strong>페이스 각도(Face Angle)</strong> — 클로즈드/오픈 설정. 슬리브 회전과 연동
          </li>
          <li>
            <strong>무게 위치(Weight Distribution)</strong> — 헤드의 이동식 웨이트로 무게중심 변경. 드로우/페이드 바이어스 또는 MOI 변화
          </li>
          <li>
            <strong>전체 무게(Total Weight)</strong> — 웨이트 자체를 다른 무게로 교체 (예: 8g ↔ 12g)
          </li>
          <li>
            <strong>길이(Length)</strong> — 일부 모델은 익스텐션 부품 가능. 흔치 않음
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">대표 어드저스터블 시스템</h3>
      <ul class="penalty-list">
        <li><strong>TaylorMade SureFit · Loft Sleeve</strong> — 8~12 위치 슬리브, ±2도 로프트 조정</li>
        <li><strong>Titleist SureFit Hosel</strong> — 16개 위치 매트릭스 (4 로프트 × 4 라이)</li>
        <li><strong>PING Trajectory Tuning</strong> — 5~8 위치 슬리브</li>
        <li><strong>Callaway OptiFit</strong> — 8 위치 슬리브 + 이동식 웨이트</li>
        <li><strong>Cobra MyFly</strong> — 8 위치 슬리브 + Front-Back 웨이트</li>
      </ul>

      <p class="section-body">
        모든 메이저 메이커가 어드저스터블 시스템을 표준 탑재합니다.
        2010년경 본격 도입되어 지금은 거의 모든 드라이버가 어드저스터블 호젤을 가지고 있어요.
      </p>
    </div>
  </section>

  <!-- 4. 3가지 조건 -->
  <section class="section section-bg-cream" id="conditions">
    <div class="section-content-narrow">
      <p class="section-eyebrow">REGULATION 02 · 적합 조건</p>
      <h2>어드저스터블이 합법이 되는 3가지 조건</h2>
      <p class="section-body">
        모든 어드저스터블 기능이 무조건 합법은 아닙니다.
        USGA·R&A 장비 규정 1b 항목은 <strong>3가지 조건을 모두 충족</strong>해야 한다고 명시합니다.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">3가지 적합 조건</p>
        <ul class="rule-list">
          <li>
            <strong>① 쉽게 조정될 수 없어야 함</strong><br/>
            특수 도구(렌치 등)가 필요해야 합니다. 손으로 빠르게 돌려서 변경 가능한 구조는 부적합.
            라운드 중 신속한 변경을 막기 위한 조항입니다.
          </li>
          <li>
            <strong>② 단단히 고정되어야 함</strong><br/>
            라운드 중 진동이나 충격으로 풀릴 가능성이 거의 없어야 합니다.
            느슨한 결합은 부적합.
          </li>
          <li>
            <strong>③ 모든 조정 위치에서 적합해야 함</strong><br/>
            예: 드라이버 슬리브가 8개 위치라면, 8개 모두에서 부피 460cc · COR 0.830 · MOI 5,900 · 길이 48인치 한계 안에 있어야 합니다.
            한 위치에서만 적합하고 다른 위치에서 부적합이면 모델 자체가 부적합.
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">납테이프(Lead Tape)는 1번 조건의 예외</h3>
      <p class="section-body">
        ①번 조건에 따르면 납테이프 부착·제거도 어렵게 만들어야 하지만, 납테이프는 <strong>전통적 관행</strong>으로 인정되어
        예외로 허용됩니다. 즉 손가락만으로 떼고 붙일 수 있어도 적합입니다 — 다만 <strong>라운드 중 변경은 절대 금지</strong>입니다 (다음 섹션 참고).
      </p>

      <h3 class="subsection-h3">제조사 적합 검증 절차</h3>
      <p class="section-body">
        어드저스터블 드라이버를 출시하려면 제조사가 USGA에 모델 제출 시 <strong>모든 조정 위치별로 적합성 데이터</strong>를 함께 제출합니다.
        예: 8개 위치 슬리브 모델이라면 8개 위치 각각에서 측정한 부피·COR·MOI·길이 데이터가 필요해요.
        한 위치에서라도 한계를 넘으면 모델 전체가 부적합 판정.
      </p>
    </div>
  </section>

  <!-- 5. 라운드 중 조정 금지 -->
  <section class="section" id="during-round">
    <div class="section-content-narrow">
      <p class="section-eyebrow">REGULATION 03 · 라운드 중 조정</p>
      <h2>Rule 4.1a(3) — 라운드 중 의도적 변경은 실격</h2>
      <p class="section-body">
        어드저스터블 클럽의 가장 중요한 룰은 <strong>"라운드 중 의도적으로 성능을 변경하면 실격"</strong>입니다.
        Rule 4.1a(3)에 명확히 규정되어 있어요.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">Rule 4.1a(3) 본문 요지</p>
        <p style="font-size: 15px; line-height: 1.85; color: var(--ink-2); margin: 0;">
          "선수는 라운드 중(플레이가 중단된 시간 포함, Rule 5.7a) 의도적으로 클럽의 성능을 변경한 후
          그 클럽으로 스트로크를 해서는 안 된다. 변경 방법:<br/>
          ① 어드저스터블 기능 사용 또는 물리적 변경 (Rule 4.1a(2)의 손상 수리는 예외)<br/>
          ② 클럽 헤드에 물질 도포 (청소 목적은 예외) — 성능에 영향을 주는 행위"
        </p>
      </div>

      <h3 class="subsection-h3">위반 페널티 — 실격(Disqualification)</h3>
      <p class="section-body">
        Rule 4.1a 위반의 페널티는 <strong>매치플레이·스트로크플레이 모두 실격</strong>입니다.
        이는 14개 클럽 룰의 페널티(2벌타~4벌타)보다 훨씬 무거워요.
        의도적인 장비 변경은 골프의 본질을 훼손한다는 USGA·R&A의 강력한 입장이 반영된 것입니다.
      </p>

      <h3 class="subsection-h3">중요한 예외 — 원래 위치로 되돌리면 페널티 없음</h3>
      <p class="section-body">
        실수로 슬리브를 돌렸거나, 호기심으로 위치를 바꿨다고 해도
        <strong>다음 스트로크 전에 원래 위치로 정확히 되돌리면</strong> 페널티가 없습니다.
        이 예외 조항이 실제 라운드에서 가장 자주 적용되는 부분입니다.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">실제 적용 시나리오</p>
        <ul class="rule-list">
          <li>
            <strong>시나리오 1 — 안전</strong><br/>
            5번 홀에서 슬리브를 돌려봤다가 즉시 원래 위치로 되돌리고 친다 → <strong>페널티 없음</strong>
          </li>
          <li>
            <strong>시나리오 2 — 위반</strong><br/>
            5번 홀에서 슬리브를 +1도 위치로 바꾸고 그대로 친다 → <strong>실격(DQ)</strong>
          </li>
          <li>
            <strong>시나리오 3 — 안전</strong><br/>
            슬리브가 라운드 중 자연스럽게 풀린 것을 발견하고 원래 위치로 다시 조이고 친다 → <strong>페널티 없음</strong> (Rule 4.1a(2) 손상 수리 적용)
          </li>
          <li>
            <strong>시나리오 4 — 위반</strong><br/>
            클럽 페이스에 왁스를 발라 마찰을 늘리고 친다 → <strong>실격(DQ)</strong>
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">단순 소지는 페널티 X</h3>
      <p class="section-body">
        라운드 시작 전 잘못 설정된 클럽이나 변경된 클럽을 <strong>가지고만 있고 사용하지 않으면</strong>
        Rule 4.1a 위반이 아닙니다 (다만 14개 클럽 한계에는 포함됨).
        실제 위반은 "그 클럽으로 스트로크를 한 순간"에 성립합니다.
      </p>
    </div>
  </section>

  <!-- 6. 납테이프 -->
  <section class="section section-bg-cream" id="lead-tape">
    <div class="section-content-narrow">
      <p class="section-eyebrow">REGULATION 04 · 납테이프 (Lead Tape)</p>
      <h2>납테이프 — 가장 오래된 어드저스터블 도구</h2>
      <p class="section-body">
        납테이프는 헤드 무게를 미세 조정하는 가장 전통적인 방법입니다.
        50년 이상 사용되어 온 도구라 USGA·R&A 규정에서도 <strong>특별 예외</strong>로 인정받습니다.
      </p>

      <div class="rule-box">
        <p class="rule-box-title">납테이프 규정의 두 측면</p>
        <ul class="rule-list">
          <li>
            <strong>예외 ① 쉽게 부착·제거 가능 OK</strong><br/>
            기본 어드저스터블 규정 ①번(쉽게 조정 X)의 예외. 손으로 떼고 붙일 수 있어도 합법.
            "전통적 관행(traditional grounds)"으로 인정.
          </li>
          <li>
            <strong>금지 ② 라운드 중 변경 절대 X</strong><br/>
            Rule 4.1a(3) 적용. 라운드 시작 후 납테이프를 추가·제거·이동하면 실격.
            이 부분은 슬리브와 동일하게 엄격.
          </li>
        </ul>
      </div>

      <h3 class="subsection-h3">납테이프 부착 방법</h3>
      <ul class="penalty-list">
        <li><strong>표준 무게</strong>: 폭 0.5인치(12.7mm) × 길이 1인치당 약 1g</li>
        <li><strong>SW 영향</strong>: 헤드에 1g 추가 시 SW 약 0.7~0.8 포인트 증가</li>
        <li><strong>부착 위치</strong>: 토(Toe) 쪽 → 페이드 바이어스 / 힐(Heel) 쪽 → 드로우 바이어스</li>
        <li><strong>솔(Sole) 위치</strong>: 무게중심을 낮춰 런치 앵글 상승</li>
        <li><strong>크라운(Crown) 위치</strong>: 무게중심을 높여 런치 앵글 감소</li>
      </ul>

      <h3 class="subsection-h3">시나리오 — 납테이프 라운드 중 떨어진 경우</h3>
      <p class="section-body">
        라운드 중 임팩트 충격이나 잔디 마찰로 납테이프가 자연스럽게 떨어지는 경우가 있어요.
        이 경우는 <strong>"의도적 변경이 아니므로" 페널티가 없습니다</strong>.
        떨어진 납테이프를 다시 붙이는 것만 위반에 해당합니다.
        라운드 후 다음 라운드 전까지는 자유롭게 다시 부착할 수 있어요.
      </p>

      <h3 class="subsection-h3">현대 헤드의 납테이프 — 점점 줄어드는 추세</h3>
      <p class="section-body">
        2010년경부터 어드저스터블 웨이트 시스템(이동식 웨이트)이 일반화되면서
        납테이프 사용이 점차 줄어들고 있어요.
        다만 <strong>아이언과 웨지의 미세 무게 조정</strong>은 여전히 납테이프가 표준입니다 — 어드저스터블 시스템이 거의 없기 때문이에요.
        프로 선수들 중에도 아이언 호젤·캐비티에 납테이프 부착 후 라운드 시작하는 경우가 많습니다.
      </p>
    </div>
  </section>

  <!-- 7. 자연 마모 vs 의도적 변경 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">WEAR vs DELIBERATE · 자연 마모와 의도적 변경</p>
      <h2>변하는 것이 모두 위반은 아닙니다</h2>
      <p class="section-body">
        Rule 4.1a는 "<strong>의도적</strong>" 변경만 금지합니다. 자연스러운 마모나 외부 요인에 의한 변화는 페널티가 없어요.
        이 구분이 실제 적용에서 가장 헷갈리는 부분입니다.
      </p>

      <div class="compare-table">
        <table>
          <thead>
            <tr>
              <th>상황</th>
              <th>의도적?</th>
              <th>판정</th>
            </tr>
          </thead>
          <tbody>
            <tr class="row-applies">
              <td><strong>라운드 중 슬리브 위치 변경 후 그대로 침</strong></td>
              <td>의도적</td>
              <td><span class="badge badge-illegal">실격</span></td>
            </tr>
            <tr class="row-not-applies">
              <td><strong>슬리브 변경 후 다음 스트로크 전 원래 위치로</strong></td>
              <td>예외 적용</td>
              <td><span class="badge badge-legal">페널티 없음</span></td>
            </tr>
            <tr class="row-applies">
              <td><strong>라운드 중 납테이프 추가</strong></td>
              <td>의도적</td>
              <td><span class="badge badge-illegal">실격</span></td>
            </tr>
            <tr class="row-not-applies">
              <td><strong>임팩트로 납테이프가 자연스럽게 떨어짐</strong></td>
              <td>비의도적</td>
              <td><span class="badge badge-legal">페널티 없음</span></td>
            </tr>
            <tr class="row-not-applies">
              <td><strong>라운드 중 슬리브가 자연스럽게 풀려서 다시 조임 (원위치)</strong></td>
              <td>비의도적 (손상 수리)</td>
              <td><span class="badge badge-legal">페널티 없음</span></td>
            </tr>
            <tr class="row-applies">
              <td><strong>페이스에 왁스나 점성 물질 도포</strong></td>
              <td>의도적</td>
              <td><span class="badge badge-illegal">실격</span></td>
            </tr>
            <tr class="row-not-applies">
              <td><strong>젖은 페이스를 수건으로 닦음</strong></td>
              <td>청소 (예외)</td>
              <td><span class="badge badge-legal">페널티 없음</span></td>
            </tr>
            <tr class="row-not-applies">
              <td><strong>1년간 사용으로 그루브 자연 마모</strong></td>
              <td>비의도적 (자연 마모)</td>
              <td><span class="badge badge-legal">페널티 없음</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="compare-note">
        <strong>핵심 구분</strong>: "의도적 변경"이냐 "자연 또는 손상에 의한 변화"냐가 판정 기준입니다.
        의심스러우면 동반자에게 알리고 위치를 명확히 표시하는 것이 안전합니다.
      </p>
    </div>
  </section>

  <!-- 8. 클럽메이커스 해석 -->
  <section class="section section-bg-green">
    <div class="section-content-narrow">
      <p class="section-eyebrow apply-eyebrow">CLUBMAKERS' INTERPRETATION · 공작소 해석</p>
      <h2 class="green-h2">현장에서 본 어드저스터블 규정</h2>
      <p class="green-body">
        어드저스터블 규정은 일반 골퍼가 가장 자주 헷갈리는 영역입니다.
        24년 공작소에서 만난 케이스를 정리합니다.
      </p>
      <ul class="interpretation-list">
        <li>
          <strong>"슬리브가 헐거워졌어요. 라운드 중 다시 조여도 되나요?"</strong><br/>
          <span class="green-body-small">자연스럽게 풀린 경우 원래 위치로 다시 조이는 것은 페널티 없습니다 (Rule 4.1a(2) 손상 수리 적용).
          다만 정확히 원위치인지 확신이 없으면 그 클럽을 사용하지 않는 것이 안전합니다.</span>
        </li>
        <li>
          <strong>"공작소에서 슬리브 설정 후 출고 — 그대로 라운드 가능?"</strong><br/>
          <span class="green-body-small">네, 가능합니다. 라운드 시작 전 설정은 자유. 일단 라운드를 시작하면 그 설정 그대로 마쳐야 합니다.
          분석 후 슬리브 조정은 라운드 전에만 가능하다는 점, 고객님께 명확히 안내드립니다.</span>
        </li>
        <li>
          <strong>"납테이프 라운드 중 새로 붙여보고 싶어요"</strong><br/>
          <span class="green-body-small">아니요, 안 됩니다. 납테이프는 라운드 시작 전에만 추가 가능. 라운드 중 추가는 실격입니다.
          새 납테이프 위치를 시도해보고 싶으시면 라운드 시작 전 결정하시거나 연습 라운드에서 시도하시기 바랍니다.</span>
        </li>
        <li>
          <strong>"드라이버 슬리브 8개 위치 — 어떻게 활용?"</strong><br/>
          <span class="green-body-small">대부분의 골퍼는 한두 개 위치만 사용하시면 충분합니다. 분석 결과로 최적 위치 결정 후
          그 위치 고정. 슬리브를 자주 바꾸면 일관성이 떨어져 오히려 스코어가 안 좋아지는 경우가 많아요.</span>
        </li>
        <li>
          <strong>"이동식 웨이트 — 드로우/페이드 바이어스를 자주 바꾸려는 분들"</strong><br/>
          <span class="green-body-small">코스에 따라 바이어스를 바꾸시려는 분들이 있는데, 이 또한 라운드 시작 전에만 가능합니다.
          한 라운드 안에서 바꾸면 실격. 일관성을 위해 한 위치로 고정하시는 것을 권합니다.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- 9. FAQ -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">FAQ · 자주 묻는 질문</p>
      <h2>실무에서 자주 받는 질문</h2>
      <ul class="faq-list">
        <li class="faq-item">
          <p class="faq-q">Q1. 라운드 중 슬리브 토크가 부족해 보여 다시 조여도 되나요?</p>
          <p class="faq-a">네, <strong>원래 위치로</strong> 다시 조이는 것은 페널티 없습니다 (Rule 4.1a(2) 손상 수리).
          다만 다른 위치로 조정하면 안 됩니다. 정확히 원위치인지 확신이 없으면 다음 라운드까지 다른 클럽으로 진행하세요.</p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q2. 공작소에서 슬리브 토크 점검 받을 수 있나요?</p>
          <p class="faq-a">네, 가능합니다. 슬리브 풀림은 자주 점검하시는 것이 안전합니다.
          정확한 토크 값(보통 4~5 N·m)으로 다시 조여드립니다. 라운드 후 점검을 권장합니다 — 슬리브 풀림이 발견되면
          정확한 위치 확인 어렵습니다.</p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q3. 어드저스터블 클럽이 일반 클럽보다 부적합 위험이 큰가요?</p>
          <p class="faq-a">아닙니다. 모든 시판 어드저스터블 모델은 모든 위치에서 적합 검증을 통과했습니다.
          오히려 골퍼가 라운드 중 실수로 변경하는 위험이 있어요. 공작소에서 출고 시 슬리브 위치를 명확히 표시하고,
          본인이 그 위치를 알고 계시면 위험 거의 없습니다.</p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q4. 라운드 중 헤드 커버에 적힌 슬리브 위치를 보고 확인해도 되나요?</p>
          <p class="faq-a">네, <strong>설정 확인은 페널티가 없습니다</strong>. 변경하지 않으면 됩니다.
          헤드 커버나 클럽 가방에 본인의 설정 위치를 적어두시는 것은 좋은 습관이에요.
          분실·변경 시 빠르게 원위치 복구 가능합니다.</p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q5. 라운드 끝나고 다음 라운드 전에 슬리브 변경 가능한가요?</p>
          <p class="faq-a">네, 자유롭게 가능합니다. 룰의 "라운드"는 한 라운드 단위로 적용됩니다.
          다음 티오프 전이라면 슬리브·웨이트·납테이프 모두 자유롭게 조정 가능. 36홀 대회의 경우 1라운드 종료~2라운드 시작 사이의 휴식 시간에 조정 가능합니다.</p>
        </li>
      </ul>
    </div>
  </section>


---
import BaseLayout from '../../layouts/BaseLayout.astro';

// 장비 규정 페이지 — JSON-LD 스키마
const equipmentRulesSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://myclubmakers.com/equipment-rules/#equipment-rules',
  name: '골프 장비 규정 가이드 — USGA · R&A',
  alternateName: ['Equipment Rules Guide', 'PGA 장비 룰 한글 정리'],
  description: 'USGA·R&A 골프 장비 규정 한글 정리. 드라이버 COR·부피·길이, 그루브, 볼, 14개 클럽 룰, 조정 가능 클럽 등 8개 토픽으로 구성. 클럽메이커스 24년 현장 관점의 해석 포함.',
  inLanguage: 'ko-KR',
  publisher: {
    '@type': 'Organization',
    name: '클럽메이커스',
    url: 'https://myclubmakers.com',
  },
  author: {
    '@type': 'Person',
    name: '채기웅',
    jobTitle: '클럽메이커스 공작소장',
    url: 'https://myclubmakers.com/about',
  },
};

// 8개 토픽 카드 데이터
const topics = [
  {
    href: '/equipment-rules/driver',
    eyebrow: 'TOPIC 01',
    title: '드라이버 규정',
    summary: 'COR 0.830 · CT 257μs · 부피 460cc · MOI 5,900 · 헤드 5.0×2.8인치 · 길이 48인치(엘리트 46인치)',
    keywords: 'COR, 반발계수, 헤드 부피 460cc, 드라이버 길이 48인치, 46인치 모범 로컬 룰, MOI 5900, 스프링 효과, CT 257',
    status: 'ready',
  },
  {
    href: '/equipment-rules/grooves',
    eyebrow: 'TOPIC 02',
    title: '그루브 규정',
    summary: '2010년 변경 · 엣지 라운딩 0.010인치 · 단면적/간격 비율 제한 · V/U그루브 · 일반 골퍼 적용 X',
    keywords: '그루브 규정, 2010 그루브, V그루브, U그루브, 엣지 라운딩, Model Local Rule G-2, Ping Eye 2',
    status: 'ready',
  },
  {
    href: '/equipment-rules/ball',
    eyebrow: 'TOPIC 03',
    title: '볼 규정',
    summary: '직경 1.68인치 · 무게 1.62oz · 초속 ODS · 대칭성 · 적합 볼 리스트',
    keywords: '골프공 규격, 볼 무게, 볼 직경, ODS, 대칭성, 적합 볼',
    status: 'soon',
  },
  {
    href: '/equipment-rules/14-clubs',
    eyebrow: 'TOPIC 04',
    title: '14개 클럽 규칙',
    summary: '한 라운드 최대 14개 · 시작·중간 추가·교체 규정 · 위반 시 페널티',
    keywords: '14개 클럽, 클럽 개수, 페널티, 라운드 중 교체',
    status: 'soon',
  },
  {
    href: '/equipment-rules/adjustable',
    eyebrow: 'TOPIC 05',
    title: '조정 가능 클럽',
    summary: '어드저스터블 호젤·웨이트 · 라운드 중 조정 금지 · 출발 전 설정',
    keywords: '어드저스터블, 조정 가능, 호젤, 무게추, 라운드 중',
    status: 'soon',
  },
  {
    href: '/equipment-rules/wedges',
    eyebrow: 'TOPIC 06',
    title: '웨지 특수 규정',
    summary: '그루브 폭·깊이·예리함 한계 · 페이스 거칠기 · 30° 이상 클럽 적용',
    keywords: '웨지 그루브, 웨지 규정, 거칠기, 콘덴서드 룰',
    status: 'soon',
  },
  {
    href: '/equipment-rules/putters',
    eyebrow: 'TOPIC 07',
    title: '퍼터 규정',
    summary: '앵커링 금지 (Rule 10.1b) · 롱퍼터·브룸스틱·벨리퍼터 합법 · arm-lock 허용 · 최대 48인치',
    keywords: '앵커링 금지, Rule 10.1b, 롱퍼터, 브룸스틱, 벨리퍼터, arm-lock, 아담 스콧, 디섐보',
    status: 'ready',
  },
  {
    href: '/equipment-rules/clubs',
    eyebrow: 'TOPIC 08',
    title: '클럽 일반 규정',
    summary: '샤프트 · 그립 형태 · 헤드 모양 · 페이스 마킹 · 이질 재료 금지',
    keywords: '샤프트 규격, 그립 형태, 헤드 모양, 페이스, 클럽 구조',
    status: 'soon',
  },
];
---

<BaseLayout
  title="장비 규정 — USGA · R&A 한글 정리"
  description="USGA·R&A 골프 장비 규정 한글 가이드. 드라이버 COR·부피·길이, 그루브, 볼 규격, 14개 클럽 룰, 조정 가능 클럽까지 8개 토픽. 클럽메이커스 24년 현장 관점의 해석 포함."
  schemaType="CollectionPage"
  keywords="골프 장비 규정, USGA 장비 규칙, R&A 장비 규정, PGA 룰, 드라이버 COR, 드라이버 길이 46인치, 그루브 규정, 14개 클럽 룰, 적합 클럽 리스트, 골프 룰 한글, 장비 규정 한글"
  extraSchema={equipmentRulesSchema}
>

  <!-- 1. Hero -->
  <section class="page-hero rules-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">EQUIPMENT RULES · 장비 규정</div>
      <h1>골프 장비 규정 —<br/>현장 관점에서 다시 읽기</h1>
      <p class="page-hero-subtitle">
        USGA(미국골프협회)와 R&A(영국왕립골프협회)가 공동 운영하는 <strong>골프 장비 규정(The Equipment Rules)</strong>을
        한글로 정리한 가이드입니다.<br/>
        <span class="hero-sub-light">각 규정의 정확한 수치 + 클럽메이커스 24년 현장 관점의 해석을 함께 제공합니다.</span>
      </p>
    </div>
  </section>

  <!-- 2. 왜 알아야 하는가 -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">WHY · 왜 알아야 하는가</p>
      <h2>장비 규정을 알면<br>피팅의 한계가 보입니다</h2>
      <div class="why-grid">
        <article class="why-card">
          <p class="why-num">01</p>
          <h3 class="why-title">합법 vs 불법의 기준</h3>
          <p class="why-body">
            대부분의 시판 클럽은 적합 클럽 리스트(Conforming Clubs List)에 등재되어 있어 문제 없습니다.
            다만 <strong>커스텀 작업, 길이 변경, 그라인드 추가 작업</strong>이 들어가면 적합성이 흔들릴 수 있습니다.
            기준선을 알아야 어디까지가 안전한 작업인지 판단할 수 있습니다.
          </p>
        </article>
        <article class="why-card">
          <p class="why-num">02</p>
          <h3 class="why-title">대회 출전의 안전선</h3>
          <p class="why-body">
            아마추어 대회·프로 투어·엘리트 이벤트마다 적용되는 규정이 다릅니다.
            특히 <strong>2022년부터 적용된 드라이버 길이 46인치 모범 로컬 룰(Model Local Rule)</strong>처럼,
            정식 규칙은 아니지만 대회 단위로 적용되는 경우가 많습니다.
          </p>
        </article>
        <article class="why-card">
          <p class="why-num">03</p>
          <h3 class="why-title">광고와 실제의 차이</h3>
          <p class="why-body">
            "MOI 최대치", "스프링 효과 한계까지" 같은 마케팅 표현이 무엇을 의미하는지 알아야
            구매 시 진짜 가치를 판단할 수 있습니다.
            대부분의 정품 드라이버는 출고 시 <strong>한계치 근처에 맞춰져</strong> 있어요.
          </p>
        </article>
        <article class="why-card">
          <p class="why-num">04</p>
          <h3 class="why-title">중고·오래된 클럽의 적합성</h3>
          <p class="why-body">
            오래된 드라이버는 페이스가 미세하게 늘어나 <strong>COR이 한계치를 초과</strong>할 수 있고,
            그루브가 마모되어 규정에 안 맞을 수도 있습니다.
            중고 클럽 구매·사용 전 알면 좋은 기준입니다.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- 3. 8개 토픽 카드 -->
  <section class="section">
    <div class="section-content">
      <p class="section-eyebrow">TOPICS · 8개 분야</p>
      <h2>분야별로 나눈 8개 토픽</h2>
      <p class="topics-intro">
        각 토픽은 독립된 페이지로 구성되며, 핵심 규정·정확한 수치·현장 해석을 함께 다룹니다.
        검색하시는 주제부터 바로 들어가실 수 있습니다.
      </p>

      <div class="topics-grid">
        {topics.map((t) => (
          <a
            href={t.status === 'ready' ? t.href : '#'}
            class={'topic-card' + (t.status === 'ready' ? '' : ' topic-card-soon')}
            aria-disabled={t.status !== 'ready'}
          >
            <p class="topic-eyebrow">
              {t.eyebrow}
              {t.status === 'soon' && <span class="topic-badge">준비 중</span>}
            </p>
            <h3 class="topic-title">{t.title}</h3>
            <p class="topic-summary">{t.summary}</p>
            <p class="topic-keywords">{t.keywords}</p>
            {t.status === 'ready' && <p class="topic-link">자세히 보기 →</p>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 출처와 면책 -->
  <section class="section section-bg-cream">
    <div class="section-content-narrow">
      <p class="section-eyebrow">SOURCE · 출처와 면책</p>
      <h2>이 가이드의 자료 출처</h2>
      <p class="source-body">
        이 페이지의 모든 규정 정보는 <strong>USGA(미국골프협회)와 R&A(영국왕립골프협회)의 공식 발표 자료</strong>를 기반으로
        2026년 5월 기준 정리되었습니다.
        본 가이드는 핵심 규정의 한글 요약과 현장 해석을 제공할 뿐, 공식 규정을 대체하지 않습니다.
      </p>
      <div class="source-links">
        <a href="https://www.usga.org/equipment-standards.html" target="_blank" rel="noopener noreferrer" class="source-link">
          USGA 장비 규정 공식 페이지 ↗
        </a>
        <a href="https://www.randa.org/roles/equipment-standards" target="_blank" rel="noopener noreferrer" class="source-link">
          R&A 장비 규정 공식 페이지 ↗
        </a>
      </div>
      <div class="source-disclaimer">
        <p class="disclaimer-title">⚠ 정확한 적합성 판정 기준</p>
        <p class="disclaimer-body">
          공식 대회나 핸디캡 등록 라운드에서 클럽·볼의 적합성 판정이 필요한 경우,
          <strong>USGA·R&A의 적합 장비 리스트(Conforming List)를 직접 확인</strong>하셔야 합니다.
          이 페이지는 일반 이해를 돕는 가이드이며, 법적 판정 자료가 아닙니다.
        </p>
      </div>
    </div>
  </section>

  <!-- 5. 자주 검색되는 질문 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">SEARCH · 자주 찾는 질문</p>
      <h2>자주 검색되는 질문</h2>
      <ul class="faq-list">
        <li class="faq-item">
          <p class="faq-q">Q. 드라이버 길이 46인치 제한은 모든 골퍼에게 적용되나요?</p>
          <p class="faq-a">아닙니다. <strong>모범 로컬 룰(Model Local Rule)</strong>이라 대회 주최 측이 채택할 때만 적용됩니다.
          PGA Tour·엘리트 아마추어 대회는 2022년 1월부터 적용 중. 일반 골퍼는 여전히 <strong>48인치까지</strong> 합법입니다.
          <a href="/equipment-rules/driver">드라이버 규정 자세히 →</a></p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q. COR이 한계치를 넘으면 어떻게 되나요?</p>
          <p class="faq-a">적합 클럽 리스트에서 제외되며, 공식 대회 출전 시 부적합 판정이 가능합니다.
          드라이버 페이스는 사용 시간에 따라 미세하게 늘어나 COR이 상승하는 경향이 있어,
          오래된 드라이버는 검사 시 한계치를 초과하는 경우가 있습니다.
          <a href="/equipment-rules/driver">COR·CT 측정 자세히 →</a></p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q. 어드저스터블 호젤은 라운드 중에 돌려도 되나요?</p>
          <p class="faq-a"><strong>안 됩니다.</strong> 라운드 시작 전 설정한 상태로 라운드를 마쳐야 합니다.
          출발 후 호젤 각도·로프트·웨이트를 변경하면 페널티가 부과됩니다.
          <a href="/equipment-rules/adjustable">조정 가능 클럽 자세히 →</a></p>
        </li>
        <li class="faq-item">
          <p class="faq-q">Q. 그루브 규정은 무엇이 변했나요?</p>
          <p class="faq-a">2010년부터 그루브의 폭·깊이·간격·예리함이 강화 규정되었습니다(V형·U형 단면 모두 허용).
          이전 "박스 그루브"보다 스핀이 약 5~10% 줄어드는 효과가 있었습니다.
          현행 시판 클럽은 모두 신규 규정에 맞춰 출시됩니다.
          <a href="/equipment-rules/grooves">그루브 규정 자세히 →</a></p>
        </li>
      </ul>
    </div>
  </section>

  <!-- 6. 관련 자료 -->
  <section class="section section-bg-green">
    <div class="section-content-narrow">
      <p class="section-eyebrow apply-eyebrow">RELATED · 관련 자료</p>
      <h2 class="related-h2">함께 읽으면 좋은 자료</h2>
      <div class="related-grid">
        <a href="/glossary" class="related-card">
          <p class="related-card-eyebrow">GLOSSARY</p>
          <h3 class="related-card-title">용어사전 (109개)</h3>
          <p class="related-card-body">COR · CT · MOI · 그루브 · 라이각 같은 용어 정의는 용어사전에서 확인하세요.</p>
        </a>
        <a href="/book" class="related-card">
          <p class="related-card-eyebrow">BOOK</p>
          <h3 class="related-card-title">『실제적인 클럽피팅』</h3>
          <p class="related-card-body">규정의 배경·물리 원리는 책에 더 깊이 있게 다뤄집니다.</p>
        </a>
        <a href="/contact" class="related-card">
          <p class="related-card-eyebrow">CONTACT</p>
          <h3 class="related-card-title">예약·문의</h3>
          <p class="related-card-body">내 클럽이 적합한지 궁금하신가요? 공작소에서 점검 가능합니다.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. Closing -->
  <section class="closing-section">
    <div class="closing-content">
      <h3>"규정은 클럽의 한계를 그립니다.<br>피팅은 그 한계 안에서 골퍼에게 맞춥니다."</h3>
      <p class="closing-meta">— 클럽메이커스 장비 규정 가이드</p>
      <div class="closing-actions">
        <a href="/equipment-rules/driver" class="btn-primary">드라이버 규정 보기 →</a>
        <a href="/glossary" class="btn-ghost">용어사전 →</a>
      </div>
    </div>
  </section>

</BaseLayout>


<style>
  /* ==================== HERO ==================== */
  .rules-hero { background: var(--bg-cream); }
  .hero-sub-light {
    font-size: 14px;
    color: var(--grey);
    font-weight: 400;
  }

  /* ==================== WHY 4 카드 ==================== */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 24px;
  }
  @media (min-width: 720px) {
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .why-card {
    background: var(--bg);
    border: 1px solid var(--line);
    border-left: 3px solid var(--green);
    padding: 28px 30px;
    border-radius: 4px;
  }
  .why-num {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 12px;
  }
  .why-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .why-body {
    font-size: 15px;
    line-height: 1.8;
    color: var(--ink-2);
    margin: 0;
  }
  .why-body strong { color: var(--ink); font-weight: 600; }

  /* ==================== TOPICS GRID ==================== */
  .topics-intro {
    font-size: 16px;
    line-height: 1.85;
    color: var(--ink-2);
    margin-bottom: 36px;
    max-width: 760px;
  }
  .topics-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .topics-grid { grid-template-columns: repeat(2, 1fr); }

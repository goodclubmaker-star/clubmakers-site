---
import BaseLayout from '../layouts/BaseLayout.astro';

// TPI Big12 — 12가지 신체 제한 평가 (개요)
const tpiBig12 = [
  { no: '01', name: 'Pelvic Tilt',          ko: '골반 기울기',         hint: '골반 회전 가동범위' },
  { no: '02', name: 'Pelvic Rotation',       ko: '골반 회전',           hint: '하체 분리 능력' },
  { no: '03', name: 'Torso Rotation',        ko: '몸통 회전',           hint: '상체 가동범위' },
  { no: '04', name: 'Overhead Deep Squat',   ko: '오버헤드 딥 스쿼트',   hint: '전신 가동·균형' },
  { no: '05', name: 'Toe Touch',             ko: '토 터치',             hint: '햄스트링·허리 유연성' },
  { no: '06', name: '90/90',                 ko: '90/90 어깨 회전',     hint: '어깨 외회전' },
  { no: '07', name: 'Single Leg Balance',    ko: '한 발 균형',          hint: '코어·발목' },
  { no: '08', name: 'Lat Test',              ko: '광배근 가동',         hint: '어깨 위 가동' },
  { no: '09', name: 'Lower Quarter Rotation', ko: '하체 회전',           hint: '고관절 회전' },
  { no: '10', name: 'Seated Trunk Rotation', ko: '앉은 자세 몸통 회전', hint: '척추 회전' },
  { no: '11', name: 'Bridge with Leg Ext.',  ko: '브릿지 + 다리 신장',   hint: '둔근·코어' },
  { no: '12', name: 'Cervical Rotation',     ko: '경추 회전',           hint: '시야 확보' },
];

// 트랜지션 (전환) — 4가지 다운스윙 스타일
const transitionTypes = [
  { type: '손·팔 사용형',  en: 'Hand-Arm Driven', signal: '손이 먼저 움직임. 클럽헤드 조기 풀림(early release).', shaft: '하이킥 / 팁 단단' },
  { type: '몸통 주도형',    en: 'Body Driven',     signal: '하체·몸통 먼저 회전. 지연 릴리즈(late release).',     shaft: '로우킥 / 팁 부드러움' },
  { type: '부드러운 템포',   en: 'Smooth Tempo',    signal: '백스윙→다운스윙 전환이 천천히, 리듬감 있음.',         shaft: '미드킥 / 토크 약간 높음' },
  { type: '급격한 전환',    en: 'Aggressive',      signal: '백스윙 탑에서 쏘듯 다운스윙으로 전환. 상체 급동작.',     shaft: '하이킥 / 토크 낮음' },
];

// 손목고리(Wrist Hinge) — 코킹 패턴
const wristHinges = [
  { name: '얼리 코킹',  en: 'Early Hinge',  effect: '백스윙 초기에 손목 꺾임 → 레깅 형성 어려움',  fit: '단단한 팁 / 무거운 헤드 / 높은 MOI' },
  { name: '미드 코킹',  en: 'Mid Hinge',    effect: '백스윙 중반 자연스럽게 코킹 → 일반적',         fit: '범용 — 미드킥 / 표준 MOI' },
  { name: '레이트 코킹', en: 'Late Hinge',   effect: '백스윙 후반 또는 다운스윙 초기에 코킹 → 레깅 강함', fit: '부드러운 팁 / 가벼운 헤드' },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: '클럽메이커스의 피팅 시스템 — 인터뷰부터 처방까지',
  description: '클럽메이커스의 클럽피팅 처방 시스템. 인터뷰 3단계, TPI Big12 신체 평가, 4가지 다운스윙 스타일, 손목고리(코킹), 처방 경로. 운동역학 기반 24년 노하우.',
  author: {
    '@type': 'Person',
    name: '채기웅',
    url: 'https://myclubmakers.com/about',
  },
  publisher: { '@type': 'Organization', name: '클럽메이커스' },
  inLanguage: 'ko-KR',
  about: [
    { '@type': 'Thing', name: 'TPI Screen' },
    { '@type': 'Thing', name: '키네마틱 시퀀스 (Kinematic Sequence)' },
    { '@type': 'Thing', name: '클럽피팅 시스템' },
  ],
};
---

<BaseLayout
  title="공작소의 시스템"
  description="클럽메이커스의 피팅 처방 시스템 — 인터뷰 3단계, TPI Big12 신체 평가, 4가지 다운스윙 스타일, 손목고리, 처방 경로. 운동역학 기반 24년 노하우의 정리."
  schemaType="Article"
  keywords="클럽피팅 시스템, 피팅 절차, 클럽피팅 순서, TPI Big12, 키네마틱 시퀀스, kinematic sequence, 다운스윙 스타일, 손목 코킹, wrist hinge, 트랜지션, transition, 클럽 처방, 클럽피팅 인터뷰, level 3 fitting"
  extraSchema={articleSchema}
>

  <!-- 4-1. 히어로 -->
  <article>
  <section class="page-hero system-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">SYSTEM · 공작소의 시스템</div>
      <h1>차근차근,<br>고객님의 클럽을 개선합니다</h1>
      <p class="page-hero-subtitle">
        24년 동안 다듬은 6단계 시스템이 큰 틀입니다. 매 세션은 <strong>고객님의 목표와 문제에 맞춰</strong> 진행하면서 — 한꺼번에 결정하지 않고, 한 단계씩 함께 확인하며 클럽을 조정해 갑니다.<br/>
        <span class="hero-sub-light">— 큰 틀은 같지만, 세션은 고객님께 맞춥니다.</span>
      </p>
    </div>
  </section>

  <!-- 4-2. 일반/전문가 토글 -->
  <section class="section">
    <div class="section-content-narrow">
      <div class="audience-toggle">
        <a href="#general" class="audience-tab" data-tab="general">고객님께 (간단히)</a>
        <a href="#expert" class="audience-tab" data-tab="expert">피터·전문가께 (자세히)</a>
      </div>

      <!-- 일반 고객 영역 -->
      <div id="general" class="audience-section">
        <p class="section-eyebrow">FOR EVERYONE · 처음 오시는 분께</p>
        <h2>피팅, 어떻게 진행되나요?</h2>
        <p class="section-lead">
          공작소의 분석 프로그램은 <strong>약 40~60분, 1:1 맞춤</strong>으로 진행됩니다.
          어렵게 느끼지 않으셔도 됩니다. 시험 보는 자리가 아니라, 함께 들여다보는 자리입니다.
        </p>

        <div class="step-flow">
          <div class="step-card">
            <div class="step-num">01</div>
            <h3 class="step-title">인터뷰</h3>
            <p class="step-body">
              어떤 클럽이 가장 편하신지, 어디서 미스가 나오는지, 후반엔 어떻게 무너지는지.
              먼저 이야기를 듣습니다.
            </p>
            <div class="step-time">10~15분</div>
          </div>
          <div class="step-card">
            <div class="step-num">02</div>
            <h3 class="step-title">신체·스윙 측정</h3>
            <p class="step-body">
              키, 손목-바닥 거리(WTF), 손 크기, 악력, 그리고 스윙 영상.
              필요시 TPI Screen 일부를 진행합니다.
            </p>
            <div class="step-time">15~20분</div>
          </div>
          <div class="step-card">
            <div class="step-num">03</div>
            <h3 class="step-title">클럽 측정·시타</h3>
            <p class="step-body">
              현재 클럽의 라이각·로프트·CPM·SW를 측정합니다.
              필요시 시타로 검증합니다.
            </p>
            <div class="step-time">15~20분</div>
          </div>
          <div class="step-card">
            <div class="step-num">04</div>
            <h3 class="step-title">처방·상담</h3>
            <p class="step-body">
              결과를 함께 보면서 다음 단계를 의논합니다.
              <strong>지금 바꾸지 않아도 되는 것</strong>도 분명히 말씀드립니다.
            </p>
            <div class="step-time">10분</div>
          </div>
        </div>

        <div class="callout">
          <p>
            <strong>"이 정도 일로 와도 될까"</strong> 망설이지 않으셔도 됩니다.
            그립이 미끄러지는 작은 문제부터, 새 클럽을 골라야 하는 큰 결정까지 — 어떤 단계라도 환영합니다.
          </p>
        </div>
      </div>

      <!-- 전문가 영역 -->
      <div id="expert" class="audience-section expert-section">
        <p class="section-eyebrow">FOR FITTERS · 피터·전문가께</p>
        <h2>처방의 6단계 시스템</h2>
        <p class="section-lead">
          클럽메이커스는 <strong>인터뷰 → 신체 → 스윙 → 데이터 → 클럽 → 처방</strong>의 6단계
          시스템으로 피팅을 진행합니다. 책 『실제적인 클럽피팅』의 PART 1~11에 해당합니다.
        </p>

        <table class="table system-table">
          <thead>
            <tr>
              <th style="width: 60px;">단계</th>
              <th>핵심 작업</th>
              <th>판단 변수</th>
              <th>책 PART</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>1</strong></td><td>인터뷰 — 골퍼 언어 → 피팅 변수 매핑</td><td>주관 데이터, 우선순위</td><td>PART 1</td></tr>
            <tr><td><strong>2</strong></td><td>신체 (스테틱) — 키·WTF·손·악력</td><td>길이, 그립 사이즈, 무게 등급</td><td>PART 3</td></tr>
            <tr><td><strong>3</strong></td><td>스윙 (다이나믹) — 키네마틱 시퀀스</td><td>전환 속도, 릴리즈, 손목고리</td><td>PART 3·9</td></tr>
            <tr><td><strong>4</strong></td><td>데이터 — 론치모니터·타점</td><td>D-Plane, Spin Loft, 타점 분포</td><td>PART 4·5·10</td></tr>
            <tr><td><strong>5</strong></td><td>클럽 측정 — 현재 클럽 스펙 확인</td><td>라이·로프트·CPM·SW·MOI</td><td>PART 6·7·8</td></tr>
            <tr><td><strong>6</strong></td><td>처방 — 통합 결정과 보정</td><td>총무게→MOI→SW 순서</td><td>PART 11</td></tr>
          </tbody>
        </table>

        <div class="callout callout-cite">
          <p class="cite-text">
            "실제적인 피팅의 판단 순서 (기본 원칙)<br/><br/>
            <strong>인터뷰 → 관찰 → 데이터 → 장비</strong><br/><br/>
            이 순서를 거꾸로 하면, 이후의 모든 판단이 연쇄적으로 흔들립니다."
          </p>
          <p class="cite-source">
            — <cite>『실제적인 클럽피팅』</cite> <a href="/book/part-1" class="cite-link">PART 1 1절 →</a>
          </p>
        </div>
      </div>

      <div class="deeper-box">
        <p class="deeper-label">처방 시스템의 디테일은 책에서</p>
        <div class="deeper-links">
          <a href="/book/part-2" class="deeper-link">PART 2 · 판단 구조 시스템 — 결과 중심에서 원인 중심으로 →</a>
          <a href="/book/part-3" class="deeper-link">PART 3 · 골퍼 구조 해석 시스템 — 인터뷰 결과를 피팅 변수로 →</a>
          <a href="/book/part-11" class="deeper-link">PART 11 · 통합 결정과 문제 해결 시스템 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-3. TPI Big12 -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">TPI BIG 12 · 신체 평가</p>
      <h2>TPI 12 평가 항목</h2>
      <p class="section-lead">
        Titleist Performance Institute가 정리한 <strong>12가지 신체 평가</strong>입니다.
        이 평가는 골퍼가 "할 수 있는 스윙"과 "하면 안 되는 스윙"을 구분하는 출발점입니다.
        몸이 안 되는 동작을 강요하는 클럽은 부상을 만듭니다.
      </p>
      <p class="section-lead">
        공작소장은 <strong>TPI Certified</strong> (Level 1 · Junior Level 2 · Golf Level 2) 인증을 보유하고 있습니다.
        모든 분께 12가지를 다 진행하지는 않습니다. 인터뷰 결과에 따라 필요한 평가만 선별해 진행합니다.
      </p>

      <div class="tpi-grid">
        {tpiBig12.map((item) => (
          <div class="tpi-card">
            <div class="tpi-no">{item.no}</div>
            <div>
              <h3 class="tpi-name">{item.name}</h3>
              <p class="tpi-ko">{item.ko}</p>
              <p class="tpi-hint">{item.hint}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="tpi-link-note">
        TPI 평가는 <a href="https://www.mytpi.com" target="_blank" rel="noopener">mytpi.com</a>에서
        Level 1~3 인증 과정을 운영하고 있으며, 클럽메이커스 공작소장은 Level 1, Junior Level 2, Golf Level 2 인증을 보유하고 있습니다.
      </p>
    </div>
  </section>

  <!-- 4-4. 트랜지션 (다운스윙 4유형) -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">TRANSITION · 다운스윙 전환 4유형</p>
      <h2>선수의 트랜지션은<br>어떤 유형일까요?</h2>
      <p class="section-lead">
        같은 헤드스피드라도 <strong>다운스윙의 전환(Transition)</strong>이 다르면
        맞는 샤프트가 달라집니다. 키네마틱 시퀀스를 보면 선수가 어느 유형인지 보입니다.
      </p>

      <table class="table transition-table">
        <thead>
          <tr>
            <th>유형</th>
            <th>비디오에서 보이는 신호</th>
            <th>맞는 샤프트 방향</th>
          </tr>
        </thead>
        <tbody>
          {transitionTypes.map((t) => (
            <tr>
              <td>
                <strong>{t.type}</strong><br/>
                <span class="table-en">{t.en}</span>
              </td>
              <td>{t.signal}</td>
              <td><span class="shaft-tag">{t.shaft}</span></td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="deeper-box">
        <p class="deeper-label">샤프트 매칭의 디테일은 책에서</p>
        <div class="deeper-links">
          <a href="/book/part-9" class="deeper-link">PART 9 · 샤프트 구조와 피팅 판단 — CPM·EI·토크 →</a>
          <a href="/book/part-3" class="deeper-link">PART 3 · 골퍼 구조 해석 시스템 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-5. 손목고리 (코킹 패턴) -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">WRIST HINGE · 손목고리(코킹) 패턴</p>
      <h2>손목고리 — 레깅을 만드는<br>가장 중요한 변수</h2>
      <p class="section-lead">
        손목 코킹의 시점이 다운스윙의 레깅(Lag)과 임팩트 시점의 헤드 가속도를 결정합니다.
        같은 클럽이라도 코킹 패턴에 따라 다르게 반응합니다.
      </p>

      <table class="table">
        <thead>
          <tr>
            <th>코킹 유형</th>
            <th>특성</th>
            <th>맞는 클럽 방향</th>
          </tr>
        </thead>
        <tbody>
          {wristHinges.map((w) => (
            <tr>
              <td>
                <strong>{w.name}</strong><br/>
                <span class="table-en">{w.en}</span>
              </td>
              <td>{w.effect}</td>
              <td>{w.fit}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="deeper-box">
        <p class="deeper-label">레깅과 샤프트 강도의 디테일은 책에서</p>
        <div class="deeper-links">
          <a href="/book/part-9" class="deeper-link">PART 9 · 샤프트 구조 — Tip Soft / Tip Stiff와 ROC →</a>
          <a href="/book/part-3" class="deeper-link">PART 3 · 골퍼 구조 해석 — 다운스윙 분류 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4-6. 처방 경로 (어디로 들어오시든) -->
  <section class="section paths-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PATHS · 처방 경로</p>
      <h2>어디로 들어오시든<br>같은 곳에 도착합니다</h2>
      <p class="section-lead">
        고객님이 다른 입구로 들어오셔도 — "거리가 안 나요" "방향이 흔들려요" "후반에 무너져요" —
        결국 우리는 같은 시스템 안에서 답을 찾습니다.
      </p>

      <div class="paths-grid">
        <div class="path-card">
          <div class="path-symptom">"거리가 안 나요"</div>
          <div class="path-arrow">→</div>
          <div class="path-check">
            <strong>먼저 확인할 것</strong>
            <ul>
              <li>타점 분포 (스매시 팩터)</li>
              <li>Attack Angle (어택 앵글)</li>
              <li>Spin Loft (스핀 로프트)</li>
              <li>그 다음에야 헤드·샤프트</li>
            </ul>
          </div>
        </div>


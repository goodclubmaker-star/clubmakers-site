---
import BaseLayout from '../layouts/BaseLayout.astro';

// 공임표 — 카테고리별 묶음
const priceGroups = [
  {
    title: '헤드 · 샤프트',
    items: [
      { label: '헤드·샤프트 연결부 수리', price: '18,000' },
      { label: '페룰 헐거움', price: '5,000' },
      { label: '샤프트 교체', price: '18,000' },
      { label: '슬리브 교체', price: '18,000' },
      { label: '헤드·샤프트 분리', price: '10,000' },
      { label: '슬리브 (타이틀·캘러웨이·테일러·핑)', price: '12,000' },
      { label: '클럽 제작', price: '25,000' },
      { label: '정밀 조립 (MOI 매칭 + 길이 + 밸런스 포함)', price: '30,000' },
    ],
  },
  {
    title: '그립',
    items: [
      { label: '그립 장착 (고객님이 그립을 가져오실 시)', price: '5,000' },
      { label: '그립 추출', price: '5,000' },
      { label: '퍼터 그립', price: '7,000' },
    ],
  },
  {
    title: '길이 · 밸런스',
    items: [
      { label: '길이재단 샤프트 교체', price: '25,000' },
      { label: '연장', price: '10,000' },
      { label: '스윙웨이트 조정', price: '5,000' },
      { label: 'MOI 매칭 (분해 없이 납테이프로 증가)', price: '5,000' },
      { label: 'MOI 매칭 (헤드 분리 시)', price: '25,000' },
    ],
  },
  {
    title: '라이 · 로프트',
    items: [
      { label: '라이·로프트 조정', price: '10,000' },
    ],
  },
];
---

<BaseLayout
  title="공작소의 작업 — 공임 안내"
  description="클럽메이커스 공작소의 작업과 공임. 분석 프로그램 60,000원 (낮시간 45,000원), 카테고리별 공임표 18개 항목 공개. 24년의 숙련. 무리한 판매를 권하지 않습니다. 서울 서초구 가보빌딩 지하층."
  schemaType="AboutPage"
  keywords="클럽메이커스, 골프채수리, 샤프트교체, 그립교체, 라이각조정, MOI매칭, 클럽피팅 가격, 양재동 골프공작소"
>

  <!-- 8-1. 히어로 -->
  <section class="page-hero workshop-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">WORKSHOP · 공작소의 작업</div>
      <h1>꼼꼼하게,<br>필요한 만큼만</h1>
      <p class="page-hero-subtitle">
        24년 동안 다듬어 온 클럽 작업입니다. 무리한 판매를 권하지 않고,
        <strong>고객님께 필요한 만큼만 작업</strong>합니다. 모든 공임을 공개합니다.<br/>
        <span class="hero-sub-light">서울 서초구 양재동, 가보빌딩 지하층.</span>
      </p>
    </div>
  </section>

  <!-- 8-1.5. 예약 안내 박스 — contact와 일관 -->
  <section class="section reserve-notice-section">
    <div class="section-content-narrow">
      <div class="reserve-notice">
        <p class="reserve-notice-label">RESERVATION · 예약 안내</p>
        <p class="reserve-notice-body">
          <strong>분석과 교육은 예약제로 진행</strong>합니다.
          그립 교체·라이각 조정 등 <strong>즉시 가능한 작업은 예약 없이 방문</strong>하셔도 됩니다.
          종류에 따라 즉시 가능한 작업과 클럽을 맡기고 찾으셔야 하는 작업이 있어,
          방문 전 <a href="tel:01043635555">전화 한 통</a> 주시면 가장 확실합니다.
        </p>
      </div>
    </div>
  </section>

  <!-- 8-2. 가격보다 중요한 것 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRINCIPLE 01 · 우리가 지키는 기준</p>
      <h2>가격보다 중요한 것</h2>
      <div class="section-body">
        <p>작업의 완성도와 신뢰라고 믿으며, 그 기준을 지켜오고 있습니다.</p>
        <p>
          24년 동안 수많은 고객님의 스윙과 클럽을 다뤄온 경험은,
          불필요한 과정과 시행착오를 줄여줍니다.
        </p>
      </div>
      <ul class="bullet-list">
        <li>샤프트 교체 시 불필요한 분해 작업 최소화</li>
        <li>라이각·길이·밸런스 조정 시 한 번에 정확한 세팅</li>
        <li>클럽 상태에 따른 최적의 작업 방법 선택</li>
      </ul>
      <p class="section-body-end">
        이런 숙련도 덕분에 작업 시간은 줄어들고, 결과는 안정적으로 유지됩니다.
      </p>
    </div>
  </section>

  <!-- 8-3. 무리한 판매를 권하지 않습니다 -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRINCIPLE 02 · 우리가 권하지 않는 것</p>
      <h2>무리한 판매를 권하지 않습니다</h2>
      <div class="section-body">
        <p>
          피팅 가격이 올라가는 가장 큰 이유 중 하나는 불필요한 제품 교체입니다.
          공작소는 실제 스윙과 클럽 상태를 기준으로 판단합니다.
        </p>
      </div>
      <ul class="bullet-list">
        <li><strong>기존 샤프트로 충분하다면</strong>, 교체를 권하지 않습니다.</li>
        <li><strong>그립만 바꿔도 해결되는 문제라면</strong>, 최소 작업만 진행합니다.</li>
        <li><strong>체감 효과가 없는 업그레이드는</strong> 추천하지 않습니다.</li>
      </ul>
      <div class="callout">
        판매를 위한 피팅이 아니라, <strong>고객님에게 필요한 만큼만 작업하는 것</strong>이
        목표입니다.
      </div>
    </div>
  </section>

  <!-- 8-4. 피팅 분석 프로그램 (강조 박스) -->
  <section class="section section-bg-green analysis-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">★ ANALYSIS · 피팅 분석 프로그램</p>
      <h2>좋은 피팅은 클럽을 바꾸는<br>데서 시작하지 않습니다</h2>
      <div class="section-body">
        <p>
          지금 내 스윙이 어떤 상태인지, 클럽이 무엇을 돕고 무엇을 방해하는지 —
          정확히 아는 것부터 시작합니다.
        </p>
      </div>

      <div class="analysis-card">
        <div class="analysis-header">분석 프로그램 구성</div>
        <ul class="analysis-list">
          <li>인터뷰 · 신체 측정 · 스윙 분석 · 클럽 측정</li>
          <li>약 40~60분 · 1:1 맞춤 진행</li>
          <li>한 번의 분석에 상담·측정·해석 모두 포함</li>
        </ul>

        <table class="analysis-price-table">
          <tbody>
            <tr>
              <th>분석 프로그램</th>
              <td class="analysis-price">60,000원</td>
            </tr>
            <tr>
              <th>낮시간 할인</th>
              <td class="analysis-price">45,000원</td>
            </tr>
          </tbody>
        </table>

        <a href="https://naver.me/GfrbfXtX" class="analysis-cta" target="_blank" rel="noopener">
          📅 네이버 예약하기
        </a>
      </div>
    </div>
  </section>

  <!-- 8-5. 공임표 (카테고리별) -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRICE · 공임표</p>
      <h2>정직한 가격, 명확한 기준</h2>
      <p class="price-intro">
        공작소에서 자주 하는 작업을 카테고리별로 정리했습니다.
        <strong>부품(그립·샤프트·헤드 등) 가격은 별도</strong>이며 — 이 페이지 아래쪽에 안내해 두었습니다.
        정확한 견적은 클럽을 직접 보고 안내드립니다.
      </p>

      {priceGroups.map((group) => (
        <div class="price-group">
          <h3 class="price-group-title">{group.title}</h3>
          <table class="price-table">
            <tbody>
              {group.items.map((item) => (
                <tr>
                  <td class="price-label">{item.label}</td>
                  <td class="price-value"><strong>{item.price}</strong>원</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>
  </section>

  <!-- 8-5.5. 부품 단가 안내 -->
  <section class="section section-bg-soft parts-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PARTS · 부품 단가 안내</p>
      <h2>부품 가격은 별도입니다</h2>
      <p class="parts-intro">
        공임은 작업 비용입니다. 샤프트·그립·헤드 등 <strong>부품 가격은 제품에 따라 다양</strong>해서
        공임표에 포함하지 않았습니다. 부품별로 일반적인 가격대를 안내드리며,
        실제 견적은 고객님이 원하시는 모델·브랜드에 따라 달라집니다.
      </p>

      <div class="parts-grid">
        <div class="parts-card">
          <p class="parts-label">SHAFT</p>
          <h3 class="parts-title">샤프트</h3>
          <p class="parts-desc">
            드라이버·우드용은 <strong>5만 원대 ~ 80만 원 이상</strong>까지 다양합니다 (모델에 따라).
            아이언 스틸은 12만 원 ~ 20만 원, 아이언 그라파이트는 30만 원 ~ 60만 원대.
          </p>
          <p class="parts-note">정확한 견적은 원하시는 모델 확인 후 안내드립니다.</p>
        </div>

        <div class="parts-card">
          <p class="parts-label">GRIP</p>
          <h3 class="parts-title">그립</h3>
          <p class="parts-desc">
            일반 라운드 그립 <strong>1만 원 ~ 2만 원대</strong>가 보편적입니다.
            프리미엄 그립(가죽·실리콘 코어 등)은 3만 원 이상.
          </p>
          <p class="parts-note">고객님이 그립을 가져오시면 장착 공임만 받습니다.</p>
        </div>

        <div class="parts-card">
          <p class="parts-label">HEAD</p>
          <h3 class="parts-title">헤드</h3>
          <p class="parts-desc">
            드라이버 헤드 단품은 <strong>20만 원 ~ 100만 원 이상</strong>, 아이언 헤드 세트는
            모델·브랜드에 따라 차이가 큽니다.
          </p>
          <p class="parts-note">신클럽 제작 또는 헤드 교체 작업 시 안내드립니다.</p>
        </div>

        <div class="parts-card">
          <p class="parts-label">ETC</p>
          <h3 class="parts-title">기타 부품</h3>
          <p class="parts-desc">
            슬리브 어댑터, 페룰, 납테이프, 카운터밸런스 웨이트 등은
            <strong>몇 천 원 ~ 2만 원대</strong> 범위입니다.
          </p>
          <p class="parts-note">작업에 필요한 만큼만 청구합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8-6. 작은 자부심 -->
  <section class="section section-bg-cream">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRIDE · 작은 자부심</p>
      <h2>작은 자부심, 그리고 기준</h2>
      <p class="pride-intro">공작소의 가격은</p>
      <ul class="pride-list">
        <li>숙련된 작업</li>
        <li>불필요한 판매 배제</li>
        <li>현장 중심의 판단</li>
      </ul>
      <p class="pride-intro">이 세 가지 기준 위에서 책정됩니다.</p>
      <div class="callout">
        <em>이 가격 정책은 타협이 아니라,<br>
        공작소장이 지켜온 작은 자부심입니다.</em>
      </div>
    </div>
  </section>

  <!-- 8-6.5. 책 / 시스템으로 가는 다리 -->
  <section class="section bridge-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">DEEPER · 작업의 원리는</p>
      <h2>왜 이 작업이 필요한가</h2>
      <p class="bridge-lead">
        공임표는 작업의 가격입니다. <strong>이 작업이 골퍼의 어떤 변수에 영향을 주는지</strong>,
        피팅 진행 단계에서 어디에 위치하는지는 별도로 정리되어 있습니다.
      </p>

      <div class="bridge-grid">
        <a href="/book" class="bridge-card">
          <p class="bridge-label">CONCEPT</p>
          <h3 class="bridge-title">『실제적인 클럽피팅』</h3>
          <p class="bridge-desc">
            라이각·로프트·MOI·SW·EI — 각 작업이 다루는 변수가 클럽피팅 판단에서
            어떻게 쓰이는지 본문 14 PART에 정리되어 있습니다.
          </p>
          <span class="bridge-arrow">→</span>
        </a>

        <a href="/system" class="bridge-card">
          <p class="bridge-label">SYSTEM</p>
          <h3 class="bridge-title">공작소의 시스템</h3>
          <p class="bridge-desc">
            인터뷰부터 처방까지 6단계 시스템. 어떤 작업이 어느 단계에서 결정되는지
            살펴보실 수 있습니다.
          </p>
          <span class="bridge-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 8-7. 위치와 예약 -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">LOCATION · 위치와 예약</p>
      <h2>찾아오시거나, 연락주세요</h2>
      <table class="table location-table">
        <tbody>
          <tr><th>공작소</th><td>서울 서초구 동산로2길 50, 가보빌딩 지하층</td></tr>
          <tr><th>전화</th><td><a href="tel:01043635555">010-4363-5555</a></td></tr>
          <tr><th>이메일</th><td><a href="mailto:clubmakers@naver.com">clubmakers@naver.com</a></td></tr>
        </tbody>
      </table>
      <p class="location-note">
        분석과 교육은 예약제로 진행됩니다. 작업은 종류에 따라 즉시 가능 또는 맡김 작업으로 나뉘니,
        방문 전 전화 한 통 주시면 가장 확실합니다.
      </p>
      <div class="cta-row">
        <a href="https://naver.me/GfrbfXtX" class="btn-primary" target="_blank" rel="noopener">분석 예약하기</a>
        <a href="/why-fitting" class="btn-ghost">공작소의 철학 →</a>
        <a href="/system" class="btn-ghost">공작소의 시스템 →</a>
        <a href="/contact" class="btn-ghost">기타 문의</a>
      </div>
    </div>
  </section>

  <!-- 8-8. 마침표 -->
  <section class="closing-section">
    <div class="closing-content">
      <h3>꼼꼼하고 성실하게<br>최선을 다해서 작업해드립니다.</h3>
      <p class="closing-meta">— WORKSHOP · SINCE 1985</p>
    </div>
  </section>

</BaseLayout>

<style>
  .workshop-hero {
    background: var(--bg-soft);
  }

  .bullet-list {
    list-style: none;
    margin: 24px 0;
    padding: 0;
  }
  .bullet-list li {
    padding: 12px 0 12px 24px;
    position: relative;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    border-bottom: 1px solid var(--line);
  }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before {
    content: '·';
    position: absolute;
    left: 4px;
    top: 8px;
    color: var(--gold);
    font-size: 24px;
    font-weight: 700;
  }
  .bullet-list strong {
    color: var(--ink);
    font-weight: 700;
  }

  .section-body-end {
    margin-top: 24px;
    font-size: 16px;
    line-height: 1.85;
    color: var(--ink-2);
  }

  .callout em {
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink);
  }

  /* ===== Hero subtitle ===== */
  .hero-sub-light {
    font-size: 14px;
    color: var(--grey);
    font-weight: 400;
  }

  /* ===== 8-1.5 예약 안내 박스 ===== */
  .reserve-notice-section {
    padding-top: 0 !important;
  }
  .reserve-notice {
    background: var(--bg-soft, #F1ECE0);
    border-left: 3px solid var(--gold, #C19A4F);
    padding: 22px 26px;
    border-radius: 4px;
  }
  .reserve-notice-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--gold, #C19A4F);
    text-transform: uppercase;
    margin: 0 0 10px;
  }
  .reserve-notice-body {
    font-size: 15.5px;
    line-height: 1.85;
    color: var(--ink-2, var(--ink, #1F1B16));
    margin: 0;
  }
  .reserve-notice-body strong { color: var(--ink); font-weight: 600; }
  .reserve-notice-body a {
    color: var(--green, #2C5F4F);
    border-bottom: 1px solid var(--green, #2C5F4F);
    font-weight: 600;
  }
  .reserve-notice-body a:hover { color: var(--green-2); }

  /* ===== 8-4 ANALYSIS ===== */
  .analysis-section {
    position: relative;
  }
  .analysis-section h2 {
    margin-bottom: 24px;
  }
  .analysis-card {
    background: var(--green-deep);

<script is:inline>
  (function () {
    function won(n) { return n.toLocaleString('ko-KR'); }

    function recalc() {
      var total = 0;
      // 체크박스 항목
      document.querySelectorAll('.estimate-tool input[type="checkbox"]').forEach(function (cb) {
        if (cb.checked) total += parseInt(cb.getAttribute('data-price'), 10) || 0;
      });
      // 개수 항목
      document.querySelectorAll('.est-count').forEach(function (el) {
        var qty = parseInt(el.textContent, 10) || 0;
        var price = parseInt(el.getAttribute('data-price'), 10) || 0;
        total += qty * price;
      });
      var out = document.getElementById('est-total');
      if (out) out.textContent = won(total);
    }

    function initEstimate() {
      var tool = document.querySelector('.estimate-tool');
      if (!tool) return;

      // 체크박스
      tool.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
        cb.addEventListener('change', recalc);
      });

      // 스테퍼 (+/-)
      tool.querySelectorAll('.est-plus').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var key = btn.getAttribute('data-qty');
          var el = document.getElementById('qty-' + key);
          if (!el) return;
          el.textContent = (parseInt(el.textContent, 10) || 0) + 1;
          recalc();
        });
      });
      tool.querySelectorAll('.est-minus').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var key = btn.getAttribute('data-qty');
          var el = document.getElementById('qty-' + key);
          if (!el) return;
          var cur = parseInt(el.textContent, 10) || 0;
          if (cur > 0) el.textContent = cur - 1;
          recalc();
        });
      });

      recalc();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initEstimate);
    } else {
      initEstimate();
    }
  })();
</script>


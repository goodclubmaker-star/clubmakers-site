---
import BaseLayout from '../layouts/BaseLayout.astro';

// 공임표 16개 (페이지 8-5)
const priceList = [
  { label: '헤드·샤프트 연결부 수리', price: '18,000' },
  { label: '페룰 헐거움', price: '5,000' },
  { label: '샤프트 교체', price: '18,000' },
  { label: '슬리브 교체', price: '18,000' },
  { label: '헤드·샤프트 분리', price: '10,000' },
  { label: '그립 장착', price: '5,000' },
  { label: '그립 추출', price: '5,000' },
  { label: '퍼터 그립', price: '7,000' },
  { label: '길이재단 샤프트 교체', price: '25,000' },
  { label: '연장', price: '10,000' },
  { label: '조립', price: '10,000' },
  { label: '클럽 제작', price: '25,000' },
  { label: 'MOI 매칭', price: '25,000' },
  { label: '스윙웨이트 조정', price: '5,000' },
  { label: '라이·로프트 조정', price: '10,000' },
  { label: '슬리브 (타이틀·캘러웨이·테일러·핑)', price: '12,000' },
];
---

<BaseLayout
  title="공작소의 작업"
  description="클럽메이커스 공작소의 작업 — 분석 프로그램 60,000원 (낮시간 45,000원), 정직한 공임표 16개 항목. 24년의 숙련. 무리한 판매를 권하지 않습니다. 서울 서초구 가보빌딩 지하층."
  schemaType="AboutPage"
>

  <!-- 8-1. 히어로 -->
  <section class="page-hero workshop-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">WORKSHOP · 공작소의 작업</div>
      <h1>공작소의 작업</h1>
      <p class="page-hero-subtitle">
        서울 서초동, 가보빌딩 지하층.<br />
        모든 작업은 예약제로 진행됩니다.
      </p>
    </div>
  </section>

  <!-- 8-2. 가격보다 중요한 것 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRINCIPLE 01 · 우리가 지키는 기준</p>
      <h2>가격보다 중요한 것</h2>
      <div class="section-body">
        <p>작업의 완성도와 신뢰라고 믿으며, 그 기준을 지켜오고 있습니다.</p>
        <p>
          24년 동안 수많은 고객님의 스윙과 클럽을 다뤄온 경험은,
          불필요한 과정과 시행착오를 줄여줍니다.
        </p>
      </div>
      <ul class="bullet-list">
        <li>샤프트 교체 시 불필요한 분해 작업 최소화</li>
        <li>라이각·길이·밸런스 조정 시 한 번에 정확한 세팅</li>
        <li>클럽 상태에 따른 최적의 작업 방법 선택</li>
      </ul>
      <p class="section-body-end">
        이런 숙련도 덕분에 작업 시간은 줄어들고, 결과는 안정적으로 유지됩니다.
      </p>
    </div>
  </section>

  <!-- 8-3. 무리한 판매를 권하지 않습니다 -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRINCIPLE 02 · 우리가 권하지 않는 것</p>
      <h2>무리한 판매를 권하지 않습니다</h2>
      <div class="section-body">
        <p>
          피팅 가격이 올라가는 가장 큰 이유 중 하나는 불필요한 제품 교체입니다.
          공작소는 실제 스윙과 클럽 상태를 기준으로 판단합니다.
        </p>
      </div>
      <ul class="bullet-list">
        <li><strong>기존 샤프트로 충분하다면</strong>, 교체를 권하지 않습니다.</li>
        <li><strong>그립만 바꿔도 해결되는 문제라면</strong>, 최소 작업만 진행합니다.</li>
        <li><strong>체감 효과가 없는 업그레이드는</strong> 추천하지 않습니다.</li>
      </ul>
      <div class="callout">
        판매를 위한 피팅이 아니라, <strong>고객님에게 필요한 만큼만 작업하는 것</strong>이
        목표입니다.
      </div>
    </div>
  </section>

  <!-- 8-4. 피팅 분석 프로그램 (강조 박스) -->
  <section class="section section-bg-green analysis-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">★ ANALYSIS · 피팅 분석 프로그램</p>
      <h2>좋은 피팅은 클럽을 바꾸는<br>데서 시작하지 않습니다</h2>
      <div class="section-body">
        <p>
          지금 내 스윙이 어떤 상태인지, 클럽이 무엇을 돕고 무엇을 방해하는지 —
          정확히 아는 것부터 시작합니다.
        </p>
      </div>

      <div class="analysis-card">
        <div class="analysis-header">분석 프로그램 구성</div>
        <ul class="analysis-list">
          <li>인터뷰 · 신체 측정 · 스윙 분석 · 클럽 측정</li>
          <li>약 40~60분 · 1:1 맞춤 진행</li>
          <li>한 번의 분석에 상담·측정·해석 모두 포함</li>
        </ul>

        <table class="analysis-price-table">
          <tbody>
            <tr>
              <th>분석 프로그램</th>
              <td class="analysis-price">60,000원</td>
            </tr>
            <tr>
              <th>낮시간 할인</th>
              <td class="analysis-price">45,000원</td>
            </tr>
          </tbody>
        </table>

        <a href="https://naver.me/GfrbfXtX" class="analysis-cta" target="_blank" rel="noopener">
          📅 네이버 예약하기
        </a>
      </div>
    </div>
  </section>

  <!-- 8-5. 공임표 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRICE · 공임표</p>
      <h2>정직한 가격, 명확한 기준</h2>
      <p class="price-intro">
        공작소에서 가장 자주 하는 작업 16가지의 공임을 모두 공개합니다.
        부품(그립·샤프트·슬리브) 가격은 별도이며, 정확한 견적은 클럽을 직접 보고 안내드립니다.
      </p>

      <table class="price-table">
        <tbody>
          {priceList.map((item) => (
            <tr>
              <td class="price-label">{item.label}</td>
              <td class="price-value"><strong>{item.price}</strong>원</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- 8-6. 작은 자부심 -->
  <section class="section section-bg-cream">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PRIDE · 작은 자부심</p>
      <h2>작은 자부심, 그리고 기준</h2>
      <p class="pride-intro">공작소의 가격은</p>
      <ul class="pride-list">
        <li>숙련된 작업</li>
        <li>불필요한 판매 배제</li>
        <li>현장 중심의 판단</li>
      </ul>
      <p class="pride-intro">이 세 가지 기준 위에서 책정됩니다.</p>
      <div class="callout">
        <em>이 가격 정책은 타협이 아니라,<br>
        공작소장이 지켜온 작은 자부심입니다.</em>
      </div>
    </div>
  </section>

  <!-- 8-7. 위치와 예약 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">LOCATION · 위치와 예약</p>
      <h2>찾아오시거나, 연락주세요</h2>
      <table class="table location-table">
        <tbody>
          <tr><th>공작소</th><td>서울 서초구 동산로2길 50, 가보빌딩 지하층</td></tr>
          <tr><th>전화</th><td><a href="tel:01043635555">010-4363-5555</a></td></tr>
          <tr><th>이메일</th><td><a href="mailto:clubmakers@naver.com">clubmakers@naver.com</a></td></tr>
        </tbody>
      </table>
      <p class="location-note">
        모든 작업은 예약제로 진행됩니다.
        분석 프로그램은 네이버 예약을 통해 진행됩니다.
      </p>
      <div class="cta-row">
        <a href="https://naver.me/GfrbfXtX" class="btn-primary" target="_blank" rel="noopener">분석 예약하기</a>
        <a href="/contact" class="btn-ghost">기타 문의</a>
      </div>
    </div>
  </section>

  <!-- 8-8. 마침표 -->
  <section class="closing-section">
    <div class="closing-content">
      <h3>꼼꼼하고 성실하게<br>최선을 다해서 작업해드립니다.</h3>
      <p class="closing-meta">— WORKSHOP · SINCE 1985</p>
    </div>
  </section>

</BaseLayout>

<style>
  .workshop-hero {
    background: var(--bg-soft);
  }

  .bullet-list {
    list-style: none;
    margin: 24px 0;
    padding: 0;
  }
  .bullet-list li {
    padding: 12px 0 12px 24px;
    position: relative;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    border-bottom: 1px solid var(--line);
  }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before {
    content: '·';
    position: absolute;
    left: 4px;
    top: 8px;
    color: var(--gold);
    font-size: 24px;
    font-weight: 700;
  }
  .bullet-list strong {
    color: var(--ink);
    font-weight: 700;
  }

  .section-body-end {
    margin-top: 24px;
    font-size: 16px;
    line-height: 1.85;
    color: var(--ink-2);
  }

  .callout em {
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink);
  }

  /* ===== 8-4 ANALYSIS ===== */
  .analysis-section {
    position: relative;
  }
  .analysis-section h2 {
    margin-bottom: 24px;
  }
  .analysis-card {
    background: var(--green-deep);
    border: 1px solid rgba(212, 184, 136, 0.3);
    border-radius: 8px;
    padding: 36px 40px;
    margin-top: 36px;
  }
  .analysis-header {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--gold-soft);
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(212, 184, 136, 0.2);
  }
  .analysis-list {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
  }
  .analysis-list li {
    color: var(--grey-3);
    padding: 6px 0 6px 18px;
    position: relative;
    font-size: 15px;
    line-height: 1.7;
  }
  .analysis-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--gold-soft);
    font-size: 22px;
    line-height: 1;
    top: 8px;
  }

  .analysis-price-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 28px;
  }
  .analysis-price-table th,
  .analysis-price-table td {
    text-align: left;
    padding: 16px 0;
    border-bottom: 1px solid rgba(212, 184, 136, 0.15);
    color: var(--cream);
  }
  .analysis-price-table th {
    font-weight: 600;
    width: 50%;
  }
  .analysis-price-table tr:last-child th,
  .analysis-price-table tr:last-child td {
    border-bottom: none;
  }
  .analysis-price {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 700;
    color: var(--gold-soft);
    text-align: right;
  }

  .analysis-cta {
    display: inline-block;
    background: var(--gold);
    color: var(--green-deep);
    padding: 16px 32px;
    border-radius: 4px;
    font-weight: 700;
    font-size: 15px;
    transition: background 0.2s;
  }
  .analysis-cta:hover {
    background: var(--gold-soft);
  }

  /* ===== 8-5 공임표 ===== */
  .price-intro {
    font-size: 15px;
    line-height: 1.85;
    color: var(--grey);
    margin-bottom: 32px;
  }
  .price-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
  }
  .price-table tr {
    border-bottom: 1px solid var(--line);
  }
  .price-table tr:nth-child(even) {
    background: var(--bg-soft);
  }
  .price-table tr:last-child { border-bottom: none; }
  .price-table td {
    padding: 16px 24px;
    font-size: 14.5px;
  }
  .price-label {
    color: var(--ink-2);
  }
  .price-value {
    text-align: right;
    color: var(--ink);
    width: 130px;
    white-space: nowrap;
  }
  .price-value strong {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 17px;
  }

  /* ===== 8-6 자부심 ===== */
  .pride-intro {
    font-size: 16px;
    color: var(--ink-2);
    margin: 16px 0;
  }
  .pride-list {
    list-style: none;
    margin: 16px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pride-list li {
    background: white;
    padding: 14px 22px;
    border-left: 3px solid var(--gold);
    font-weight: 600;
    color: var(--ink);
    font-size: 15px;
  }

  /* ===== 8-7 위치 ===== */
  .location-table th { width: 90px; }
  .location-note {
    font-size: 14.5px;
    line-height: 1.8;
    color: var(--grey);
    margin: 24px 0 32px;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ===== 8-8 마침표 ===== */
  .closing-section {
    background: var(--green);
    padding: 100px 80px;
    text-align: center;
  }
  .closing-content {
    max-width: 720px;
    margin: 0 auto;
  }
  .closing-section h3 {
    font-family: var(--font-serif);
    font-size: 32px;
    line-height: 1.5;
    font-weight: 700;
    color: var(--cream);
    letter-spacing: -0.015em;
    margin-bottom: 24px;
  }
  .closing-meta {
    font-size: 12px;
    color: var(--gold-soft);
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  @media (max-width: 968px) {
    .analysis-card {
      padding: 28px 24px;
    }
    .analysis-price {
      font-size: 20px;
    }
    .price-table td {
      padding: 12px 16px;
      font-size: 13.5px;
    }
    .price-value {
      width: 100px;
    }
    .closing-section {
      padding: 70px 24px;
    }
    .closing-section h3 {
      font-size: 24px;
    }
    .cta-row {
      flex-direction: column;
    }
    .cta-row a {
      text-align: center;
    }
  }
</style>

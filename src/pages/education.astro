---
import BaseLayout from '../layouts/BaseLayout.astro';

// 2일 커리큘럼 (예시 — 정확한 내용은 책 PART 1·11·부록 기준)
const day1 = [
  { time: '10:00 ~ 12:00', topic: '인터뷰 시스템',     detail: 'Level 1·2·3 인터뷰 구조. 골퍼의 말 → 피팅 변수로 변환하는 매핑. 책 PART 1.' },
  { time: '13:00 ~ 15:00', topic: '신체·스윙 측정',    detail: '키·WTF·손 크기·악력 측정. 키네마틱 시퀀스 파악. 4가지 다운스윙 스타일 진단. PART 3·9.' },
  { time: '15:30 ~ 17:30', topic: '클럽 측정·실습',    detail: '라이·로프트 조정. CPM 측정. SW·MOI 계산. 직접 손으로 작업.' },
  { time: '17:30 ~ 18:30', topic: 'Day 1 정리',       detail: '오늘 다룬 변수 복기. 다음 날 케이스 스터디 안내.' },
];

const day2 = [
  { time: '10:00 ~ 12:00', topic: '론치모니터 해석',   detail: 'D-Plane, Spin Loft, 타점 분석. 4단계 해석 시스템. PART 4·5·10.' },
  { time: '13:00 ~ 15:00', topic: '통합 결정 시스템',  detail: '총무게→MOI→SW 결정 순서. 6단계 처방 흐름. 변수 충돌 우선순위. PART 11.' },
  { time: '15:30 ~ 17:30', topic: '실전 케이스 스터디', detail: '실제 케이스 5건 분석. 인터뷰부터 처방까지 직접 작성. 피드백 세션.' },
  { time: '17:30 ~ 18:00', topic: '수료 · 후속 안내',  detail: '수료증 수여. 책 1권 증정. 후속 학습 자료 안내.' },
];

// CourseInstance schema
const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: '클럽메이커스 클럽메이킹 교육',
  description: '2일간 진행되는 클럽피팅·클럽메이킹 실전 교육. 인터뷰 시스템부터 통합 결정 시스템까지. 책 『실제적인 클럽피팅』 저자가 직접 진행. 정원 2인 1:1 맞춤.',
  provider: {
    '@type': 'Organization',
    name: '클럽메이커스',
    url: 'https://myclubmakers.com',
  },
  instructor: {
    '@type': 'Person',
    name: '채기웅',
    jobTitle: '클럽메이커스 공작소장 (TPI Certified, KIPO 특허 3종)',
  },
  educationalLevel: 'Professional',
  inLanguage: 'ko-KR',
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'onsite',
    courseWorkload: 'PT16H',
    location: {
      '@type': 'Place',
      name: '클럽메이커스 공작소',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '동산로2길 50, 가보빌딩 지하층',
        addressLocality: '서초구',
        addressRegion: '서울',
        addressCountry: 'KR',
      },
    },
    offers: {
      '@type': 'Offer',
      price: '880000',
      priceCurrency: 'KRW',
      availability: 'https://schema.org/InStock',
    },
    maximumAttendeeCapacity: 2,
  },
};
---

<BaseLayout
  title="클럽메이킹 교육"
  description="클럽메이커스 클럽피팅·클럽메이킹 클럽메이킹 교육. 2일간, 정원 2인, 88만원. 책 『실제적인 클럽피팅』 저자 채기웅 공작소장이 직접 진행. 한스클럽하우스 공동 진행."
  schemaType="Course"
  keywords="클럽피팅 교육, 클럽메이킹 교육, 클럽피터 양성, 한국 클럽피팅 전문가, TPI Certified, 한스클럽하우스, club fitting course Korea, club building, 클럽피팅 자격증"
  extraSchema={courseSchema}
>

  <!-- 9-1. 히어로 -->
  <article>
  <section class="page-hero edu-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">EDUCATION · 클럽메이킹 교육</div>
      <h1>클럽피팅·클럽메이킹<br>클럽메이킹 교육</h1>
      <p class="page-hero-subtitle">
        24년 현장 경력의 공작소장이 직접 진행하는 <strong>2일 실전 교육</strong>입니다.<br/>
        매장을 운영하시는 피터, 클럽메이커를 꿈꾸시는 분, 깊이 공부하고 싶으신 골퍼를 위한 과정입니다.
      </p>
    </div>
  </section>

  <!-- 9-2. 핵심 정보 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PROGRAM · 과정 개요</p>
      <h2>2일, 정원 2인,<br>88만원</h2>

      <table class="table info-table">
        <tbody>
          <tr><th>일정</th><td>총 2일 · 1일 약 8시간</td></tr>
          <tr><th>정원</th><td>최대 <strong>2인</strong> (소수 정예 1:1 맞춤)</td></tr>
          <tr><th>비용</th><td><strong>88만원</strong> (책 1권 + 수료증 포함)</td></tr>
          <tr><th>장소</th><td>클럽메이커스 공작소 (서울 서초구 가보빌딩 지하층)</td></tr>
          <tr><th>대상</th><td>매장 운영 피터 · 클럽메이커 입문자 · 본격 클럽피팅을 공부하는 골퍼</td></tr>
          <tr><th>교재</th><td>책 『실제적인 클럽피팅』 (Clubmakers Korea, 2026)</td></tr>
          <tr><th>강사</th><td>채기웅 공작소장 (TPI Certified, KIPO 특허 3종)</td></tr>
          <tr><th>공동 진행</th><td>한스클럽하우스 한평구 대표</td></tr>
        </tbody>
      </table>

      <div class="callout">
        <p>
          <strong>왜 정원이 2인인가요?</strong> 클럽피팅·클럽메이킹은 강의로만 익혀지지 않습니다.
          공작소장이 직접 옆에서 손을 잡아드리는 작업이 필요합니다.
          그래서 한 번에 두 분만 받습니다 — 더 많은 분께 양보다 깊이를 드립니다.
        </p>
      </div>
    </div>
  </section>

  <!-- 9-3. 무엇을 배우게 되나요? -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">CURRICULUM · 무엇을 배우나요</p>
      <h2>이 과정에서 배우는 것</h2>

      <div class="learn-grid">
        <div class="learn-card">
          <div class="learn-num">01</div>
          <h3>인터뷰 시스템</h3>
          <p>
            골퍼의 말을 피팅 변수로 변환하는 시스템. Level 1·2·3 단계 인터뷰. 34문항 · 7영역 기준표.
            <em>"같은 슬라이스도 원인이 다르면 처방이 다릅니다."</em>
          </p>
        </div>
        <div class="learn-card">
          <div class="learn-num">02</div>
          <h3>신체·스윙 분석</h3>
          <p>
            키·WTF·손 크기·악력 측정. 키네마틱 시퀀스. 4가지 다운스윙 스타일 진단.
            손목고리 패턴. TPI Big12 평가 일부.
          </p>
        </div>
        <div class="learn-card">
          <div class="learn-num">03</div>
          <h3>클럽 측정·작업 실습</h3>
          <p>
            라이·로프트 벤딩. CPM 측정. SW·MOI 계산. 그립 교체. 길이 조정.
            <strong>직접 손으로 작업합니다.</strong>
          </p>
        </div>
        <div class="learn-card">
          <div class="learn-num">04</div>
          <h3>론치모니터 해석</h3>
          <p>
            D-Plane, Spin Loft, 타점 분석. 4단계 해석 시스템.
            결과 중심이 아닌 <strong>원인 중심</strong>의 해석.
          </p>
        </div>
        <div class="learn-card">
          <div class="learn-num">05</div>
          <h3>통합 결정 시스템</h3>
          <p>
            총무게 → MOI → SW 결정 순서. 6단계 처방 흐름.
            변수 충돌 우선순위. 책 PART 11의 모든 것.
          </p>
        </div>
        <div class="learn-card">
          <div class="learn-num">06</div>
          <h3>실전 케이스 스터디</h3>
          <p>
            실제 5건의 케이스를 인터뷰부터 처방까지 직접 작성합니다.
            공작소장의 피드백을 받습니다.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 9-4. 2일 커리큘럼 -->
  <section class="section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">SCHEDULE · 2일 커리큘럼</p>
      <h2>2일간의 흐름</h2>

      <div class="day-block">
        <h3 class="day-title"><span>DAY 1</span> 인터뷰 · 신체 · 스윙 · 클럽 측정</h3>
        <table class="table day-table">
          <tbody>
            {day1.map((s) => (
              <tr>
                <td class="day-time">{s.time}</td>
                <td class="day-topic"><strong>{s.topic}</strong></td>
                <td class="day-detail">{s.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="day-block">
        <h3 class="day-title"><span>DAY 2</span> 데이터 해석 · 통합 결정 · 케이스 스터디</h3>
        <table class="table day-table">
          <tbody>
            {day2.map((s) => (
              <tr>
                <td class="day-time">{s.time}</td>
                <td class="day-topic"><strong>{s.topic}</strong></td>
                <td class="day-detail">{s.detail}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 9-5. 한스클럽하우스 (공동 진행) -->
  <section class="section section-bg-cream partner-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">PARTNER · 공동 진행</p>
      <h2>한스클럽하우스와 함께</h2>
      <p class="partner-body">
        클럽메이커스 클럽메이킹 교육은 <strong>한스클럽하우스 한평구 대표</strong>와 공동 진행합니다.
        두 명의 시선이 한 케이스를 함께 보면서 더 풍부한 학습이 가능합니다.
      </p>
      <div class="partner-card">
        <h3>한평구 — 한스클럽하우스 대표</h3>
        <ul>
          <li>한국 클럽피팅·클럽메이킹 분야 전문가</li>
          
          <li>장비·샤프트·조립 기술의 다양한 노하우 보유</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 9-6. 채기웅 PROFILE -->
  <section class="section profile-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow">INSTRUCTOR · 강사 프로필</p>
      <h2>채기웅 — 클럽메이커스 공작소장</h2>

      <dl class="profile-list">
        <div class="profile-item">
          <dt>경력</dt>
          <dd>클럽피팅·클럽메이킹 24년. 1985년 부친의 경인골프부터 41년 헤리티지.</dd>
        </div>
        <div class="profile-item">
          <dt>인증</dt>
          <dd>
            <strong>TPI (Titleist Performance Institute) Certified</strong> — Level 1 (2011),
            Junior Level 2 (2012), Golf Level 2 (2013).
          </dd>
        </div>
        <div class="profile-item">
          <dt>특허</dt>
          <dd>
            <strong>대한민국 특허청(KIPO) 등록 특허 3종</strong> — 클럽피팅·클럽메이킹 자체 R&D.
            VERSUS · KRZ · DEFINE 자체 제품 라인의 기반.
          </dd>
        </div>
        <div class="profile-item">
          <dt>저서</dt>
          <dd>
            <strong>『실제적인 클럽피팅』 (2026)</strong> — 본문 15 PART · 부록 4 · 현장작업표준서 12종.
            한국 클럽피팅 분야 최초의 체계적 단행본.
          </dd>
        </div>
        <div class="profile-item">
          <dt>현장</dt>
          <dd>
            KLPGA · LPGA 다수 선수의 클럽피팅·분석 진행 (박희영·김효주·백규정·김민선·고진영 등).
            카페 「골프채공작소」 회원 1만 명. 24년 누적 케이스 다수.
          </dd>
        </div>
        <div class="profile-item">
          <dt>철학</dt>
          <dd>
            "친근한 골프채공작소를 지향합니다." 무리한 판매를 하지 않고, 가격보다 작업의 완성도를 지킵니다.
          </dd>
        </div>
      </dl>

      <div class="profile-cta">
        <a href="/about" class="btn-ghost">공작소장 자세히 →</a>
        <a href="/book" class="btn-ghost">책 자세히 →</a>
      </div>
    </div>
  </section>

  <!-- 9-7. 신청·문의 -->
  <section class="section section-bg-green apply-section">
    <div class="section-content-narrow">
      <p class="section-eyebrow apply-eyebrow">APPLY · 신청·문의</p>
      <h2>참여를 원하신다면</h2>
      <p class="apply-body">
        정원이 2인이라 일정 협의가 필요합니다. 가능하신 날짜, 현재 경력, 학습 목표를 함께
        알려주시면 일정을 잡아드립니다.
      </p>

      <div class="apply-channels">
        <a href="tel:01043635555" class="apply-channel">📞 010-4363-5555</a>
        <a href="mailto:clubmakers@naver.com?subject=전문가%20과정%20문의" class="apply-channel">
          ✉️ clubmakers@naver.com
        </a>
        <a href="/contact" class="apply-channel apply-channel-primary">
          예약·문의 페이지 →
        </a>
      </div>
    </div>
  </section>
  </article>

  <!-- AEO: FAQ -->
  <section class="section section-bg-soft">
    <div class="section-content-narrow">
      <p class="section-eyebrow">FREQUENTLY ASKED</p>
      <h2>자주 묻는 질문</h2>
      <details class="faq-detail">
        <summary>비용 88만원에 무엇이 포함되나요?</summary>
        <p>2일 교육비, 책 『실제적인 클럽피팅』 1권, 수료증, 실습 재료비가 포함됩니다. 점심 식사는 별도입니다.</p>
      </details>
      <details class="faq-detail">
        <summary>클럽피팅 경험이 전혀 없어도 가능한가요?</summary>
        <p>네, 가능합니다. 매장 운영 피터, 클럽메이커 입문자, 본격 공부하고 싶으신 골퍼 모두 신청하실 수 있습니다. 다만 책 『실제적인 클럽피팅』의 주요 PART(특히 PART 1·2·3)를 먼저 한 번 읽고 오시면 학습 효율이 훨씬 좋습니다.</p>
      </details>
      <details class="faq-detail">
        <summary>일정은 언제 진행되나요?</summary>
        <p>정원이 2인이고 1:1 맞춤이라 정해진 일정이 없습니다. 신청자와 일정을 협의해서 진행합니다. 전화나 이메일로 가능 일정을 알려주세요.</p>
      </details>
      <details class="faq-detail">
        <summary>수료 후 자격증이 나오나요?</summary>
        <p>클럽메이커스 수료증이 발급됩니다. 공식 국가 자격증은 아니지만 24년 현장의 노하우와 책 『실제적인 클럽피팅』의 체계가 정리된 과정 이수의 증명입니다.</p>
      </details>
      <details class="faq-detail">
        <summary>한스클럽하우스는 어떤 곳인가요?</summary>
        <p>한국 클럽피팅·클럽메이킹 분야의 전문 업체입니다. 한평구 대표는 클럽메이커스와 함께 클럽메이킹 교육을 공동 진행합니다.</p>
      </details>
    </div>
  </section>

</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '비용 88만원에 무엇이 포함되나요?', acceptedAnswer: { '@type': 'Answer', text: '2일 교육비, 책 『실제적인 클럽피팅』 1권, 수료증, 실습 재료비가 포함됩니다. 점심 식사는 별도입니다.' } },
    { '@type': 'Question', name: '클럽피팅 경험이 전혀 없어도 가능한가요?', acceptedAnswer: { '@type': 'Answer', text: '네, 가능합니다. 매장 운영 피터, 클럽메이커 입문자, 본격 공부하고 싶으신 골퍼 모두 신청하실 수 있습니다. 다만 책의 주요 PART를 먼저 한 번 읽고 오시면 학습 효율이 훨씬 좋습니다.' } },

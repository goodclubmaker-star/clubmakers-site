---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal', ({ data }) => {
    return data.draft !== true;
  });
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'journal'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// 카테고리 라벨
const categoryLabels: Record<string, { ko: string; emoji: string }> = {
  log:    { ko: '작업 일지',     emoji: '🔧' },
  review: { ko: '샤프트·헤드 리뷰', emoji: '📐' },
  trends: { ko: '장비 트렌드',    emoji: '📊' },
  data:   { ko: '측정 데이터',    emoji: '📏' },
};

const clubLabels: Record<string, string> = {
  driver: '드라이버',
  fairway: '페어웨이우드',
  hybrid: '하이브리드',
  iron: '아이언',
  wedge: '웨지',
  putter: '퍼터',
  mixed: '복합',
};

const cat = categoryLabels[entry.data.category];

function formatDate(date: Date) {
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// JSON-LD Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `https://myclubmakers.com/journal/${entry.slug}/#article`,
  headline: entry.data.title,
  description: entry.data.description,
  inLanguage: 'ko-KR',
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updatedDate || entry.data.pubDate).toISOString(),
  author: { '@type': 'Person', name: '채기웅', url: 'https://myclubmakers.com/about' },
  publisher: {
    '@type': 'Organization',
    name: '클럽메이커스',
    url: 'https://myclubmakers.com',
  },
};

// 다른 일지 (관련 글) — 같은 카테고리 또는 같은 클럽 종류
const allEntries = await getCollection('journal', ({ data }) => data.draft !== true);
const related = allEntries
  .filter((e) => e.slug !== entry.slug)
  .filter((e) =>
    e.data.category === entry.data.category ||
    (entry.data.clubType && e.data.clubType === entry.data.clubType)
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description || `${cat.ko} — 클럽메이커스 공작소 일지`}
  schemaType="Article"
  keywords={`공작소 일지, ${cat.ko}, ${entry.data.tags?.join(', ') || ''}`}
  extraSchema={[articleSchema]}
>

  <article class="journal-article">

    <!-- 헤더 -->
    <header class="article-header">
      <a href="/journal" class="article-back">← 공작소 일지로</a>

      <div class="article-meta">
        <span class={`article-cat article-cat-${entry.data.category}`}>
          {cat.emoji} {cat.ko}
        </span>
        {entry.data.clubType && (
          <span class="article-club">{clubLabels[entry.data.clubType]}</span>
        )}
        <time datetime={entry.data.pubDate.toISOString()} class="article-date">
          {formatDate(entry.data.pubDate)}
        </time>
      </div>

      <h1 class="article-title">{entry.data.title}</h1>

      {entry.data.description && (
        <p class="article-desc">{entry.data.description}</p>
      )}

      {entry.data.tags && entry.data.tags.length > 0 && (
        <div class="article-tags">
          {entry.data.tags.map((tag) => (
            <span class="article-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- 본문 -->
    <div class="article-body">
      <Content />
    </div>

    <!-- 관련 진단 트리 (선택) -->
    {entry.data.relatedSymptom && (
      <aside class="related-symptom">
        <p class="related-symptom-eyebrow">RELATED · 관련 진단</p>
        <a href={entry.data.relatedSymptom} class="related-symptom-link">
          이 사례와 관련된 증상·처방 보기 →
        </a>
      </aside>
    )}

    <!-- 관련 일지 -->
    {related.length > 0 && (
      <aside class="related-entries">
        <h2>관련 일지</h2>
        <div class="related-list">
          {related.map((e) => {
            const rcat = categoryLabels[e.data.category];
            return (
              <a href={`/journal/${e.slug}`} class="related-card">
                <span class={`related-cat related-cat-${e.data.category}`}>
                  {rcat.emoji} {rcat.ko}
                </span>
                <p class="related-title">{e.data.title}</p>
                <p class="related-date">{formatDate(e.data.pubDate)}</p>
              </a>
            );
          })}
        </div>
      </aside>
    )}

    <!-- CTA -->
    <aside class="article-cta">
      <p class="cta-eyebrow">CONTACT · 문의</p>
      <h3>비슷한 고민이 있으신가요?</h3>
      <p class="cta-body">
        같은 증상이라도 분마다 원인이 다를 수 있습니다.
        직접 측정해보고 싶으시면 편하게 연락주세요.
      </p>
      <div class="cta-actions">
        <a href="/contact" class="cta-btn cta-btn-primary">예약·문의 →</a>
        <a href="/topics" class="cta-btn cta-btn-ghost">증상·처방 보기 →</a>
      </div>
    </aside>

  </article>

</BaseLayout>


<style>
  .journal-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 60px 24px 100px;
  }

  /* 헤더 */
  .article-header {
    margin-bottom: 48px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }
  .article-back {
    display: inline-block;
    font-size: 13px;
    color: var(--grey);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .article-back:hover { color: var(--green); }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }
  .article-cat {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 100px;
  }
  .article-cat-log    { background: rgba(15, 41, 34, 0.08); color: var(--green); }
  .article-cat-review { background: rgba(184, 152, 92, 0.15); color: var(--gold); }
  .article-cat-trends { background: rgba(70, 110, 200, 0.10); color: #2E5BBA; }
  .article-cat-data   { background: rgba(120, 60, 60, 0.10); color: #804040; }

  .article-club {
    font-size: 12px;
    font-weight: 600;
    color: var(--grey);
    padding: 5px 12px;
    border: 1px solid var(--line);
    border-radius: 100px;
  }
  .article-date {
    font-size: 13px;
    color: var(--grey);
    margin-left: auto;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4.5vw, 38px);
    font-weight: 700;
    line-height: 1.35;
    color: var(--ink);
    letter-spacing: -0.015em;
    margin: 0 0 16px;
  }
  .article-desc {
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0 0 16px;
  }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .article-tag {
    font-size: 12px;
    color: var(--grey);
    padding: 4px 10px;
    background: var(--bg-soft);
    border-radius: 100px;
  }

  /* 본문 — markdown 렌더링 */
  .article-body {
    font-size: 16px;
    line-height: 1.85;
    color: var(--ink-2);
  }
  .article-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 700;
    color: var(--ink);
    margin: 48px 0 16px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    line-height: 1.4;
  }
  .article-body :global(h3) {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 700;
    color: var(--ink);
    margin: 32px 0 12px;
    line-height: 1.4;
  }
  .article-body :global(p) {
    margin-bottom: 18px;
  }
  .article-body :global(strong) {
    color: var(--ink);
    font-weight: 700;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 20px;
    padding-left: 1.5em;
  }
  .article-body :global(li) {
    margin-bottom: 8px;
    line-height: 1.8;
  }
  .article-body :global(a) {
    color: var(--green);
    border-bottom: 1px solid var(--green);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .article-body :global(a:hover) { opacity: 0.7; }
  .article-body :global(blockquote) {
    margin: 24px 0;
    padding: 16px 22px;
    background: var(--bg-soft);
    border-left: 3px solid var(--green);
    border-radius: 4px;
    font-style: italic;
    color: var(--ink-2);
  }
  .article-body :global(code) {
    background: var(--bg-soft);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'SF Mono', Consolas, monospace;
  }
  .article-body :global(pre) {
    background: var(--bg-soft);
    padding: 16px 20px;
    border-radius: 6px;
    overflow-x: auto;
    border: 1px solid var(--line);
    margin: 20px 0;
  }
  .article-body :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  .article-body :global(th),
  .article-body :global(td) {
    padding: 10px 14px;
    text-align: left;
    border-bottom: 1px solid var(--line);
  }
  .article-body :global(th) {
    background: var(--bg-soft);
    font-weight: 700;
    color: var(--ink);
  }
  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 20px 0;
  }
  .article-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 36px 0;
  }

  /* 관련 진단 */
  .related-symptom {
    background: var(--cream, #F8F2E5);
    border-left: 3px solid var(--gold, #B8985C);
    padding: 16px 22px;
    border-radius: 6px;
    margin: 36px 0;
  }
  .related-symptom-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--gold);
    margin: 0 0 6px;
  }
  .related-symptom-link {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
  }
  .related-symptom-link:hover { color: var(--green); border-color: var(--green); }

  /* 관련 일지 */
  .related-entries {
    margin: 48px 0 32px;
    padding: 32px;
    background: var(--bg-soft);
    border-radius: 8px;
  }
  .related-entries h2 {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 18px;
  }
  .related-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 640px) {
    .related-list { grid-template-columns: repeat(3, 1fr); }
  }
  .related-card {
    display: block;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 16px 18px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.2s, border-color 0.2s;
  }
  .related-card:hover {
    transform: translateY(-1px);
    border-color: var(--green);
  }
  .related-cat {
    display: inline-block;
    font-size: 10.5px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 100px;
    margin-bottom: 8px;
  }
  .related-cat-log    { background: rgba(15, 41, 34, 0.08); color: var(--green); }
  .related-cat-review { background: rgba(184, 152, 92, 0.15); color: var(--gold); }
  .related-cat-trends { background: rgba(70, 110, 200, 0.10); color: #2E5BBA; }
  .related-cat-data   { background: rgba(120, 60, 60, 0.10); color: #804040; }
  .related-title {
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.4;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-date {
    font-size: 11px;
    color: var(--grey);
    margin: 0;
  }

  /* CTA */
  .article-cta {
    background: var(--ink);
    color: white;
    padding: 36px 32px;
    border-radius: 8px;
    margin-top: 36px;
    text-align: center;
  }
  .cta-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--gold-soft);
    margin: 0 0 8px;
  }
  .article-cta h3 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .cta-body {
    font-size: 14.5px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: 0 auto 24px;
  }
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .cta-btn {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    padding: 12px 22px;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .cta-btn-primary {
    background: var(--gold);
    color: var(--ink);
  }
  .cta-btn-primary:hover { background: var(--gold-soft); transform: translateX(2px); }
  .cta-btn-ghost {
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .cta-btn-ghost:hover {
    background: rgba(255, 255, 255, 0.06);
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 640px) {
    .journal-article { padding: 40px 18px 80px; }
    .article-cta { padding: 28px 22px; }
    .related-entries { padding: 22px 20px; }
    .article-date { width: 100%; margin-left: 0; }
  }
</style>

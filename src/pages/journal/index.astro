---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 모든 일지 가져오기 (draft 제외, 최신순 정렬)
const allEntries = await getCollection('journal', ({ data }) => {
  return data.draft !== true;
});

const entries = allEntries.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 카테고리별 카운트
const counts = {
  log: entries.filter(e => e.data.category === 'log').length,
  review: entries.filter(e => e.data.category === 'review').length,
  trends: entries.filter(e => e.data.category === 'trends').length,
  data: entries.filter(e => e.data.category === 'data').length,
};

// 카테고리 라벨
const categoryLabels: Record<string, { ko: string; emoji: string }> = {
  log:    { ko: '작업 일지',     emoji: '🔧' },
  review: { ko: '샤프트·헤드 리뷰', emoji: '📐' },
  trends: { ko: '장비 트렌드',    emoji: '📊' },
  data:   { ko: '측정 데이터',    emoji: '📏' },
};

// 클럽 라벨
const clubLabels: Record<string, string> = {
  driver: '드라이버',
  fairway: '페어웨이우드',
  hybrid: '하이브리드',
  iron: '아이언',
  wedge: '웨지',
  putter: '퍼터',
  mixed: '복합',
};

// 날짜 포맷터
function formatDate(date: Date) {
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).replace(/\. /g, '.').replace(/\.$/, '');
}
---

<BaseLayout
  title="공작소 일지"
  description="클럽메이커스 공작소장 채기웅의 일지. 매일 들어오는 클럽 작업, 샤프트·헤드 리뷰, 장비 트렌드, 측정 데이터를 짧게 기록합니다. 25년 현장에서 누적되는 자료."
  schemaType="CollectionPage"
  keywords="공작소 일지, 클럽피팅 일지, 샤프트 리뷰, 헤드 리뷰, 골프 장비 트렌드, 클럽 측정 데이터, 채기웅 일지"
>

  <section class="page-hero journal-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">JOURNAL · 공작소 일지</div>
      <h1>매일의 작업이<br/>여기에 쌓입니다</h1>
      <p class="page-hero-subtitle">
        25년 공작소 현장에서 매일 만나는 클럽, 샤프트, 손님의 증상.
        그날 그날의 측정과 진단을 짧게 기록합니다.
      </p>

      {entries.length > 0 && (
        <div class="journal-stats">
          <div class="stat">
            <p class="stat-num">{entries.length}</p>
            <p class="stat-label">개<br/>전체 글</p>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <p class="stat-num">{counts.log}</p>
            <p class="stat-label">개<br/>작업 일지</p>
          </div>
          {counts.review > 0 && (
            <>
              <div class="stat-divider"></div>
              <div class="stat">
                <p class="stat-num">{counts.review}</p>
                <p class="stat-label">개<br/>리뷰</p>
              </div>
            </>
          )}
        </div>
      )}
    </div>
  </section>

  {entries.length === 0 ? (
    <section class="section">
      <div class="section-content-narrow">
        <div class="empty-state">
          <p class="empty-icon">📝</p>
          <h2>곧 첫 글이 올라옵니다</h2>
          <p class="empty-text">
            공작소장이 매주 1~2개씩 짧은 글을 올릴 예정입니다.
            그날의 작업·측정·진단을 기록합니다.
          </p>
          <p class="empty-text">
            <strong>네이버 블로그</strong>에서 그동안의 작업 기록을 먼저 보실 수 있습니다.
          </p>
          <a href="https://blog.naver.com/clubmakers" target="_blank" rel="noopener noreferrer" class="empty-cta">
            네이버 블로그에서 보기 ↗
          </a>
        </div>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="section-content-narrow">
        <p class="section-eyebrow">RECENT · 최근 글</p>

        <div class="journal-list">
          {entries.map((entry) => {
            const cat = categoryLabels[entry.data.category];
            return (
              <a href={`/journal/${entry.slug}`} class="journal-card">
                <div class="journal-meta">
                  <span class={`journal-cat journal-cat-${entry.data.category}`}>
                    {cat.emoji} {cat.ko}
                  </span>
                  {entry.data.clubType && (
                    <span class="journal-club">{clubLabels[entry.data.clubType]}</span>
                  )}
                  <span class="journal-date">{formatDate(entry.data.pubDate)}</span>
                </div>

                <h2 class="journal-title">{entry.data.title}</h2>

                {entry.data.description && (
                  <p class="journal-desc">{entry.data.description}</p>
                )}

                {entry.data.tags && entry.data.tags.length > 0 && (
                  <div class="journal-tags">
                    {entry.data.tags.map((tag) => (
                      <span class="journal-tag">#{tag}</span>
                    ))}
                  </div>
                )}

                <span class="journal-arrow">읽기 →</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="section section-bg-cream">
    <div class="section-content-narrow">
      <p class="section-eyebrow">ABOUT · 일지에 관하여</p>
      <h2>왜 일지를 쓰나요?</h2>
      <p class="about-body">
        24년간 매일 들어오는 클럽이 다 다르고, 손님의 증상도 다 다릅니다.
        그동안 쌓인 자료가 적지 않은데 — 책에는 핵심 원리가, 케이스 스터디에는 큰 사례가,
        일지에는 그날 그날의 작은 기록이 담깁니다.
      </p>
      <p class="about-body">
        하나의 짧은 글이지만 시간이 지나면 <strong>측정 데이터, 샤프트 강도, 손님의 증상이
        검색 가능한 자료로 누적</strong>됩니다. 비슷한 고민을 가진 분이 검색으로 찾아오실 수 있게요.
      </p>

      <div class="about-formats">
        <h3>일지 형식</h3>
        <ul>
          <li><strong>🔧 작업 일지</strong> — 그날의 작업·측정·진단을 짧게. 증상 → 측정 → 진단 → 처방 4단</li>
          <li><strong>📐 샤프트·헤드 리뷰</strong> — 실측 EI 곡선·CPM·무게·시타 소감. 마케팅이 아닌 측정 데이터 우선</li>
          <li><strong>📊 장비 트렌드</strong> — PGA·KLPGA에서 자주 보이는 샤프트, 신제품, 시장 변화 (분기 1회)</li>
          <li><strong>📏 측정 데이터</strong> — 샤프트별 CPM/EI, 헤드별 MOI/CG. 시간이 갈수록 가치가 커집니다</li>
        </ul>
      </div>
    </div>
  </section>

</BaseLayout>


<style>
  .journal-hero { background: var(--bg-cream); }
  .page-hero h1 { margin-bottom: 1.5rem; }
  .page-hero-subtitle { margin-bottom: 2.5rem; }

  /* 통계 행 */
  .journal-stats {
    display: inline-flex;
    align-items: center;
    gap: 28px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 18px 28px;
    margin-top: 0.5rem;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 700;
    color: var(--green);
    line-height: 1;
    margin: 0 0 4px;
  }
  .stat-label {
    font-size: 11px;
    color: var(--grey);
    margin: 0;
    line-height: 1.4;
  }
  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--line);
  }

  /* 빈 상태 */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--bg-soft);
    border-radius: 8px;
    border: 1px dashed var(--line);
  }
  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }
  .empty-state h2 {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 16px;
  }
  .empty-text {
    font-size: 15px;
    line-height: 1.85;
    color: var(--ink-2);
    margin-bottom: 14px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .empty-text strong {
    color: var(--ink);
    font-weight: 600;
  }
  .empty-cta {
    display: inline-block;
    background: #03C75A;
    color: white;
    padding: 12px 24px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    margin-top: 8px;
    transition: opacity 0.2s, transform 0.2s;
  }
  .empty-cta:hover {
    opacity: 0.9;
    transform: translateX(2px);
  }

  /* 일지 카드 리스트 */
  .journal-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 28px;
  }
  .journal-card {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 24px 28px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    display: block;
  }
  .journal-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(15, 41, 34, 0.08);
    border-color: var(--green);
  }

  .journal-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .journal-cat {
    display: inline-block;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 4px 10px;
    border-radius: 100px;
  }
  .journal-cat-log    { background: rgba(15, 41, 34, 0.08); color: var(--green); }
  .journal-cat-review { background: rgba(184, 152, 92, 0.15); color: var(--gold); }
  .journal-cat-trends { background: rgba(70, 110, 200, 0.10); color: #2E5BBA; }
  .journal-cat-data   { background: rgba(120, 60, 60, 0.10); color: #804040; }

  .journal-club {
    display: inline-block;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--grey);
    padding: 4px 10px;
    border: 1px solid var(--line);
    border-radius: 100px;
  }
  .journal-date {
    font-size: 12px;
    color: var(--grey);
    margin-left: auto;
  }

  .journal-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.4;
    margin: 0 0 8px;
  }
  .journal-desc {
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0 0 12px;
  }
  .journal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 12px;
  }
  .journal-tag {
    font-size: 11.5px;
    color: var(--grey);
    padding: 3px 8px;
    background: var(--bg-soft);
    border-radius: 100px;
  }
  .journal-arrow {
    font-size: 13px;
    font-weight: 600;
    color: var(--green);
    letter-spacing: 0.03em;
  }
  .journal-card:hover .journal-arrow {
    color: var(--gold);
  }

  /* About 섹션 */
  .about-body {
    font-size: 16px;
    line-height: 1.85;
    color: var(--ink-2);
    margin-bottom: 18px;
  }
  .about-body strong {
    color: var(--ink);
    font-weight: 600;
  }
  .about-formats {
    margin-top: 28px;
    padding: 24px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
  }
  .about-formats h3 {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .about-formats ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about-formats li {
    padding: 10px 0;
    font-size: 14px;
    line-height: 1.7;
    color: var(--ink-2);
    border-bottom: 1px solid var(--line-soft, var(--line));
  }
  .about-formats li:last-child { border-bottom: none; }
  .about-formats strong {
    color: var(--ink);
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .journal-stats { padding: 14px 20px; gap: 18px; }
    .stat-num { font-size: 22px; }
    .journal-card { padding: 20px 22px; }
    .journal-title { font-size: 18px; }
    .journal-meta { gap: 6px; }
    .journal-date { width: 100%; margin-left: 0; }
  }
</style>

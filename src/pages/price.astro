<BaseLayout title={pageTitle} description={pageDescription} keywords={pageKeywords} schemaType="CollectionPage" extraSchema={priceSchema}>

  <!-- 히어로 -->
  <section class="page-hero price-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">PRICE · 부품 가격표</div>
      <h1>그립 · 샤프트 가격표</h1>
      <p class="page-hero-subtitle">
        골프채공작소에서 주문·장착 가능한 그립과 샤프트 가격입니다.
        대부분 주문 시 총판을 통해 준비해 드립니다.
      </p>
      <p class="price-hero-positioning">
        단순 부품 교체가 아니라, <strong>25년 경력의 클럽피팅과 함께</strong> 진행합니다.
        같은 샤프트도 사용자의 스윙에 맞춰 길이·강도·밸런스를 잡아야 제 성능이 나옵니다.
      </p>
    </div>
  </section>

  <!-- 안내 박스 -->
  <section class="section">
    <div class="section-content-narrow">
      <aside class="price-notice">
        <p class="price-notice-title">표시 가격 안내</p>
        <ul class="price-notice-list">
          <li><strong>그립</strong>은 표시 금액에 <strong>교체 공임이 포함</strong>되어 있습니다.</li>
          <li><strong>샤프트</strong>는 표시 금액이 <strong>부품 가격</strong>이며, <strong>장착·교체 공임은 별도</strong>입니다.</li>
          <li>대부분의 제품은 <strong>주문 시 총판을 통해 준비</strong>해 드립니다. 재고 보유 여부는 문의 부탁드립니다.</li>
          <li>샤프트 공임은 <a href="/workshop#estimate">작업 가격 계산기</a>에서 확인하실 수 있습니다.</li>
          <li>가격은 변동될 수 있으니, 정확한 안내는 문의 부탁드립니다.</li>
        </ul>
        <div class="price-notice-cta">
          <a href="https://open.kakao.com/o/sLAG3lbb" target="_blank" rel="noopener" class="price-btn price-btn-kakao">카카오톡 문의</a>
          <a href="tel:010-4363-5555" class="price-btn price-btn-call">전화 010-4363-5555</a>
        </div>
      </aside>

      <!-- 대표 제품 소개 카드 (productInfo → 카드 + 스키마 + 본문 동시 출력) -->
      <div class="product-intro">
        <h2 class="product-intro-title">대표 제품 소개</h2>
        <p class="product-intro-desc">
          자주 찾으시는 대표 모델의 특징과 추천 대상입니다. 아래 태그를 누르면 해당 제품이 강조됩니다. 전체 목록·가격은 하단 표에서 확인하실 수 있습니다.
        </p>

        <!-- 상단 태그(한 줄 전체). 누르면 해당 태그 카드 강조 + 첫 카드로 이동 -->
        <nav class="product-tags" aria-label="태그로 보기">
          <button class="product-tag is-active" data-tag="" type="button">전체</button>
          {[...new Set(productInfo.flatMap((p) => p.tags))].map((tag) => (
            <button class="product-tag" data-tag={tag} type="button">{tag}</button>
          ))}
        </nav>

        {[...new Set(productInfo.map((p) => p.usage))].map((usage) => {
          const slug = usage.replace(/\s+/g, '-');
          const brandsInUsage = [...new Set(productInfo.filter((p) => p.usage === usage).map((p) => p.brand))];
          return (
            <div class="product-intro-cat" id={`u-${slug}`}>
              <h3 class="product-intro-cat-title">{usage}</h3>
              {brandsInUsage.map((b) => (
                <div class="product-brand-block">
                  <h4 class="product-brand-label">{b}</h4>
                  <div class="product-grid">
                    {productInfo.filter((p) => p.usage === usage && p.brand === b).map((p) => (
                      <article
                        class="product-card"
                        data-name={(p.brand + ' ' + p.model).toLowerCase()}
                        data-brand-name={p.brand.toLowerCase()}
                        data-tags={p.tags.join('|')}
                      >
                        {p.image
                          ? <img class="product-card-img" src={p.image} alt={p.brand + ' ' + p.model} loading="lazy" />
                          : null}
                        <div class="product-card-body">
                          <div class="product-card-head">
                            <span class="product-card-tag">{p.tag}</span>
                            {p.isNew && <span class="product-card-new">신제품</span>}
                          </div>
                          <h5 class="product-card-model">{p.model}</h5>
                          <p class="product-card-spec">{p.weight}</p>
                          <p class="product-card-summary">{p.summary}</p>
                          <p class="product-card-features">{p.features}</p>
                          <div class="product-card-rec">
                            <span class="product-card-rec-label">이런 분께 추천</span>
                            <span class="product-card-rec-text">{p.recommendedFor}</span>
                          </div>
                          <div class="product-card-chips">
                            {p.tags.map((t) => (<span class="product-card-chip" data-chip={t}>{t}</span>))}
                          </div>
                          <div class="product-card-foot">
                            <span class="product-card-price">
                              {fmt(p.priceFrom)}원~ <em>{p.category === '그립' ? '교체비 포함' : '부품가 · 공임 별도'}</em>
                            </span>
                            {p.officialUrl && <a class="product-card-link" href={p.officialUrl} target="_blank" rel="noopener">공식 정보 ↗</a>}
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          );
        })}
        <p class="product-intro-empty" id="cardEmpty" style="display:none;">
          검색과 일치하는 대표 제품 소개가 없습니다. 아래 전체 가격표를 확인해 주세요.
        </p>
      </div>

      <!-- 대표 제품 Product 스키마 -->
      <script type="application/ld+json" set:html={JSON.stringify(productListSchema)} />

      <!-- 검색 -->
      <div class="price-search-wrap">
        <input type="text" id="priceSearch" class="price-search" placeholder="제품명·브랜드 검색 (예: 텐세이, 다이나믹골드, MCC)" />
        <p class="price-search-hint" id="searchHint"></p>
      </div>

      <!-- 가격표 -->
      {priceData.map((cat) => (
        <div class="price-category" data-category={cat.category}>
          <h2 class="price-cat-title">{cat.category}</h2>
          {cat.brands.map((br) => (
            <div class="price-brand" data-brand={br.brand}>
              <h3 class="price-brand-title">{br.brand}</h3>
              <table class="price-table">
                <tbody>
                  {br.items.map((item) => (
                    <tr class="price-row" data-name={item.name.toLowerCase()} data-brand-name={br.brand.toLowerCase()}>
                      <td class="price-name">{item.name}</td>
                      <td class="price-value">{fmt(item.price)}원</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ))}
        </div>
      ))}

      <p class="price-footer-note">
        ※ 그립 가격은 교체 공임 포함, 샤프트 가격은 부품가이며 장착 공임은 별도입니다.
        대부분 주문 시 총판을 통해 준비해 드리며, 가격은 변동될 수 있습니다. 정확한 견적은 클럽을 직접 보고 안내드립니다.
      </p>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function () {
    var input = document.getElementById('priceSearch');
    var hint = document.getElementById('searchHint');
    if (!input) return;

    function normalize(s) { return (s || '').toLowerCase().replace(/\s+/g, ''); }

    input.addEventListener('input', function () {
      var q = normalize(input.value);
      var rows = document.querySelectorAll('.price-row');
      var shown = 0;

      rows.forEach(function (row) {
        var name = (row.getAttribute('data-name') || '').replace(/\s+/g, '');
        var brand = (row.getAttribute('data-brand-name') || '').replace(/\s+/g, '');
        var match = !q || name.indexOf(q) > -1 || brand.indexOf(q) > -1;
        row.style.display = match ? '' : 'none';
        if (match) shown++;
      });

      // 빈 브랜드·카테고리 숨기기
      document.querySelectorAll('.price-brand').forEach(function (bd) {
        var visible = bd.querySelectorAll('.price-row:not([style*="none"])').length;
        bd.style.display = visible ? '' : 'none';
      });
      document.querySelectorAll('.price-category').forEach(function (ct) {
        var visible = ct.querySelectorAll('.price-row:not([style*="none"])').length;
        ct.style.display = visible ? '' : 'none';
      });

      // 대표 제품 소개 카드도 함께 필터
      var cards = document.querySelectorAll('.product-card');
      var cardShown = 0;
      cards.forEach(function (card) {
        var name = (card.getAttribute('data-name') || '').replace(/\s+/g, '');
        var brand = (card.getAttribute('data-brand-name') || '').replace(/\s+/g, '');
        var match = !q || name.indexOf(q) > -1 || brand.indexOf(q) > -1;
        card.style.display = match ? '' : 'none';
        if (match) cardShown++;
      });
      document.querySelectorAll('.product-brand-block').forEach(function (bb) {
        var visible = bb.querySelectorAll('.product-card:not([style*="none"])').length;
        bb.style.display = visible ? '' : 'none';
      });
      document.querySelectorAll('.product-intro-cat').forEach(function (cc) {
        var visible = cc.querySelectorAll('.product-card:not([style*="none"])').length;
        cc.style.display = visible ? '' : 'none';
      });
      var cardEmpty = document.getElementById('cardEmpty');
      if (cardEmpty) cardEmpty.style.display = (q && cardShown === 0) ? '' : 'none';

      hint.textContent = q ? (shown + '개 제품 검색됨') : '';
    });
  })();
</script>

<script is:inline>
  // 상단 태그 → 해당 태그 카드 강조(숨기지 않음) + 첫 카드로 부드럽게 이동
  (function () {
    var tagBtns = document.querySelectorAll('.product-tag');
    if (!tagBtns.length) return;
    var activeTag = '';

    function apply(tag) {
      var cards = document.querySelectorAll('.product-card');
      cards.forEach(function (card) {
        var tags = (card.getAttribute('data-tags') || '').split('|');
        var on = tag && tags.indexOf(tag) > -1;
        card.classList.remove('is-revealed'); // 새 태그 선택 시 개별 선명화 초기화
        card.classList.toggle('is-highlight', !!on);
        card.classList.toggle('is-dim', !!tag && !on);
        // 카드 안 칩도 해당 태그 강조
        card.querySelectorAll('.product-card-chip').forEach(function (chip) {
          chip.classList.toggle('is-on', tag && chip.getAttribute('data-chip') === tag);
        });
      });
      // 첫 강조 카드로 스크롤
      if (tag) {
        var first = document.querySelector('.product-card.is-highlight');
        if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }

    tagBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var tag = btn.getAttribute('data-tag') || '';
        // 같은 태그 다시 누르면 해제(전체로)
        if (tag && tag === activeTag) { tag = ''; }
        activeTag = tag;
        tagBtns.forEach(function (b) {
          b.classList.toggle('is-active', (b.getAttribute('data-tag') || '') === tag);
        });
        apply(tag);
      });
    });

    // 카드 안의 칩을 눌러도 같은 태그로 강조
    document.querySelectorAll('.product-card-chip').forEach(function (chip) {
      chip.addEventListener('click', function (e) {
        e.stopPropagation();
        var tag = chip.getAttribute('data-chip') || '';
        var btn = document.querySelector('.product-tag[data-tag="' + tag + '"]');
        if (btn) btn.click();
      });
    });

    // 흐려진 카드를 직접 탭하면 그 카드만 선명하게(흐림 해제)
    document.querySelectorAll('.product-card').forEach(function (card) {
      card.addEventListener('click', function (e) {
        // 카드 안 링크(공식 정보)는 그대로 동작
        if (e.target.closest('a')) return;
        if (card.classList.contains('is-dim')) {
          card.classList.remove('is-dim');
          card.classList.add('is-revealed');
        }
      });
    });
  })();
</script>

<style>

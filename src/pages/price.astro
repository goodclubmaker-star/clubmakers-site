// productInfo → Product 스키마 (ItemList). 단일 데이터에서 자동 생성.
const productListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '대표 그립·샤프트 제품 소개 — 골프채공작소 클럽메이커스',
  itemListElement: productInfo.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `${p.brand} ${p.model}`,
      category: p.type,
      description: p.summary,
      brand: { '@type': 'Brand', name: p.brand },
      ...(p.priceFrom
        ? {
            offers: {
              '@type': 'Offer',
              priceCurrency: 'KRW',
              price: p.priceFrom,
              availability: 'https://schema.org/InStock',
              seller: { '@type': 'LocalBusiness', name: '골프채공작소 클럽메이커스' },
            },
          }
        : {}),
    },
  })),
};

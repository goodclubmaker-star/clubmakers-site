---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content as GlossaryContent } from '../content/glossary/index.md';

// AI 검색용 DefinedTermSet schema
const glossarySchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': 'https://myclubmakers.com/glossary#glossary',
  name: '클럽메이커스 골프 피팅 용어사전',
  alternateName: 'Clubmakers Glossary',
  description: '클럽피팅·클럽메이킹 현장에서 정리한 109개 용어. 헤드·샤프트, 그립, 길이·밸런스, 라이·로프트의 4가지 작업 카테고리와 스윙·신체·데이터 분석 시스템까지 사이트 내부 페이지로 직접 연결됩니다.',
  inLanguage: 'ko-KR',
  numberOfItems: 109,
  publisher: {
    '@type': 'Organization',
    name: '클럽메이커스',
    url: 'https://myclubmakers.com',
  },
  author: {
    '@type': 'Person',
    name: '채기웅',
    jobTitle: '클럽메이커스 공작소장',
    url: 'https://myclubmakers.com/about',
  },
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: '골프 클럽피팅 용어사전 — 109개 핵심 용어',
  description: '라이각, MOI, CPM, 트랙맨 31개 데이터, 키네마틱 시퀀스, 제로토크 퍼터까지. 공작소가 정리한 109개 골프 피팅 용어 정의.',
  author: {
    '@type': 'Person',
    name: '채기웅',
    url: 'https://myclubmakers.com/about',
  },
  publisher: { '@type': 'Organization', name: '클럽메이커스' },
  inLanguage: 'ko-KR',
};
---

<BaseLayout
  title="용어사전 (109개)"
  description="클럽메이커스 골프 피팅 용어사전 109개. 라이각·MOI·CPM·트랙맨 31개 데이터·키네마틱 시퀀스·제로토크 퍼터까지. 공작소가 정리한 클럽피팅·클럽메이킹 용어 정의."
  schemaType="CollectionPage"
  keywords="클럽피팅 용어, 골프 용어사전, 라이각, MOI, CPM, 토크, 스윙웨이트, 페이스앵글, 클럽패스, D-Plane, 트랙맨, kinematic sequence, club fitting glossary, 키네마틱 시퀀스, TPI, WTF, 제로토크 퍼터, LS 드라이버, FLO"
  extraSchema={[glossarySchema, articleSchema]}
>

  <!-- 6-1. 히어로 -->
  <section class="page-hero glossary-hero">
    <div class="page-hero-content">
      <div class="page-hero-eyebrow">GLOSSARY · 용어사전</div>
      <h1>109개 핵심 용어</h1>
      <p class="page-hero-subtitle">
        클럽메이커스 현장에서 정리한 클럽피팅·클럽메이킹 용어사전입니다.<br/>
        <strong>골퍼와 피팅 전문가 양쪽이 모두 읽을 수 있도록</strong> — 첫 한 줄은 누구나 이해할 수 있게,
        다음 단락은 깊이 있게 정리했습니다. 각 용어는 사이트의 <strong>공작소 작업</strong> 또는 <strong>분석 시스템</strong> 페이지로 바로 연결됩니다.
      </p>
    </div>
  </section>

  <!-- 6-2. 검색 + 카테고리 필터 -->
  <section class="filter-section">
    <div class="filter-bar">
      <input
        type="search"
        id="glossary-search"
        class="search-input"
        placeholder="용어 검색 (예: 라이각, MOI, 트랙맨, 키네마틱)"
        aria-label="용어 검색"
      />
      <div class="filter-tags" id="filter-tags">
        <button class="filter-tag active" data-filter="all">전체 109</button>
        <button class="filter-tag" data-filter="head-shaft">🔧 헤드·샤프트</button>
        <button class="filter-tag" data-filter="grip">✊ 그립</button>
        <button class="filter-tag" data-filter="length-balance">⚖️ 길이·밸런스</button>
        <button class="filter-tag" data-filter="lie-loft">📐 라이·로프트</button>
        <button class="filter-tag" data-filter="system">📊 시스템·분석</button>
        <button class="filter-tag" data-filter="other">📚 기타</button>
      </div>
    </div>
  </section>

  <!-- 6-3. 본문 — markdown 렌더링 -->
  <section class="glossary-content-section">
    <div class="glossary-prose">
      <GlossaryContent />
    </div>
    <p id="no-results-msg" class="no-results-msg" style="display:none;">
      검색 결과가 없습니다. 다른 키워드로 시도해보세요.
    </p>
  </section>

  <!-- 6-4. CTA -->
  <section class="section section-bg-green glossary-cta">
    <div class="section-content-narrow">
      <p class="section-eyebrow apply-eyebrow">FROM THE BOOK · 책에서 더 자세히</p>
      <h2 class="cta-h2">『실제적인 클럽피팅』<br>부록 D · 용어 · 수치 참조표</h2>
      <p class="cta-body">
        이 사이트의 109개 용어는 시작점입니다. 책에는 부록 D <strong>「용어 · 수치 참조표 (Glossary)」</strong>가
        별도로 있어, 각 용어와 함께 현장 판단의 수치 기준이 정리되어 있습니다.
      </p>
      <div class="cta-actions">
        <a href="/book" class="cta-btn cta-btn-primary">책 자세히 →</a>
        <a href="/contact" class="cta-btn">예약·문의 →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .glossary-hero {
    background: var(--bg-cream);
    border-bottom: none;
  }

  /* ===== 검색·필터 ===== */
  .filter-section {
    position: sticky;
    top: 60px;
    z-index: 30;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
    padding: 20px 80px;
  }
  .filter-bar {
    max-width: 1080px;
    margin: 0 auto;
  }
  .search-input {
    width: 100%;
    padding: 14px 20px;
    font-size: 15px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg-soft);
    font-family: var(--font-sans);
    color: var(--ink);
    margin-bottom: 14px;
    transition: border-color 0.2s, background 0.2s;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--green);
    background: white;
  }
  .filter-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .filter-tag {
    background: white;
    border: 1px solid var(--line);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 13px;
    color: var(--ink-2);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-sans);
  }
  .filter-tag:hover {
    border-color: var(--green);
    background: var(--bg-soft);
  }
  .filter-tag.active {
    background: var(--green);
    color: var(--cream);
    border-color: var(--green);
    font-weight: 600;
  }

  /* ===== Markdown prose 스타일 ===== */
  .glossary-content-section {
    padding: 60px 80px 100px;
    background: var(--bg);
  }
  .glossary-prose {
    max-width: 820px;
    margin: 0 auto;
    font-size: 15.5px;
    line-height: 1.8;
    color: var(--ink-2);
  }

  /* H1 — 페이지 최상단 ("# 클럽메이커스 용어사전") 숨김 (히어로에 이미 있음) */
  .glossary-prose :global(h1) {
    display: none;
  }

  /* 도입 인용문 */
  .glossary-prose :global(blockquote) {
    background: var(--bg-cream);
    border-left: 3px solid var(--gold);
    padding: 24px 30px;
    margin: 24px 0;
    font-family: var(--font-serif);
    font-size: 15.5px;
    line-height: 1.8;
    color: var(--ink);
  }
  .glossary-prose :global(blockquote strong) {
    color: var(--green);
    font-weight: 700;
  }
  .glossary-prose :global(blockquote em) {
    color: var(--green);
    font-style: italic;
  }

  /* 메타데이터 코드 블록은 숨김 */
  .glossary-prose :global(pre) {
    display: none;
  }

  /* H2 — 가나다 분류 (## ㄱ, ## ㄴ ...) */
  .glossary-prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 56px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: -0.02em;
    margin: 80px 0 32px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--line);
    line-height: 1;
  }

  /* H3 — 개별 용어 헤더 */
  .glossary-prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.015em;
    margin: 36px 0 8px;
    line-height: 1.35;
    scroll-margin-top: 200px;
  }

  /* 영문 이탤릭 */
  .glossary-prose :global(p em:only-child) {
    color: var(--gold);
    font-size: 13px;
    letter-spacing: 0.05em;
    font-weight: 600;
    font-style: normal;
  }

  /* 한 줄 정의 (>) */
  .glossary-prose :global(h3 + p + blockquote),
  .glossary-prose :global(h3 ~ blockquote) {
    background: var(--bg-soft);
    border-left: 3px solid var(--green);
    padding: 18px 24px;
    margin: 12px 0 18px;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    font-family: var(--font-sans);
    font-weight: 500;
    font-style: normal;
  }

  /* 일반 단락 */
  .glossary-prose :global(p) {
    margin: 12px 0;
    color: var(--ink-2);
  }
  .glossary-prose :global(p strong) {
    color: var(--ink);
    font-weight: 700;
  }

  /* 리스트 */
  .glossary-prose :global(ul), .glossary-prose :global(ol) {
    margin: 12px 0;
    padding-left: 22px;
  }
  .glossary-prose :global(li) {
    margin: 6px 0;
    line-height: 1.65;
  }

  /* 링크 */
  .glossary-prose :global(a) {
    color: var(--green);
    border-bottom: 1px solid var(--green);
    padding-bottom: 1px;
    transition: opacity 0.2s;
  }
  .glossary-prose :global(a:hover) {
    opacity: 0.7;
  }

  /* 가로선 (---) — 용어 사이 구분선 */
  .glossary-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line-soft, var(--line));
    margin: 32px 0;
  }

  /* 코드 (인라인) */
  .glossary-prose :global(code) {
    background: var(--bg-soft);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: 'SFMono-Regular', Consolas, monospace;
    font-size: 0.92em;
    color: var(--green);
  }

  /* 표 */
  .glossary-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  .glossary-prose :global(table th),
  .glossary-prose :global(table td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    text-align: left;
  }
  .glossary-prose :global(table th) {
    background: var(--bg-soft);
    font-weight: 700;
  }

  /* 검색 결과 없음 메시지 */
  .no-results-msg {
    max-width: 820px;
    margin: 60px auto 0;
    text-align: center;
    color: var(--grey);
    font-size: 15px;
    padding: 40px;
    background: var(--bg-soft);
    border-radius: 6px;
  }

  /* ===== CTA ===== */
  .glossary-cta {
    text-align: center;
  }
  .apply-eyebrow { color: var(--gold-soft) !important; }
  .cta-h2 {
    color: var(--cream);
    text-align: center;
    margin-bottom: 24px;
  }
  .cta-body {
    font-size: 16px;
    line-height: 1.85;
    color: var(--grey-3, rgba(255,255,255,0.85));
    max-width: 580px;
    margin: 0 auto 32px;
  }
  .cta-body strong { color: var(--gold-soft); font-weight: 700; }
  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-btn {
    background: rgba(212, 184, 136, 0.1);
    border: 1px solid rgba(212, 184, 136, 0.3);
    color: var(--cream);
    padding: 14px 26px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.2s;
  }
  .cta-btn:hover { background: rgba(212, 184, 136, 0.2); }
  .cta-btn-primary {
    background: var(--gold);
    color: var(--green-deep);
    border-color: var(--gold);
  }
  .cta-btn-primary:hover { background: var(--gold-soft); }

  /* ===== 모바일 ===== */
  @media (max-width: 968px) {
    .filter-section {
      padding: 14px 16px;
    }
    .search-input {
      padding: 11px 14px;
      font-size: 14px;
    }
    .filter-tag {
      padding: 7px 12px;
      font-size: 12px;
    }
    .glossary-content-section {
      padding: 40px 24px 80px;
    }
    .glossary-prose {
      font-size: 14.5px;
    }
    .glossary-prose :global(h2) {
      font-size: 40px;
      margin: 50px 0 24px;
    }
    .glossary-prose :global(h3) {
      font-size: 19px;
    }
    .glossary-prose :global(blockquote) {
      padding: 18px 20px;
      font-size: 14px;
    }
    .cta-actions { flex-direction: column; }
  }
</style>

<script is:inline>
  (function() {
    'use strict';

    document.addEventListener('DOMContentLoaded', function() {
      const proseEl = document.querySelector('.glossary-prose');
      if (!proseEl) return;

      // === 1. 모든 용어 H3에 카테고리 매핑 ===
      // 각 용어 본문 안의 링크를 보고 카테고리 결정
      // - "/workshop#head-shaft" 링크 → head-shaft
      // - "/workshop#grip" 링크 → grip
      // - "/workshop#length-balance" 링크 → length-balance
      // - "/workshop#lie-loft" 링크 → lie-loft
      // - "/system" 링크 → system
      // - 링크 없음 → other

      const allH3s = Array.from(proseEl.querySelectorAll('h3'));

      allH3s.forEach(function(h3) {
        h3.classList.add('term-header');

        // 다음 H3 또는 H2 직전까지가 이 용어의 본문
        const blockEls = [h3];
        let next = h3.nextElementSibling;
        while (next && next.tagName !== 'H3' && next.tagName !== 'H2') {
          blockEls.push(next);
          if (next.tagName === 'HR') {
            // HR까지 포함하고 종료
            next = next.nextElementSibling;
            break;
          }
          next = next.nextElementSibling;
        }

        // 본문 안의 링크 검사
        let category = 'other';
        for (let i = 0; i < blockEls.length; i++) {
          const el = blockEls[i];
          const links = el.querySelectorAll ? el.querySelectorAll('a') : [];
          for (let j = 0; j < links.length; j++) {
            const href = links[j].getAttribute('href') || '';
            if (href.indexOf('/workshop#head-shaft') !== -1) { category = 'head-shaft'; break; }
            if (href.indexOf('/workshop#grip') !== -1)       { category = 'grip'; break; }
            if (href.indexOf('/workshop#length-balance') !== -1) { category = 'length-balance'; break; }
            if (href.indexOf('/workshop#lie-loft') !== -1)   { category = 'lie-loft'; break; }
            if (href === '/system' || href.indexOf('/system') === 0 || /\/system$/.test(href)) {
              category = 'system'; break;
            }
          }
          if (category !== 'other') break;
        }

        // 카테고리 데이터 부여
        h3.dataset.category = category;
        blockEls.forEach(function(el) {
          if (el.classList) el.classList.add('term-element');
          if (el.dataset) el.dataset.category = category;
        });
      });

      // === 2. 카테고리 필터 ===
      const filterTags = document.querySelectorAll('.filter-tag');
      let activeFilter = 'all';

      filterTags.forEach(function(tag) {
        tag.addEventListener('click', function() {
          filterTags.forEach(function(t) { t.classList.remove('active'); });
          tag.classList.add('active');
          activeFilter = tag.dataset.filter;
          applyFilters();
        });
      });

      // === 3. 검색 ===
      const searchInput = document.getElementById('glossary-search');
      let searchQuery = '';

      if (searchInput) {
        searchInput.addEventListener('input', function(e) {
          searchQuery = e.target.value.trim().toLowerCase();
          applyFilters();
        });
      }

      // === 4. 필터 적용 ===
      const noResultsMsg = document.getElementById('no-results-msg');

      function applyFilters() {
        const headers = document.querySelectorAll('h3.term-header');
        let visibleCount = 0;

        headers.forEach(function(h3) {
          const cat = h3.dataset.category || 'other';
          const text = h3.textContent.toLowerCase();

          let visible = true;
          if (activeFilter !== 'all' && cat !== activeFilter) {
            visible = false;
          }
          if (searchQuery && text.indexOf(searchQuery) === -1) {
            visible = false;
          }

          if (visible) visibleCount++;

          // h3와 그 이후 다음 H3 직전까지 표시/숨김
          h3.style.display = visible ? '' : 'none';
          let cur = h3.nextElementSibling;
          while (cur && cur.tagName !== 'H3' && cur.tagName !== 'H2') {
            cur.style.display = visible ? '' : 'none';
            const next = cur.nextElementSibling;
            if (cur.tagName === 'HR') break;
            cur = next;
          }
        });

        // 가나다 헤더는 그 아래 보이는 H3가 하나라도 있으면 보이게
        document.querySelectorAll('.glossary-prose h2').forEach(function(h2) {
          let next = h2.nextElementSibling;
          let hasVisible = false;
          while (next && next.tagName !== 'H2') {
            if (next.tagName === 'H3' && next.classList.contains('term-header') && next.style.display !== 'none') {
              hasVisible = true;
              break;
            }
            next = next.nextElementSibling;
          }
          h2.style.display = hasVisible ? '' : 'none';
        });

        if (noResultsMsg) {
          noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      }
    });
  })();
</script>

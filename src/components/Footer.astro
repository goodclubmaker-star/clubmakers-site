<style>
  .footer {
    background: var(--green-deep);
    color: var(--grey-3);
    padding: 80px 80px 40px;
  }
  .footer-grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
  }
  .footer h3 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 14px;
    letter-spacing: -0.02em;
  }
  .footer-tagline {
    font-size: 13px;
    color: var(--gold-soft);
    margin-bottom: 22px;
    letter-spacing: 0.05em;
  }
  .footer-info {
    font-size: 13px;
    line-height: 1.9;
    color: var(--grey-3);
    margin-bottom: 18px;
  }
  .footer-info strong {
    color: var(--cream);
    font-weight: 600;
    letter-spacing: 0.05em;
    display: inline-block;
    width: 50px;
  }
  .footer-info a {
    color: var(--grey-3);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .footer-info a:hover { border-bottom-color: var(--gold-soft); }

  .footer-hours {
    font-size: 12.5px;
    line-height: 1.85;
    color: var(--grey-3);
    padding-top: 16px;
    border-top: 1px solid rgba(212, 184, 136, 0.15);
  }
  .footer-hours strong {
    color: var(--cream);
    font-weight: 600;
    display: inline-block;
    width: 70px;
  }

  .footer-col-title {
    font-size: 11px;
    color: var(--gold-soft);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 18px;
    font-weight: 700;
  }
  .footer-col ul {
    list-style: none;
    font-size: 13px;
    line-height: 2;
  }
  .footer-col a {
    color: var(--grey-3);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--gold-soft); }

  .footer-channels {
    grid-column: 1 / -1;
    background: rgba(212, 184, 136, 0.05);
    border: 1px solid rgba(212, 184, 136, 0.15);
    border-radius: 4px;
    padding: 32px 40px;
    margin-top: 30px;
  }
  .footer-channels-title {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--cream);
    margin-bottom: 12px;
    font-weight: 700;
  }
  .footer-channels-body {
    font-size: 13.5px;
    color: var(--grey-3);
    margin-bottom: 18px;
    line-height: 1.7;
  }
  .footer-channels-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-channels-links a {
    color: var(--gold-soft);
    font-size: 13.5px;
    font-weight: 600;
    border-bottom: 1px solid var(--gold-soft);
    padding-bottom: 2px;
  }
  .footer-channels-links a small {
    font-size: 11px;
    color: var(--grey-3);
    margin-left: 6px;
    border: none;
    padding: 0;
    font-weight: 400;
  }

  .footer-bottom {
    max-width: var(--container-max);
    margin: 0 auto;
    padding-top: 30px;
    border-top: 1px solid rgba(212, 184, 136, 0.15);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--grey);
    letter-spacing: 0.03em;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-since {
    font-family: var(--font-serif);
    color: var(--gold-soft);
    letter-spacing: 0.3em;
    font-weight: 700;
    flex-shrink: 0;
  }

  @media (max-width: 968px) {
    .footer {
      padding: 60px 24px 30px;
    }
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-channels {
      padding: 24px 20px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>

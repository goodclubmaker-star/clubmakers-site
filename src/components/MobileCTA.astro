---
// MobileCTA.astro
// 모바일 화면 하단에 고정되는 CTA 바
// 전화 / 예약·문의 두 개 버튼
// 모바일(720px 이하)에서만 보임, 데스크톱은 자동 숨김
---

<aside class="mobile-cta" aria-label="빠른 연락 메뉴">
  <a href="tel:010-4363-5555" class="mobile-cta-btn mobile-cta-call" aria-label="전화 걸기">
    <span class="mobile-cta-icon" aria-hidden="true">📞</span>
    <span class="mobile-cta-label">
      <span class="mobile-cta-title">전화</span>
      <span class="mobile-cta-sub">010-4363-5555</span>
    </span>
  </a>
  <a href="/contact" class="mobile-cta-btn mobile-cta-book" aria-label="예약 및 문의 페이지로 이동">
    <span class="mobile-cta-icon" aria-hidden="true">💬</span>
    <span class="mobile-cta-label">
      <span class="mobile-cta-title">예약·문의</span>
      <span class="mobile-cta-sub">바로가기 →</span>
    </span>
  </a>
</aside>

<style>
  .mobile-cta {
    /* 모바일 전용 — 데스크톱에서 숨김 */
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid var(--line, #EAE7E0);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.06);
    padding: 8px;
    gap: 6px;
    /* iOS Safari 안전 영역 (홈 인디케이터 회피) */
    padding-bottom: calc(8px + env(safe-area-inset-bottom, 0px));
  }

  /* 모바일에서만 표시 */
  @media (max-width: 720px) {
    .mobile-cta {
      display: flex;
    }

    /* body 하단 패딩 — CTA 바가 콘텐츠 가리지 않게 */
    :global(body) {
      padding-bottom: 76px;
    }
  }

  .mobile-cta-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    font-family: var(--font-sans, sans-serif);
    transition: transform 0.15s, opacity 0.15s;
    min-height: 56px;
  }
  .mobile-cta-btn:active {
    transform: scale(0.97);
    opacity: 0.85;
  }

  .mobile-cta-call {
    background: var(--green, #0F2922);
    color: white;
  }
  .mobile-cta-book {
    background: var(--gold, #B8985C);
    color: var(--ink, #0F0F0E);
  }

  .mobile-cta-icon {
    font-size: 22px;
    line-height: 1;
    flex-shrink: 0;
  }
  .mobile-cta-label {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.2;
  }
  .mobile-cta-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .mobile-cta-sub {
    font-size: 11px;
    opacity: 0.85;
    margin-top: 2px;
    font-weight: 500;
  }

  /* 매우 작은 화면 (360px 이하) — 부제 숨김 */
  @media (max-width: 360px) {
    .mobile-cta-sub {
      display: none;
    }
    .mobile-cta-btn {
      min-height: 48px;
    }
  }
</style>

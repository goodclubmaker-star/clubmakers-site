---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schemaType?: 'WebSite' | 'AboutPage' | 'Article' | 'FAQPage' | 'CollectionPage' | 'Course' | 'Person' | 'Book' | 'Service';
  /** 페이지별 추가 JSON-LD를 BaseLayout이 함께 출력하도록 객체나 배열로 전달 */
  extraSchema?: Record<string, unknown> | Record<string, unknown>[];
  /** 키워드 (영문/한글 혼용 가능, 콤마 구분) */
  keywords?: string;
}

const {
  title,
  description = '골프채공작소 클럽메이커스 — 25년 경력 채기웅 공작소장의 클럽피팅·클럽메이킹 전문 골프채공작소. 서울 서초구 양재동. 더 나은 피팅을 하고 싶었습니다.',
  ogImage = '/og-default.jpg',
  schemaType = 'WebSite',
  extraSchema,
  keywords,
} = Astro.props;

const fullTitle = title === '클럽메이커스'
  ? '골프채공작소 클럽메이커스 — 양재 클럽피팅 전문'
  : `${title} | 골프채공작소 클럽메이커스`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="클럽메이커스" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- AI 검색 최적화 (GEO/AEO) -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="채기웅 (골프채공작소 클럽메이커스 공작소장)" />
    <meta name="article:author" content="채기웅" />
    <meta name="publisher" content="골프채공작소 클럽메이커스" />
    <meta name="geo.region" content="KR-11" />
    <meta name="geo.placename" content="서울 서초구 양재동" />
    <meta name="geo.position" content="37.4707;127.0388" />
    <meta name="ICBM" content="37.4707, 127.0388" />

    <!-- schema.org JSON-LD : 페이지 메타 -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": schemaType,
      "name": fullTitle,
      "description": description,
      "url": canonicalUrl,
      "publisher": {
        "@type": "LocalBusiness",
        "@id": "https://myclubmakers.com/#localbusiness",
        "name": "골프채공작소 클럽메이커스"
      }
    })} />

    <!-- schema.org JSON-LD : LocalBusiness (독립, AI 검색 최적화 - GEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://myclubmakers.com/#localbusiness",
      "name": "골프채공작소 클럽메이커스",
      "legalName": "골프채공작소",
      "alternateName": ["골프채공작소", "골프채 공작소", "클럽메이커스", "양재 골프채공작소", "서초 골프채공작소"],
      "description": "골프채공작소 클럽메이커스 — 25년 경력 채기웅 공작소장의 클럽피팅·클럽메이킹 전문 골프채공작소. 서울 서초구 양재동. 친근한 골프채공작소를 지향합니다.",
      "url": "https://myclubmakers.com",
      "telephone": "+82-10-4363-5555",
      "email": "clubmakers@naver.com",
      "image": "https://myclubmakers.com/og-default.jpg",
      "logo": "https://myclubmakers.com/logo.png",
      "priceRange": "₩₩",
      "founder": {
        "@type": "Person",
        "name": "채기웅",
        "jobTitle": "공작소장",
        "url": "https://myclubmakers.com/about"
      },
      "foundingDate": "1985",
      "taxID": "813-01-03827",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "동산로2길 50, 가보빌딩 지하층",
        "addressLocality": "서초구",
        "addressRegion": "서울",
        "postalCode": "06750",
        "addressCountry": "KR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "37.4707",
        "longitude": "127.0388"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "10:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "17:00"
        }
      ],
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": "37.4707",
          "longitude": "127.0388"
        },
        "geoRadius": "50000"
      },
      "knowsAbout": [
        "클럽피팅",
        "클럽메이킹",
        "라이각 조정",
        "리샤프트",
        "MOI 매칭",
        "키네마틱 시퀀스 분석",
        "론치모니터 데이터 해석",
        "K-Vest 분석",
        "골프 샤프트 강도",
        "드라이버 피팅",
        "아이언 피팅",
        "퍼터 피팅",
        "웨지 피팅"
      ],
      "sameAs": [
        "https://blog.naver.com/clubmakers",
        "https://naver.me/GiyUpXkH",
        "https://www.daangn.com/kr/local-profile/yyeaukav6525/"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "74",
        "bestRating": "5",
        "worstRating": "1"
      }
    })} />

    <!-- schema.org JSON-LD : Organization (검색 결과 로고·사이트명 표시) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://myclubmakers.com/#organization",
      "name": "골프채공작소 클럽메이커스",
      "alternateName": ["골프채공작소", "클럽메이커스"],
      "url": "https://myclubmakers.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://myclubmakers.com/logo.png",
        "width": 600,
        "height": 600,
        "caption": "골프채공작소 클럽메이커스"
      },
      "image": "https://myclubmakers.com/og-default.jpg",
      "founder": {
        "@type": "Person",
        "name": "채기웅"
      },
      "foundingDate": "1985",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+82-10-4363-5555",
        "email": "clubmakers@naver.com",
        "contactType": "customer service",
        "areaServed": "KR",
        "availableLanguage": "Korean"
      },
      "sameAs": [
        "https://blog.naver.com/clubmakers",
        "https://naver.me/GiyUpXkH",
        "https://www.daangn.com/kr/local-profile/yyeaukav6525/"
      ]
    })} />

    <!-- schema.org JSON-LD : WebSite (사이트 본체 인식 + 사이트명) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://myclubmakers.com/#website",
      "url": "https://myclubmakers.com",
      "name": "골프채공작소 클럽메이커스",
      "alternateName": "Clubmakers",
      "description": "골프채공작소 클럽메이커스 — 25년 경력 채기웅 공작소장의 클럽피팅·클럽메이킹 전문 골프채공작소",
      "inLanguage": "ko-KR",
      "publisher": {
        "@id": "https://myclubmakers.com/#organization"
      }
    })} />

    {/* 페이지별 추가 JSON-LD */}
    {extraSchema && (Array.isArray(extraSchema) ? extraSchema : [extraSchema]).map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileCTA />
  </body>
</html>

<style>
  main {
    min-height: 60vh;
  }
</style>

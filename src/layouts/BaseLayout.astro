---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schemaType?: 'WebSite' | 'AboutPage' | 'Article' | 'FAQPage' | 'CollectionPage' | 'Course' | 'Person' | 'Book' | 'Service';
  /** 페이지별 추가 JSON-LD를 BaseLayout이 함께 출력하도록 객체나 배열로 전달 */
  extraSchema?: Record<string, unknown> | Record<string, unknown>[];
  /** 키워드 (영문/한글 혼용 가능, 콤마 구분) */
  keywords?: string;
}

const {
  title,
  description = '골프채공작소 클럽메이커스 — 25년 경력 채기웅 공작소장의 클럽피팅·클럽메이킹 전문 골프채공작소. 서울 서초구 양재동. 더 나은 피팅을 하고 싶었습니다.',
  ogImage = '/og-default.jpg',
  schemaType = 'WebSite',
  extraSchema,
  keywords,
} = Astro.props;

const fullTitle = title === '클럽메이커스'
  ? '골프채공작소 클럽메이커스 — 양재 클럽피팅 전문'
  : `${title} | 골프채공작소 클럽메이커스`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

// 플로팅 카카오 챗봇 버튼: 가격표 등 '도착지' 페이지에선 숨김
// (챗봇은 콘텐츠 페이지 → 사이트로 유입시키는 입구 역할이므로)
const hideChatPaths = ['/price'];
const showKakaoChat = !hideChatPaths.some((p) => Astro.url.pathname.startsWith(p));
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- 검색엔진 사이트 소유확인 -->
    <meta name="naver-site-verification" content="30ec15f63a0cfe37bff617de977ca0fb6a3a0aad" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="클럽메이커스" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- AI 검색 최적화 (GEO/AEO) -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="채기웅 (골프채공작소 클럽메이커스 공작소장)" />
    <meta name="article:author" content="채기웅" />
    <meta name="publisher" content="골프채공작소 클럽메이커스" />
    <meta name="geo.region" content="KR-11" />
    <meta name="geo.placename" content="서울 서초구 양재동" />
    <meta name="geo.position" content="37.4707;127.0388" />
    <meta name="ICBM" content="37.4707, 127.0388" />

    <!-- schema.org JSON-LD : 페이지 메타 -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": schemaType,
      "name": fullTitle,
      "description": description,
      "url": canonicalUrl,
      "publisher": {
        "@type": "LocalBusiness",
        "@id": "https://myclubmakers.com/#localbusiness",
        "name": "골프채공작소 클럽메이커스"
      }
    })} />

    <!-- schema.org JSON-LD : LocalBusiness (독립, AI 검색 최적화 - GEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://myclubmakers.com/#localbusiness",
      "name": "골프채공작소 클럽메이커스",
      "legalName": "골프채공작소",
      "alternateName": ["골프채공작소", "골프채 공작소", "클럽메이커스", "양재 골프채공작소", "서초 골프채공작소"],
      "description": "골프채공작소 클럽메이커스 — 25년 경력 채기웅 공작소장의 클럽피팅·클럽메이킹 전문 골프채공작소. 서울 서초구 양재동. 친근한 골프채공작소를 지향합니다.",
      "url": "https://myclubmakers.com",
      "telephone": "+82-10-4363-5555",
      "email": "clubmakers@naver.com",
      "image": "https://myclubmakers.com/og-default.jpg",
      "logo": "https://myclubmakers.com/logo.png",
      "priceRange": "₩₩",
      "founder": {
        "@type": "Person",
        "name": "채기웅",
        "jobTitle": "공작소장",
        "url": "https://myclubmakers.com/about"
      },
      "foundingDate": "1985",
      "taxID": "813-01-03827",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "동산로2길 50, 가보빌딩 지하층",
        "addressLocality": "서초구",
        "addressRegion": "서울",
        "postalCode": "06750",
        "addressCountry": "KR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "37.4707",
        "longitude": "127.0388"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "10:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "17:00"
        }
      ],
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": "37.4707",
          "longitude": "127.0388"
        },
        "geoRadius": "50000"
      },
      "knowsAbout": [
        "클럽피팅",
        "클럽메이킹",
        "라이각 조정",
        "리샤프트",
        "MOI 매칭",
        "키네마틱 시퀀스 분석",
        "론치모니터 데이터 해석",
        "K-Vest 분석",
        "골프 샤프트 강도",
        "드라이버 피팅",
        "아이언 피팅",
        "퍼터 피팅",
        "웨지 피팅"
      ],
      "sameAs": [
        "https://blog.naver.com/clubmakers",
        "https://naver.me/GiyUpXkH",
        "https://www.daangn.com/kr/local-profile/yyeaukav6525/"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "74",
        "bestRating": "5",
        "worstRating": "1"
      }
    })} />

    <!-- schema.org JSON-LD : Organization (검색 결과 로고·사이트명 표시) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://myclubmakers.com/#organization",
      "name": "골프채공작소 클럽메이커스",
      "alternateName": ["골프채공작소", "클럽메이커스"],
      "url": "https://myclubmakers.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://myclubmakers.com/logo.png",
        "width": 600,
        "height": 600,
        "caption": "골프채공작소 클럽메이커스"
      },
      "image": "https://myclubmakers.com/og-default.jpg",
      "founder": {
        "@type": "Person",
        "name": "채기웅"
      },
      "foundingDate": "1985",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+82-10-4363-5555",
        "email": "clubmakers@naver.com",
        "contactType": "customer service",
        "areaServed": "KR",
        "availableLanguage": "Korean"
      },
      "sameAs": [
        "https://blog.naver.com/clubmakers",
        "https://naver.me/GiyUpXkH",
        "https://www.daangn.com/kr/local-profile/yyeaukav6525/"
      ]
    })} />

    <!-- schema.org JSON-LD : WebSite (사이트 본체 인식 + 사이트명) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://myclubmakers.com/#website",
      "url": "https://myclubmakers.com",
      "name": "골프채공작소 클럽메이커스",
      "alternateName": "Clubmakers",
      "description": "골프채공작소 클럽메이커스 — 25년 경력 채기웅 공작소장의 클럽피팅·클럽메이킹 전문 골프채공작소",
      "inLanguage": "ko-KR",
      "publisher": {
        "@id": "https://myclubmakers.com/#organization"
      }
    })} />

    {/* 페이지별 추가 JSON-LD */}
    {extraSchema && (Array.isArray(extraSchema) ? extraSchema : [extraSchema]).map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <MobileCTA />

    {showKakaoChat && (
      <div class="kfab" id="kfab">
        <a class="kfab-row kfab-chat" href="https://pf.kakao.com/_JSVDn/chat" target="_blank" rel="noopener" aria-label="챗봇 연결">
          <span class="kfab-label">챗봇 연결</span>
          <span class="kfab-btn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3C6.5 3 2 6.6 2 11c0 2.8 1.9 5.3 4.7 6.7-.2.7-.7 2.6-.8 3-.1.5.2.5.4.4.2-.1 2.6-1.8 3.6-2.5.7.1 1.4.2 2.1.2 5.5 0 10-3.6 10-8S17.5 3 12 3z"/></svg>
          </span>
        </a>
        <a class="kfab-row kfab-open" href="https://open.kakao.com/o/sLAG3lbb" target="_blank" rel="noopener" aria-label="1:1 문의">
          <span class="kfab-label">1:1 문의</span>
          <span class="kfab-btn kfab-btn-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </span>
        </a>
      </div>
    )}
  </body>
</html>

<style>
  main {
    min-height: 60vh;
  }

  /* 플로팅 카카오 버튼 (챗봇 + 1:1 문의) */
  .kfab {
    position: fixed; right: 18px; bottom: 20px; z-index: 50;
    display: flex; flex-direction: column; align-items: flex-end; gap: 10px;
  }
  .kfab-row { display: flex; align-items: center; gap: 9px; text-decoration: none; }
  .kfab-label {
    background: #fff; border: 1px solid #E5DED1; color: #0F0F0E;
    font-size: 12.5px; font-weight: 600; padding: 7px 12px; border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,.10); white-space: nowrap;
  }
  .kfab-btn {
    width: 56px; height: 56px; border-radius: 50%; flex: 0 0 auto;
    background: #FEE500; color: #3C1E1E;
    box-shadow: 0 6px 20px rgba(0,0,0,.18);
    display: flex; align-items: center; justify-content: center;
    transition: transform .15s;
  }
  .kfab-btn svg { width: 28px; height: 28px; }
  /* 1:1 문의는 살짝 작고 연한 톤으로 위계 */
  .kfab-open .kfab-btn-sm { width: 48px; height: 48px; background: #FEF3A8; }
  .kfab-open .kfab-btn-sm svg { width: 22px; height: 22px; }
  .kfab-open .kfab-label { font-weight: 500; color: #555; }
  .kfab-row:hover .kfab-btn { transform: scale(1.06); }

  @media (max-width: 768px) {
    .kfab { right: 14px; bottom: 84px; gap: 8px; }
    .kfab-label { display: none; }
    .kfab-btn { width: 50px; height: 50px; }
    .kfab-btn svg { width: 24px; height: 24px; }
    .kfab-open .kfab-btn-sm { width: 44px; height: 44px; }
    .kfab-open .kfab-btn-sm svg { width: 20px; height: 20px; }
  }
</style>
